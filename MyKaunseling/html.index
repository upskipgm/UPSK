// RENDER ANALISIS SESI
// ══════════════════════════════════════════
function pgAKSesi(c){ renderSesiPage(c, SES.kampus); }
function pgAUSesi(c){ renderSesiPage(c, null); }

async function renderSesiPage(c, kampusFilter){
  // Load: Sheets > IDB > CSV
  const sesiParsed = await loadTabData("sesi", parseSesiRow, KAUNS_CACHE, "sesi");
  KAUNS_CACHE.sesi = sesiParsed;
  let data = KAUNS_CACHE.sesi || [];
  if(kampusFilter) data = data.filter(d=>(d.organisasi||"").toLowerCase().includes(kObj(kampusFilter).nama?.replace("IPG Kampus ","").toLowerCase()||kampusFilter));

  c.innerHTML = kaunsUploadNotice("sesi","Sesi Kaunseling","#0E7C61");

  // Attach file input
  setTimeout(()=>{
    const fi = document.getElementById("sesi-file-inp");
    if(fi) fi.onchange = function(){ importCSVKauns(this,"sesi"); };
  },100);

  if(!data.length){
    c.innerHTML += `<div style="text-align:center;padding:48px;color:var(--muted);">
      <i class="fas fa-calendar-check" style="font-size:40px;display:block;margin-bottom:14px;opacity:.2;"></i>
      <div style="font-size:14px;font-weight:600;">Tiada data analisis sesi</div>
      <div style="font-size:12px;margin-top:4px;">Muat naik fail CSV untuk papar analisis</div>
    </div>`; return;
  }

  const st = sesiStat(data);
  const colors = ["#0E7C61","#3B82F6","#E88D3A","#8B5CF6","#EF4444","#14B8A6","#F59E0B","#6366F1"];

  c.innerHTML += `
  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,#084A39,#0E7C61);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-10px;top:-20px;width:120px;height:120px;background:rgba(255,255,255,.05);border-radius:50%;"></div>
    <div style="position:relative;">
      <div style="font-size:.7rem;color:rgba(255,255,255,.5);margin-bottom:4px;"><i class="fas fa-calendar-check mr-2"></i>PENGURUSAN KAUNSELING</div>
      <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">Analisis Perkhidmatan Sesi Kaunseling</div>
      <div style="font-size:.78rem;color:rgba(255,255,255,.5);margin-top:3px;">${st.n} rekod · Jumlah klien: ${st.totalJumlah.toLocaleString("ms-MY")}</div>
    </div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Sesi",v:st.n.toLocaleString("ms-MY"),i:"fa-calendar-check",c:"sc-pri",bg:"bg-pri-50",fg:"text-pri-600"},
      {l:"Jumlah Klien",v:st.totalJumlah.toLocaleString("ms-MY"),i:"fa-users",c:"sc-navy",bg:"bg-navy-50",fg:"text-navy-600"},
      {l:"Klien Lelaki",v:st.totalL.toLocaleString("ms-MY"),i:"fa-mars",c:"sc-pri",bg:"bg-blue-50",fg:"text-blue-600",sub:st.totalJumlah?((st.totalL/st.totalJumlah)*100).toFixed(1)+"%":""},
      {l:"Klien Perempuan",v:st.totalP.toLocaleString("ms-MY"),i:"fa-venus",c:"sc-amber",bg:"bg-amb-50",fg:"text-amb-600",sub:st.totalJumlah?((st.totalP/st.totalJumlah)*100).toFixed(1)+"%":""},
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--navy);">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
      ${s.sub?`<div style="font-size:.7rem;color:var(--muted);">${s.sub}</div>`:""}
    </div>`).join("")}
  </div>

  <!-- Kategori Klien -->
  <div class="card" style="margin-bottom:14px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-layer-group text-pri-500 mr-2"></i>Pecahan Klien Mengikut Kategori</span></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;">
        ${[
          {l:"PPP",v:st.totalPPP,c:"#0E7C61"},
          {l:"Peg. Gunasama",v:st.totalPG,c:"#3B82F6"},
          {l:"AKP",v:st.totalAKP,c:"#E88D3A"},
          {l:"Murid/Pelajar",v:st.totalMurid,c:"#8B5CF6"},
          {l:"Komuniti",v:st.totalKomuniti,c:"#EF4444"},
        ].map(k=>`
        <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:14px;border-top:3px solid ${k.c};">
          <div style="font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:800;color:${k.c};">${k.v.toLocaleString("ms-MY")}</div>
          <div style="font-size:.72rem;color:var(--muted);margin-top:3px;">${k.l}</div>
          <div style="font-size:.7rem;color:${k.c};font-weight:600;">${st.totalJumlah?((k.v/st.totalJumlah)*100).toFixed(1)+"%":"—"}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Jenis Sesi + Kategori Isu -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-tag text-amb-500 mr-2"></i>Jenis Sesi</span></div>
      <div class="card-body">
        ${st.byJenis.slice(0,8).map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="width:10px;height:10px;border-radius:50%;background:${colors[i%8]};flex-shrink:0;"></div>
          <div style="font-size:.8rem;flex:1;">${k}</div>
          <div style="width:90px;"><div class="prog"><div class="prog-fill" style="width:${st.byJenis[0]?((v/st.byJenis[0][1])*100).toFixed(0):0}%;background:${colors[i%8]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:40px;text-align:right;">${v.toLocaleString("ms-MY")}</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-list text-navy-500 mr-2"></i>Kategori Isu</span></div>
      <div class="card-body"><canvas id="ch-kategori" height="240"></canvas></div>
    </div>
  </div>

  <!-- Trend Bulanan + Zon -->
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-chart-line text-pri-500 mr-2"></i>Trend Sesi (12 Bulan Terkini)</span></div>
      <div class="card-body"><canvas id="ch-sesi-trend" height="200"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-map-marker-alt text-red-500 mr-2"></i>Mengikut Zon</span></div>
      <div class="card-body">
        ${st.byZon.map(([z,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="font-size:.78rem;flex:1;font-weight:500;">${z}</div>
          <div style="width:80px;"><div class="prog"><div class="prog-fill" style="width:${st.byZon[0]?((v/st.byZon[0][1])*100).toFixed(0):0}%;background:${colors[i%8]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:28px;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Jadual -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-pri-500 mr-2"></i>Rekod Sesi</span>
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="text" class="fi" style="max-width:160px;font-size:.8rem;" placeholder="Cari..." id="sesi-cari" oninput="filterSesi()">
        <select class="fi" style="width:auto;font-size:.8rem;" id="sesi-jenis" onchange="filterSesi()">
          <option value="">Semua Jenis</option>
          ${[...new Set(data.map(d=>d.jenisSesi).filter(Boolean))].map(j=>`<option>${j}</option>`).join("")}
        </select>
        <button class="btn btn-out btn-sm" onclick="exportExcelFromTable('tbl-sesi','Analisis_Sesi')"><i class="fas fa-download"></i>CSV</button>
        <button class="btn btn-ghost btn-sm" onclick="exportPagePDF()"><i class="fas fa-file-pdf" style="color:#DC2626;"></i></button>
      </div>
    </div>
    <div id="sesi-count" style="font-size:.72rem;color:var(--muted);padding:6px 16px;">Menunjukkan ${Math.min(data.length,50)} daripada ${data.length} rekod</div>
    <div style="overflow-x:auto;">${renderSesiTable(data.slice(0,50))}</div>
  </div>`;

  window._sesiData = data;

  setTimeout(()=>{
    if(st.byKategori.length){
      _charts.kategori = new Chart(document.getElementById("ch-kategori"),{
        type:"bar",
        data:{labels:st.byKategori.slice(0,8).map(([k])=>k.length>20?k.slice(0,18)+"..":k),
          datasets:[{data:st.byKategori.slice(0,8).map(([,v])=>v),backgroundColor:"rgba(139,92,246,.75)",borderRadius:4}]},
        options:{responsive:true,indexAxis:"y",plugins:{legend:{display:false}},scales:{x:{beginAtZero:true}}}
      });
    }
    if(st.byBulan.length){
      _charts.sesiTrend = new Chart(document.getElementById("ch-sesi-trend"),{
        type:"line",
        data:{labels:st.byBulan.map(([k])=>k),
          datasets:[{data:st.byBulan.map(([,v])=>v),borderColor:"#0E7C61",backgroundColor:"rgba(14,124,97,.1)",tension:.4,fill:true,pointRadius:3}]},
        options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
      });
    }
  },80);
}

function renderSesiTable(data){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod.</p>`;
  return `<table class="tbl" id="tbl-sesi">
    <thead><tr>
      <th>Tahun</th><th>Bulan</th><th>Zon</th><th>Organisasi</th>
      <th>Jenis Sesi</th><th>Kategori Isu</th>
      <th>PPP</th><th>PG</th><th>AKP</th><th>Murid</th><th>Komuniti</th>
      <th>Jum. L</th><th>Jum. P</th><th>Jumlah</th>
    </tr></thead>
    <tbody>${data.map(d=>`<tr>
      <td>${d.tahun}</td><td>${d.bulan}</td>
      <td><span class="bdg bdg-navy" style="font-size:.65rem;">${d.zon}</span></td>
      <td style="font-size:.75rem;">${d.organisasi}</td>
      <td style="font-size:.75rem;">${d.jenisSesi}</td>
      <td style="font-size:.72rem;">${d.kategoriIsu}</td>
      <td style="text-align:right;">${d.jPPP}</td>
      <td style="text-align:right;">${d.jPG}</td>
      <td style="text-align:right;">${d.jAKP}</td>
      <td style="text-align:right;">${d.jMurid}</td>
      <td style="text-align:right;">${d.jKomuniti}</td>
      <td style="text-align:right;font-weight:600;">${d.jumlahL}</td>
      <td style="text-align:right;font-weight:600;">${d.jumlahP}</td>
      <td style="text-align:right;font-weight:700;color:#0E7C61;">${d.jumlah}</td>
    </tr>`).join("")}</tbody>
  </table>`;
}

function filterSesi(){
  let d = window._sesiData||[];
  const q=(document.getElementById("sesi-cari")?.value||"").toLowerCase();
  const jenis=document.getElementById("sesi-jenis")?.value||"";
  if(q) d=d.filter(x=>(x.organisasi+x.zon+x.jenisSesi+x.kategoriIsu).toLowerCase().includes(q));
  if(jenis) d=d.filter(x=>x.jenisSesi===jenis);
  const el=document.querySelector("#tbl-sesi")?.parentElement;
  if(el) el.innerHTML=renderSesiTable(d.slice(0,50));
  const cnt=document.getElementById("sesi-count");
  if(cnt) cnt.textContent=`Menunjukkan ${Math.min(d.length,50)} daripada ${d.length} rekod`;
}

// ══════════════════════════════════════════
// RENDER ANALISIS PROGRAM
// ══════════════════════════════════════════
function pgAKProgram(c){ renderProgramPage(c, SES.kampus); }
function pgAUProgram(c){ renderProgramPage(c, null); }

async function renderProgramPage(c, kampusFilter){
  // Load: Sheets > IDB > CSV
  const progParsed = await loadTabData("program", parseProgramRow, KAUNS_CACHE, "program");
  KAUNS_CACHE.program = progParsed;
  let data = KAUNS_CACHE.program || [];
  if(kampusFilter) data = data.filter(d=>(d.organisasi||"").toLowerCase().includes(kObj(kampusFilter).nama?.replace("IPG Kampus ","").toLowerCase()||kampusFilter));

  c.innerHTML = kaunsUploadNotice("program","Analisis Program","#3B82F6");

  setTimeout(()=>{
    const fi = document.getElementById("program-file-inp");
    if(fi) fi.onchange = function(){ importCSVKauns(this,"program"); };
  },100);

  if(!data.length){
    c.innerHTML += `<div style="text-align:center;padding:48px;color:var(--muted);">
      <i class="fas fa-chalkboard-teacher" style="font-size:40px;display:block;margin-bottom:14px;opacity:.2;"></i>
      <div style="font-size:14px;font-weight:600;">Tiada data analisis program</div>
      <div style="font-size:12px;margin-top:4px;">Muat naik fail CSV untuk papar analisis</div>
    </div>`; return;
  }

  const st = programStat(data);
  const colors = ["#3B82F6","#0E7C61","#E88D3A","#8B5CF6","#EF4444","#14B8A6","#F59E0B","#6366F1"];

  c.innerHTML += `
  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,#1e3a8a,#3B82F6);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-10px;top:-20px;width:120px;height:120px;background:rgba(255,255,255,.05);border-radius:50%;"></div>
    <div style="position:relative;">
      <div style="font-size:.7rem;color:rgba(255,255,255,.5);margin-bottom:4px;"><i class="fas fa-chalkboard-teacher mr-2"></i>PENGURUSAN KAUNSELING</div>
      <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">Analisis Program Kaunseling</div>
      <div style="font-size:.78rem;color:rgba(255,255,255,.5);margin-top:3px;">${st.n} rekod · Jumlah peserta: ${st.totalJumlah.toLocaleString("ms-MY")}</div>
    </div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Program",v:st.n.toLocaleString("ms-MY"),i:"fa-chalkboard-teacher",c:"sc-navy",bg:"bg-navy-50",fg:"text-navy-600"},
      {l:"Jumlah Peserta",v:st.totalJumlah.toLocaleString("ms-MY"),i:"fa-users",c:"sc-pri",bg:"bg-pri-50",fg:"text-pri-600"},
      {l:"Peserta Lelaki",v:st.totalL.toLocaleString("ms-MY"),i:"fa-mars",c:"sc-pri",bg:"bg-blue-50",fg:"text-blue-600",sub:st.totalJumlah?((st.totalL/st.totalJumlah)*100).toFixed(1)+"%":""},
      {l:"Peserta Perempuan",v:st.totalP.toLocaleString("ms-MY"),i:"fa-venus",c:"sc-amber",bg:"bg-amb-50",fg:"text-amb-600",sub:st.totalJumlah?((st.totalP/st.totalJumlah)*100).toFixed(1)+"%":""},
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--navy);">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
      ${s.sub?`<div style="font-size:.7rem;color:var(--muted);">${s.sub}</div>`:""}
    </div>`).join("")}
  </div>

  <!-- Pecahan Peserta -->
  <div class="card" style="margin-bottom:14px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-layer-group text-blue-500 mr-2"></i>Pecahan Peserta Mengikut Kategori</span></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;">
        ${[
          {l:"PPP",v:st.totalPPP,c:"#3B82F6"},
          {l:"Peg. Gunasama",v:st.totalPG,c:"#0E7C61"},
          {l:"AKP",v:st.totalAKP,c:"#E88D3A"},
          {l:"Murid/Pelajar",v:st.totalMurid,c:"#8B5CF6"},
          {l:"Komuniti",v:st.totalKomuniti,c:"#EF4444"},
        ].map(k=>`
        <div style="text-align:center;background:#f8fafc;border-radius:8px;padding:14px;border-top:3px solid ${k.c};">
          <div style="font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:800;color:${k.c};">${k.v.toLocaleString("ms-MY")}</div>
          <div style="font-size:.72rem;color:var(--muted);margin-top:3px;">${k.l}</div>
          <div style="font-size:.7rem;color:${k.c};font-weight:600;">${st.totalJumlah?((k.v/st.totalJumlah)*100).toFixed(1)+"%":"—"}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Pendekatan + Trend -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-sitemap text-blue-500 mr-2"></i>Pendekatan Program</span></div>
      <div class="card-body">
        ${st.byPendekatan.slice(0,8).map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="width:10px;height:10px;border-radius:50%;background:${colors[i%8]};flex-shrink:0;"></div>
          <div style="font-size:.8rem;flex:1;">${k}</div>
          <div style="width:80px;"><div class="prog"><div class="prog-fill" style="width:${st.byPendekatan[0]?((v/st.byPendekatan[0][1])*100).toFixed(0):0}%;background:${colors[i%8]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:40px;text-align:right;">${v.toLocaleString("ms-MY")}</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-chart-line text-blue-500 mr-2"></i>Trend Program (12 Bulan Terkini)</span></div>
      <div class="card-body"><canvas id="ch-prog-trend" height="220"></canvas></div>
    </div>
  </div>

  <!-- Jadual -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-blue-500 mr-2"></i>Rekod Program</span>
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="text" class="fi" style="max-width:160px;font-size:.8rem;" placeholder="Cari..." id="prog-cari" oninput="filterProgram()">
        <select class="fi" style="width:auto;font-size:.8rem;" id="prog-pend" onchange="filterProgram()">
          <option value="">Semua Pendekatan</option>
          ${[...new Set(data.map(d=>d.pendekatan).filter(Boolean))].map(p=>`<option>${p}</option>`).join("")}
        </select>
        <button class="btn btn-out btn-sm" onclick="exportExcelFromTable('tbl-program','Analisis_Program')"><i class="fas fa-download"></i>CSV</button>
        <button class="btn btn-ghost btn-sm" onclick="exportPagePDF()"><i class="fas fa-file-pdf" style="color:#DC2626;"></i></button>
      </div>
    </div>
    <div id="prog-count" style="font-size:.72rem;color:var(--muted);padding:6px 16px;">Menunjukkan ${Math.min(data.length,50)} daripada ${data.length} rekod</div>
    <div style="overflow-x:auto;">${renderProgramTable(data.slice(0,50))}</div>
  </div>`;

  window._programData = data;

  setTimeout(()=>{
    if(st.byBulan.length){
      _charts.progTrend = new Chart(document.getElementById("ch-prog-trend"),{
        type:"bar",
        data:{labels:st.byBulan.map(([k])=>k),
          datasets:[{data:st.byBulan.map(([,v])=>v),backgroundColor:"rgba(59,130,246,.7)",borderRadius:4}]},
        options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
      });
    }
  },80);
}

function renderProgramTable(data){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod.</p>`;
  return `<table class="tbl" id="tbl-program">
    <thead><tr>
      <th>Tahun</th><th>Bulan</th><th>Zon</th><th>Organisasi</th>
      <th>Pendekatan</th>
      <th>PPP</th><th>PG</th><th>AKP</th><th>Murid</th><th>Komuniti</th>
      <th>Jum. L</th><th>Jum. P</th><th>Jumlah</th>
    </tr></thead>
    <tbody>${data.map(d=>`<tr>
      <td>${d.tahun}</td><td>${d.bulan}</td>
      <td><span class="bdg bdg-blue" style="font-size:.65rem;">${d.zon}</span></td>
      <td style="font-size:.75rem;">${d.organisasi}</td>
      <td style="font-size:.75rem;">${d.pendekatan}</td>
      <td style="text-align:right;">${d.jPPP}</td>
      <td style="text-align:right;">${d.jPG}</td>
      <td style="text-align:right;">${d.jAKP}</td>
      <td style="text-align:right;">${d.jMurid}</td>
      <td style="text-align:right;">${d.jKomuniti}</td>
      <td style="text-align:right;font-weight:600;">${d.jumlahL}</td>
      <td style="text-align:right;font-weight:600;">${d.jumlahP}</td>
      <td style="text-align:right;font-weight:700;color:#3B82F6;">${d.jumlah}</td>
    </tr>`).join("")}</tbody>
  </table>`;
}

function filterProgram(){
  let d = window._programData||[];
  const q=(document.getElementById("prog-cari")?.value||"").toLowerCase();
  const pend=document.getElementById("prog-pend")?.value||"";
  if(q) d=d.filter(x=>(x.organisasi+x.zon+x.pendekatan).toLowerCase().includes(q));
  if(pend) d=d.filter(x=>x.pendekatan===pend);
  const el=document.querySelector("#tbl-program")?.parentElement;
  if(el) el.innerHTML=renderProgramTable(d.slice(0,50));
  const cnt=document.getElementById("prog-count");
  if(cnt) cnt.textContent=`Menunjukkan ${Math.min(d.length,50)} daripada ${d.length} rekod`;
}


// Wrapper parseSesiRow untuk loadTabData (hi not used, index-based)
function _parseEnrolmenRow(row, hi){
  const g = (col) => (row[hi[col]||hi[col.toUpperCase()]]||"").toString().trim();
  const ipgk = g("IPGK") || g("KOD_IPG") || "";
  const kobj = KAMPUS.find(k=>"IPGK"+k.id===ipgk||k.id===ipgk.replace(/^IPGK/,"K"))||{};
  return {
    no_matrik: g("NO_MATRIK"), nama: g("NAMA"), jantina: g("JANTINA"),
    ipgk, zon: g("ZON"),
    kampus_id: kobj.id||ipgk.replace(/^IPGK/,"K"),
    kampus_nama: kobj.nama||ipgk,
    aliran_sekolah: g("ALIRAN SEKOLAH")||g("ALIRAN_SEKOLAH"),
    opsyen_1: g("KOD_OPSYEN_1"), opsyen_2: g("KOD_OPSYEN_2"),
    sesi_ambilan: g("SESI_AMBILAN_PENGAJIAN"),
    sesi_tamat: g("SESI_TAMAT_PENGAJIAN"),
    status_pengajian: g("STATUS_PENGAJIAN")||g("STATUS PENGAJIAN"),
    agama: g("AGAMA"),
    agama_txt: {"1":"Islam","2":"Kristian","3":"Buddha","4":"Hindu","5":"Lain-lain"}[g("AGAMA")]||g("AGAMA"),
    program: g("PROGRAM"), tahun: g("TAHUN"),
    daerah: g("DAERAH"), negeri: g("NEGERI"),
    lat: parseFloat(g("LATITUDE"))||0, lng: parseFloat(g("LONGITUDE"))||0
  };
}

// ══════════════════════════════════════════
// SIDEBAR TOGGLE
// ══════════════════════════════════════════
function toggleSb(){document.getElementById("sidebar").classList.toggle("open");document.getElementById("sb-overlay").classList.toggle("hidden");}
function closeSb(){document.getElementById("sidebar").classList.remove("open");document.getElementById("sb-overlay").classList.add("hidden");}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
renderPortal();
setTimeout(hcInit, 100);
</script>
</body>
</html>
