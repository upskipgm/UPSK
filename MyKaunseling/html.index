  filterPengguna();
}

function filterPengguna(){
  const q=(document.getElementById("fp-cari")?.value||"").toLowerCase();
  const role=document.getElementById("fp-role")?.value||"";
  const zon=document.getElementById("fp-zon")?.value||"";
  const kid=document.getElementById("fp-kampus")?.value||"";
  let d=APP.pengguna.filter(u=>{
    if(q&&!u.id.toLowerCase().includes(q)&&!u.nama.toLowerCase().includes(q))return false;
    if(role&&u.peranan!==role)return false;
    if(kid&&u.kampus!==kid)return false;
    if(zon&&u.kampus){const k=KAMPUS.find(x=>x.id===u.kampus);if(!k||k.zona!==zon)return false;}
    return true;
  });
  const wrap=document.getElementById("tbl-pengguna-wrap");
  const cnt=document.getElementById("fp-count");
  if(wrap)wrap.innerHTML=renderTblPengguna(d);
  if(cnt)cnt.textContent=`Menunjukkan ${d.length} daripada ${APP.pengguna.length} pengguna`;
}

function resetFilterPengguna(){
  ["fp-cari","fp-role","fp-zon","fp-kampus"].forEach(id=>{const el=document.getElementById(id);if(el)el.value="";});
  filterPengguna();
}

function renderTblPengguna(data){
  if(!data.length)return`<p class="text-sm text-gray-400 p-4 text-center">Tiada pengguna ditemui.</p>`;
  return`<table class="tbl">
    <thead><tr><th>ID Pengguna</th><th>Nama</th><th>Jenis Akaun</th><th>Kampus</th><th>Zon</th><th>Kata Laluan</th><th>Tindakan</th></tr></thead>
    <tbody>${data.map(u=>{
      const idx=APP.pengguna.findIndex(x=>x.id===u.id);
      const k=u.kampus?KAMPUS.find(x=>x.id===u.kampus):null;
      return`<tr>
        <td class="font-mono text-xs font-semibold text-navy-700">${u.id}</td>
        <td class="font-medium">${u.nama}</td>
        <td><span class="bdg ${u.peranan==="admin_utama"?"bdg-amber":"bdg-pri"}">${u.peranan==="admin_utama"?"Admin Utama":"Admin Kampus"}</span></td>
        <td class="text-xs">${k?k.nama.replace("IPG Kampus ",""):"Semua Kampus"}</td>
        <td class="text-xs">${k?`<span class="bdg bdg-gray">${k.zona}</span>`:"—"}</td>
        <td>
          <div class="flex items-center gap-1">
            <span class="font-mono text-xs text-gray-400" id="pw-${u.id}">${"•".repeat(Math.min(u.kataLaluan.length,8))}</span>
            <button onclick="togPw('${u.id}','${u.kataLaluan}')" class="text-gray-300 hover:text-gray-500 text-xs ml-1"><i class="fas fa-eye"></i></button>
          </div>
        </td>
        <td>
          <div class="flex gap-1">
            <button onclick="modalPengguna(${idx})" class="btn btn-ghost btn-xs" title="Edit"><i class="fas fa-pen"></i></button>
            ${APP.pengguna.length>1&&u.peranan!=="admin_utama"?`<button onclick="hapusPengguna(${idx})" class="btn btn-danger btn-xs" title="Padam"><i class="fas fa-trash"></i></button>`:""}
          </div>
        </td>
      </tr>`;
    }).join("")}
    </tbody></table>`;
}

function togPw(uid,pw){
  const el=document.getElementById("pw-"+uid);
  if(!el)return;
  el.textContent=el.textContent.includes("•")?pw:"•".repeat(Math.min(pw.length,8));
}

function modalPengguna(idx){
  const isE=idx>=0;
  const u=isE?APP.pengguna[idx]:{id:"",nama:"",peranan:"admin_kampus",kampus:null,kataLaluan:"IPG123"};
  const oldId=u.id;
  document.getElementById("modal-wrap").innerHTML=`
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:520px">

      <!-- Header -->
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-3">
          <div style="width:36px;height:36px;border-radius:8px;background:${isE?"var(--pri)":"var(--navy)"};display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="fas ${isE?"fa-user-pen":"fa-user-plus"} text-white text-sm"></i>
          </div>
          <div>
            <h3 class="font-display font-700 text-lg text-navy-800">${isE?"Kemaskini Maklumat Pengguna":"Tambah Pengguna Baharu"}</h3>
            <div class="text-xs text-gray-400">${isE?"Semua maklumat boleh dikemaskini":"Isi semua maklumat yang diperlukan"}</div>
          </div>
        </div>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
      </div>

      <!-- Divider -->
      <div style="height:1px;background:var(--border);margin-bottom:20px;"></div>

      <div class="space-y-4">

        <!-- ID Pengguna -->
        <div>
          <label class="fl">ID Pengguna <span class="text-red-400">*</span></label>
          <input type="text" id="pu-id" class="fi font-mono"
            value="${u.id}"
            placeholder="Contoh: IPGKBM4"
            ${isE?`oninput="checkIdChange('${oldId}',this.value)"`:""}
          >
          <div class="text-xs mt-1 ${isE?"text-amb-600":"text-gray-400"}" id="pu-id-hint">
            ${isE?`<i class="fas fa-triangle-exclamation mr-1"></i>Perubahan ID akan mempengaruhi log masuk pengguna ini`
                 :"Format cadangan: IPG + Kod Kampus + Nombor (contoh: IPGKBM4)"}
          </div>
        </div>

        <!-- Nama -->
        <div>
          <label class="fl">Nama Penuh <span class="text-red-400">*</span></label>
          <input type="text" id="pu-nama" class="fi" value="${u.nama}" placeholder="Nama penuh pengguna">
        </div>

        <!-- Jenis Akaun -->
        <div>
          <label class="fl">Jenis Akaun <span class="text-red-400">*</span></label>
          <select id="pu-role" class="fi"
            onchange="document.getElementById('pu-krow').classList.toggle('hidden',this.value==='admin_utama')">
            <option value="admin_kampus"${u.peranan==="admin_kampus"?" selected":""}>Admin Kampus</option>
            <option value="admin_utama"${u.peranan==="admin_utama"?" selected":""}>Admin Utama (Kebangsaan)</option>
          </select>
        </div>

        <!-- Kampus -->
        <div id="pu-krow" class="${u.peranan==="admin_utama"?"hidden":""}">
          <label class="fl">Kampus <span class="text-red-400">*</span></label>
          <select id="pu-kampus" class="fi">
            <option value="">— Pilih Kampus —</option>
            ${kampusOptgroup(u.kampus||"")}
          </select>
        </div>

        <!-- Kata Laluan -->
        <div>
          <label class="fl">Kata Laluan <span class="text-red-400">*</span></label>
          <div class="flex gap-2">
            <div class="relative flex-1">
              <input type="text" id="pu-pw" class="fi font-mono"
                value="${u.kataLaluan}"
                placeholder="Masukkan kata laluan">
            </div>
            ${isE?`<button type="button" onclick="document.getElementById('pu-pw').value='IPG123'" class="btn btn-ghost btn-sm whitespace-nowrap" title="Set semula ke IPG123"><i class="fas fa-rotate-left"></i> Set Semula</button>`:""}
          </div>
          <div class="text-xs text-gray-400 mt-1"><i class="fas fa-info-circle mr-1"></i>Kata laluan lalai sistem: <span class="font-mono bg-gray-100 px-1 rounded">IPG123</span></div>
        </div>

        <!-- Butang -->
        <div class="flex gap-3 pt-3 border-t border-gray-100">
          ${isE&&u.peranan!=="admin_utama"?`<button onclick="hapusPengguna(${idx})" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i>Padam</button>`:""}
          <div class="flex-1"></div>
          <button onclick="closeModal()" class="btn btn-ghost">Batal</button>
          <button onclick="simpanPengguna(${idx},'${oldId}')" class="btn btn-pri"><i class="fas fa-save"></i>Simpan Perubahan</button>
        </div>
      </div>
    </div>
  </div>`;
}

function checkIdChange(oldId, newVal){
  const hint = document.getElementById("pu-id-hint");
  if(!hint) return;
  if(newVal.trim() !== oldId){
    hint.innerHTML = `<i class="fas fa-triangle-exclamation mr-1"></i>ID akan ditukar dari <span class="font-mono bg-amber-100 px-1 rounded">${oldId}</span> ke <span class="font-mono bg-green-100 px-1 rounded">${newVal||"..."}</span> — pengguna perlu guna ID baharu untuk log masuk`;
    hint.className = "text-xs mt-1 text-amb-600";
  } else {
    hint.innerHTML = `<i class="fas fa-triangle-exclamation mr-1"></i>Perubahan ID akan mempengaruhi log masuk pengguna ini`;
    hint.className = "text-xs mt-1 text-gray-400";
  }
}

