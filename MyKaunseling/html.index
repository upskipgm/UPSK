    <div class="card-body space-y-4">
      <div><label class="fl">E-mel</label><input type="text" id="hb-emel" class="fi" value="${APP.hubungi.emel}"></div>
      <div><label class="fl">Telefon</label><input type="text" id="hb-tel" class="fi" value="${APP.hubungi.tel}"></div>
      <div><label class="fl">Alamat</label><textarea id="hb-alamat" class="fi" rows="2">${APP.hubungi.alamat}</textarea></div>
      <button onclick="simpanHubungi()" class="btn btn-pri"><i class="fas fa-save"></i>Simpan Perubahan</button>
    </div>
  </div>`;
}

function simpanHubungi(){
  APP.hubungi={emel:document.getElementById("hb-emel").value,tel:document.getElementById("hb-tel").value,alamat:document.getElementById("hb-alamat").value};
  saveApp(); renderPortal(); toast("Maklumat hubungi dikemaskini","ok");
}

