    </div>

    <!-- Kemaskini Kata Laluan Pukal -->
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-key text-amb-500 mr-2"></i>Kemaskini Kata Laluan Pukal</span></div>
      <div class="card-body">
        <p class="text-sm text-gray-500 mb-3">Kemaskini kata laluan untuk semua akaun dalam satu kampus serentak.</p>
        <div class="flex flex-wrap gap-3 items-end">
          <div><label class="fl">Kampus</label><select id="bulk-kampus" class="fi" style="width:240px"><option value="">— Pilih Kampus —</option>${kampusOptgroup()}</select></div>
          <div><label class="fl">Kata Laluan Baru</label><input type="text" id="bulk-pw" class="fi" style="width:160px" placeholder="Contoh: IPG123"></div>
          <button onclick="kemaskiniKataLaluanPukal()" class="btn btn-amb btn-sm" style="background:var(--amb);color:#fff;"><i class="fas fa-key"></i>Kemaskini</button>
        </div>
