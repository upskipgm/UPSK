// Data kampus per-kampus (pelajar, pensyarah, pegawai)
function genKampusData(id){
  const s=id.split("").reduce((a,c)=>a+c.charCodeAt(0),0);
  const r=(a,b)=>a+Math.floor(((s*7+a*3)%997)/997*(b-a));
  return{
    pelajar:Array.from({length:8},(_,i)=>({
      id:`${id}-P${String(i+1).padStart(3,"0")}`,
      nama:["Ahmad Fauzi","Nurul Aisyah","Muhammad Haziq","Siti Balqis","Lim Wei Jie","Kavitha a/p Rajan","Mohd Amin","Nur Afiqah"][(i+s)%8],
      noMatrik:`${id}${2024000+i*17}`.slice(0,10),
      program:["PISMP","PISMP","DPLI","PISMP","BPisMP","PISMP","DPLI","PISMP"][i%8],
      semester:String(r(1,8)),
      statusK:i%7===0?"Aktif — Perlu Susulan":"Normal",
      sesiCount:i%4+1,
      ujianTerakhir:["Inventori Minat Kerjaya","Personaliti Big Five","Tahap Stres","Kesejahteraan Psikologi","Daya Tahan Mental","Gaya Pembelajaran"][i%6],
      skor:45+Math.floor(((s*3+i*11)%50))
    })),
    pensyarah:Array.from({length:5},(_,i)=>({
      id:`${id}-T${String(i+1).padStart(3,"0")}`,
      nama:["Dr. Zulkifli Hamid","Prof. Madya Siti Rohani","En. Rashdan Malik","Pn. Noraini Abdullah","Dr. Kumar Rajan"][i%5],
      noStaf:`${id}S${String(100+i)}`,
      jawatan:["Pensyarah Kanan","Pensyarah","Pensyarah Cemerlang","Pensyarah Kanan","Pensyarah"][i%5],
      bidang:["Matematik","Bahasa Melayu","Sains","Pendidikan Islam","Bahasa Inggeris"][i%5],
      statusK:i%6===0?"Aktif — Memerlukan Sokongan":"Normal",
      sesiCount:i%3
    })),
    pegawai:Array.from({length:3},(_,i)=>({
      id:`${id}-O${String(i+1).padStart(3,"0")}`,
      nama:["Pn. Fatimah Zahra","En. Kamarudin Hassan","Pn. Rozita Mohd"][i%3],
      noStaf:`${id}O${String(200+i)}`,
      jawatan:["Penolong Pendaftar","Juruteknik","Pembantu Tadbir"][i%3],
      statusK:"Normal",
      sesiCount:0
    })),
    statsesi:r(60,300),
    statemujanji:r(15,60),
    statkaunselor:r(2,8)
  };
}

