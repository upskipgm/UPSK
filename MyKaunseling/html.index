// ══════════════════════════════════════════
// PENGURUSAN KAUNSELING — CACHE & HELPERS
// ══════════════════════════════════════════


function parseSesiRow(row, hi){
  // Index-based parsing (most reliable for CSV with special chars in headers)
  // Sesi: 0=TAHUN,1=BULAN,2=ZON,3=ORGANISASI,4=JENIS SESI,5=KATEGORI ISU
  // 6=PPP(L),7=PPP(P),8=JUM PPP,9=PG(L),10=PG(P),11=JUM PG
  // 12=AKP(L),13=AKP(P),14=JUM AKP,15=MURID L,16=MURID P,17=JUM MURID
  // 18=KOMUNITI L,19=KOMUNITI P,20=JUM KOMUNITI,21=JUM L,22=JUM P,23=JUMLAH
  const g = (i) => (row[i]||"").toString().trim();
  const n = (i) => { const v=parseFloat((row[i]||"").toString().replace(/,/g,"").trim()); return isNaN(v)?0:v; };
  const jumlahL = n(21), jumlahP = n(22);
  const jumlah  = n(23) || (jumlahL+jumlahP);
  return {
    tahun:g(0), bulan:g(1), zon:g(2), organisasi:g(3),
    jenisSesi:g(4), kategoriIsu:g(5),
    pppL:n(6), pppP:n(7), jPPP:n(8),
    pgL:n(9), pgP:n(10), jPG:n(11),
    akpL:n(12), akpP:n(13), jAKP:n(14),
    muridL:n(15), muridP:n(16), jMurid:n(17),
    komunitiL:n(18), komunitiP:n(19), jKomuniti:n(20),
    jumlahL, jumlahP, jumlah
  };
}

function parseProgramRow(row, hi){
  // Program: 0=TAHUN,1=BULAN,2=PENDEKATAN PROGRAM,3=ZON,4=ORGANISASI
  // 5=PPP(L),6=PPP(P),7=JUMLAH PPP,8=PG(L),9=PG(P),10=JUMLAH PG
  // 11=AKP(L),12=AKP(P),13=JUMLAH AKP,14=PELAJAR L,15=PELAJAR P,16=JUMLAH PELAJAR
  // 17=KOMUNITI L,18=KOMUNITI P,19=JUMLAH KOMUNITI,20=JUMLAH L,21=JUMLAH P,22=JUMLAH
  const g = (i) => (row[i]||"").toString().trim();
  const n = (i) => { const v=parseFloat((row[i]||"").toString().replace(/,/g,"").trim()); return isNaN(v)?0:v; };
  const jumlahL = n(20), jumlahP = n(21);
  const jumlah  = n(22) || (jumlahL+jumlahP);
  return {
    tahun:g(0), bulan:g(1), pendekatan:g(2), zon:g(3), organisasi:g(4),
    pppL:n(5), pppP:n(6), jPPP:n(7),
    pgL:n(8), pgP:n(9), jPG:n(10),
    akpL:n(11), akpP:n(12), jAKP:n(13),
    muridL:n(14), muridP:n(15), jMurid:n(16),
    komunitiL:n(17), komunitiP:n(18), jKomuniti:n(19),
    jumlahL, jumlahP, jumlah
  };
}

// ── Parse Kaunselor CSV ──
// Cols: 0=ZON,1=NEGERI,2=NAMA ORGANISASI,3=NAMA PEGAWAI,4=GELARAN JAWATAN,
//       5=JANTINA,6=GRED,7=NO KAUNSELOR BERDAFTAR,8=INSTITUSI,
//       9=ALAMAT,10=TEL PEJABAT,11=FAKS,12=BIMBIT,13=EMAIL,14=SASARAN SESI
function parseKaunselorRow(row, hi){
  const g = (i) => (row[i]||"").toString().trim();
  const n = (i) => { const v=parseFloat((row[i]||"").toString().replace(/,/g,"").trim()); return isNaN(v)?0:v; };
  return {
    zon:          g(0),
    negeri:       g(1),
    organisasi:   g(2),
    nama:         g(3),
    jawatan:      g(4),
    jantina:      g(5),
    gred:         g(6),
    noKaunselor:  g(7),
    institusi:    g(8),
    alamat:       g(9),
    telPejabat:   g(10),
    faks:         g(11),
    bimbit:       g(12),
    email:        g(13),
    sasaranSesi:  n(14),
  };
}

function importCSVKauns(input, jenis){
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const lines = e.target.result.replace(/\r/g,"").split("\n").filter(l=>l.trim());
      if(lines.length < 2){ toast("Fail CSV kosong","err"); return; }
      const sep = lines[0].split("\t").length > 3 ? "\t" : ",";
      const parseFn = jenis==="sesi" ? parseSesiRow : jenis==="program" ? parseProgramRow : parseKaunselorRow;
      const parsed = lines.slice(1).filter(l=>l.trim()).map(line=>{
        const row = line.split(sep).map(v=>v.replace(/"/g,"").trim());
        return parseFn(row, {});
      }).filter(d=>d.tahun||d.organisasi);
      KAUNS_CACHE[jenis] = parsed;
      try {
        if(typeof idbSave==="function") idbSave("csv_"+jenis, parsed).then(ok=>{
          if(ok) localStorage.setItem("csv_"+jenis+"_date", new Date().toLocaleString("ms-MY"));
        });
      } catch(e){}
      localStorage.setItem("csv_"+jenis+"_date", new Date().toLocaleString("ms-MY"));
      toast(parsed.length.toLocaleString("ms-MY")+" rekod "+jenis.toUpperCase()+" berjaya diimport","ok");
      navTo(SES.pg);
    } catch(err){ toast("Gagal baca CSV: "+err.message,"err"); }
  };
  reader.readAsText(file);
}



// Stat helpers
function sesiStat(data){
  const sum = (key) => data.reduce((s,d)=>s+(d[key]||0),0);
  const countBy = (key) => { const c={}; data.forEach(d=>{const v=d[key]||"?"; c[v]=(c[v]||0)+(d.jumlah||1);}); return Object.entries(c).sort((a,b)=>b[1]-a[1]); };
  const countByN = (key) => { const c={}; data.forEach(d=>{const v=d[key]||"?"; c[v]=(c[v]||0)+1;}); return Object.entries(c).sort((a,b)=>b[1]-a[1]); };
  return {
    n: data.length,
    totalJumlah: sum("jumlah"),
    totalL: sum("jumlahL"),
    totalP: sum("jumlahP"),
    totalPPP: sum("jPPP"),
    totalPG: sum("jPG"),
    totalAKP: sum("jAKP"),
    totalMurid: sum("jMurid"),
    totalKomuniti: sum("jKomuniti"),
    byJenis: countBy("jenisSesi"),
    byKategori: countBy("kategoriIsu"),
    byZon: countByN("zon"),
    byBulan: Object.entries(data.reduce((a,d)=>{const k=(d.tahun||"")+"-"+(d.bulan||""); a[k]=(a[k]||0)+(d.jumlah||0); return a;},{})).sort((a,b)=>a[0].localeCompare(b[0])).slice(-12),
    byOrg: countBy("organisasi"),
  };
}

function programStat(data){
  const sum = (key) => data.reduce((s,d)=>s+(d[key]||0),0);
  const countBy = (key) => { const c={}; data.forEach(d=>{const v=d[key]||"?"; c[v]=(c[v]||0)+(d.jumlah||1);}); return Object.entries(c).sort((a,b)=>b[1]-a[1]); };
  const countByN = (key) => { const c={}; data.forEach(d=>{const v=d[key]||"?"; c[v]=(c[v]||0)+1;}); return Object.entries(c).sort((a,b)=>b[1]-a[1]); };
  return {
    n: data.length,
    totalJumlah: sum("jumlah"),
    totalL: sum("jumlahL"),
    totalP: sum("jumlahP"),
    totalPPP: sum("jPPP"),
    totalPG: sum("jPG"),
    totalAKP: sum("jAKP"),
    totalMurid: sum("jMurid"),
    totalKomuniti: sum("jKomuniti"),
    byPendekatan: countBy("pendekatan"),
    byZon: countByN("zon"),
    byBulan: Object.entries(data.reduce((a,d)=>{const k=(d.tahun||"")+"-"+(d.bulan||""); a[k]=(a[k]||0)+(d.jumlah||0); return a;},{})).sort((a,b)=>a[0].localeCompare(b[0])).slice(-12),
    byOrg: countBy("organisasi"),
  };
}

// ── UPLOAD NOTICE helper ──
function kaunsUploadNotice(jenis, label, color){
  const date = localStorage.getItem("csv_"+jenis+"_date")||"";
  const data = KAUNS_CACHE[jenis];
  const count = data ? data.length : 0;
  const hasData = count > 0;
  const isSheets = date && date.includes("★Sheets");
  return `<div style="background:${hasData?(isSheets?"rgba(59,130,246,0.07)":"rgba(14,124,97,0.07)"):"#fffbeb"};border:1px solid ${hasData?(isSheets?"rgba(59,130,246,0.2)":"rgba(14,124,97,0.2)"):"#fde68a"};border-radius:8px;padding:10px 14px;margin-bottom:14px;display:flex;align-items:center;flex-wrap:wrap;gap:8px;">
    <i class="fas ${hasData?(isSheets?"fa-table":"fa-circle-check"):"fa-triangle-exclamation"}" style="color:${hasData?(isSheets?"#3B82F6":"#0E7C61"):"#D97706"};"></i>
    <span style="font-size:12px;font-weight:600;color:${hasData?(isSheets?"#1D4ED8":"#0B634D"):"#92400e"};">
      ${hasData ? count.toLocaleString("ms-MY")+" rekod "+label+(isSheets?" · Google Sheets":"") : "Tiada data "+label}
    </span>
    ${date?`<span style="font-size:11px;color:#64748B;"><i class="fas fa-clock mr-1"></i>${date.replace(" ★Sheets","")}</span>`:""}
    <div style="margin-left:auto;display:flex;gap:6px;align-items:center;">
      <label style="background:${color};color:#fff;padding:4px 12px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;">
        <i class="fas fa-upload"></i>${hasData?"Kemaskini":"Muat Naik"} CSV
        <input type="file" accept=".csv,.tsv,.txt" style="display:none" id="${jenis}-file-inp">
      </label>
      ${hasData?`<button onclick="KAUNS_CACHE['${jenis}']=null;if(typeof idbDelete==='function')idbDelete('csv_${jenis}').then(()=>navTo(SES.pg));else navTo(SES.pg);" style="font-size:11px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:4px 10px;border-radius:6px;cursor:pointer;"><i class="fas fa-rotate-right mr-1"></i>Refresh</button>`:""}
      ${hasData&&isAdmin()?`<button onclick="KAUNS_CACHE['${jenis}']=null;localStorage.removeItem('csv_${jenis}_date');idbDelete('csv_${jenis}').then(()=>navTo(SES.pg))" style="font-size:11px;color:#991b1b;border:1px solid #fca5a5;padding:4px 8px;border-radius:6px;background:#fff;cursor:pointer;"><i class="fas fa-trash"></i></button>`:""}
      ${!isAdmin()?`<button onclick="exportPagePDF()" style="font-size:11px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;padding:4px 10px;border-radius:6px;cursor:pointer;"><i class="fas fa-file-pdf mr-1" style="color:#DC2626;"></i>PDF</button>`:""}
    </div>
  </div>`;
}

