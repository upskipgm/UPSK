      </div></div>
    </div>

    <!-- Penapis & Carian -->
    <div class="card">
      <div class="card-head">
        <span class="card-title">Senarai Pengguna Sistem</span>
        <button class="btn btn-pri btn-sm" onclick="modalPengguna(-1)"><i class="fas fa-plus"></i>Tambah Pengguna</button>
      </div>
      <div class="card-body pb-2">
        <div class="flex flex-wrap gap-2 mb-3">
          <input type="text" class="fi" style="max-width:200px" placeholder="Cari ID / nama..." id="fp-cari" oninput="filterPengguna()">
