function pgKerjaya(c){
  c.innerHTML = `
  <div class="afu" style="background:linear-gradient(135deg,#0E7C61,#084A39);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-20px;top:-20px;width:120px;height:120px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    <div style="position:relative;z-index:1;">
      <div style="font-size:.7rem;color:rgba(255,255,255,0.5);margin-bottom:4px;"><i class="fas fa-compass mr-2"></i>DASHBOARD PSIKOLOGI</div>
      <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">Kerjaya</div>
      <div style="font-size:.78rem;color:rgba(255,255,255,0.5);margin-top:3px;">Dashboard Bimbingan Kerjaya Pelajar IPG</div>
    </div>
  </div>

  <div style="background:#fff;border:1px solid var(--border);border-radius:12px;padding:40px;text-align:center;margin-bottom:16px;">
    <div style="width:64px;height:64px;border-radius:50%;background:rgba(14,124,97,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
      <i class="fas fa-compass" style="font-size:28px;color:#0E7C61;"></i>
    </div>
    <div style="font-family:'Outfit',sans-serif;font-size:1.1rem;font-weight:700;color:var(--navy);margin-bottom:8px;">Modul Kerjaya Akan Datang</div>
    <div style="font-size:.85rem;color:var(--muted);max-width:480px;margin:0 auto 20px;line-height:1.7;">
      Modul ini akan memuatkan data analisis bimbingan kerjaya pelajar IPG.
      Sila kongsikan link Google Sheet untuk data kerjaya supaya kami dapat integrasikan.
    </div>
    <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;">
      <div style="background:rgba(14,124,97,0.07);border:1px dashed #0E7C61;border-radius:8px;padding:12px 20px;font-size:.82rem;color:#0E7C61;font-weight:600;">
        <i class="fas fa-link mr-2"></i>Kongsi Google Sheet Data Kerjaya
      </div>
      <div style="background:rgba(59,130,246,0.07);border:1px dashed #3B82F6;border-radius:8px;padding:12px 20px;font-size:.82rem;color:#3B82F6;font-weight:600;">
        <i class="fas fa-file-csv mr-2"></i>Muat Naik CSV Kerjaya
      </div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
    ${[
      {i:"fa-compass",l:"Inventori Minat Holland",d:"RIASEC — Realistic, Investigative, Artistic, Social, Enterprising, Conventional",c:"#0E7C61"},
      {i:"fa-chart-bar",l:"Analisis Pilihan Kerjaya",d:"Trend pilihan kerjaya pelajar mengikut program dan semester",c:"#3B82F6"},
      {i:"fa-star",l:"Profil Kekuatan",d:"Kekuatan dan potensi pelajar berasaskan ujian psikologi",c:"#8B5CF6"}
    ].map(m=>`
    <div class="card" style="border-top:3px solid ${m.c};opacity:0.7;">
      <div class="card-body" style="text-align:center;padding:20px;">
        <div style="width:44px;height:44px;border-radius:10px;background:${m.c}18;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">
          <i class="fas ${m.i}" style="color:${m.c};font-size:1.1rem;"></i>
        </div>
        <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:.9rem;margin-bottom:6px;">${m.l}</div>
        <div style="font-size:.75rem;color:var(--muted);line-height:1.5;">${m.d}</div>
        <div style="margin-top:10px;font-size:.72rem;color:${m.c};font-weight:600;">Akan Datang</div>
      </div>
    </div>`).join("")}
  </div>`;
}

