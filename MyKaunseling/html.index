// MUAT TURUN DOKUMEN
// ══════════════════════════════════════════
let DRIVE_FOLDER_URL = "";
let DRIVE_FILES = JSON.parse(localStorage.getItem("drive_files")||"[]");

function pgDokumen(c){
  c.innerHTML = `
  <div class="afu" style="background:linear-gradient(135deg,#132238,#1F2C50);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;">
    <div style="font-size:.7rem;color:rgba(255,255,255,0.5);margin-bottom:4px;"><i class="fas fa-folder-open mr-2"></i>DOKUMEN</div>
    <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">Muat Turun Dokumen</div>
    <div style="font-size:.78rem;color:rgba(255,255,255,0.5);margin-top:3px;">Akses dokumen rasmi Unit Psikologi dan Kaunseling IPGKPM</div>
  </div>

  <!-- Setup Google Drive -->
  <div class="card" style="margin-bottom:16px;">
    <div class="card-head">
      <span class="card-title"><i class="fab fa-google-drive text-amb-500 mr-2"></i>Sumber Google Drive</span>
      ${SES.role==="admin_utama"?`<button class="btn btn-pri btn-sm" onclick="setupDrive()"><i class="fas fa-cog"></i> Tetapkan</button>`:""}
    </div>
    <div class="card-body" id="drive-status">
      ${DRIVE_FOLDER_URL || localStorage.getItem("drive_url") ?
        `<div style="display:flex;align-items:center;gap:10px;padding:10px;background:rgba(22,163,74,0.08);border:1px solid rgba(22,163,74,0.2);border-radius:8px;">
          <i class="fas fa-circle-check" style="color:#16A34A;"></i>
          <div style="flex:1;font-size:12px;color:#166534;">
            <b>Folder Google Drive disambungkan</b><br>
            <a href="${DRIVE_FOLDER_URL||localStorage.getItem('drive_url')}" target="_blank" style="color:#0E7C61;font-size:11px;">${DRIVE_FOLDER_URL||localStorage.getItem('drive_url')}</a>
          </div>
          <a href="${DRIVE_FOLDER_URL||localStorage.getItem('drive_url')}" target="_blank" class="btn btn-out btn-sm"><i class="fas fa-external-link-alt"></i> Buka Drive</a>
        </div>` :
        `<div style="padding:12px;background:#fffbeb;border:1px solid #fde68a;border-radius:8px;font-size:12px;color:#92400e;">
          <i class="fas fa-triangle-exclamation mr-2"></i>
          ${SES.role==="admin_utama"?
            'Belum ada folder Google Drive. Klik <b>Tetapkan</b> untuk masukkan pautan folder.':
            'Folder belum ditetapkan. Sila hubungi Admin Utama.'}
        </div>`
      }
    </div>
  </div>

  <!-- Senarai Dokumen -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-files text-pri-500 mr-2"></i>Senarai Dokumen</span>
      ${SES.role==="admin_utama"?`<button class="btn btn-pri btn-sm" onclick="tambahDokumen()"><i class="fas fa-plus"></i> Tambah Dokumen</button>`:""}
    </div>
    <div class="card-body" id="dokumen-list">
      ${renderDokumenList()}
    </div>
  </div>`;
}

function renderDokumenList(){
  const files = JSON.parse(localStorage.getItem("drive_files")||"[]");
  if(!files.length){
    return `<div style="text-align:center;padding:32px;color:var(--muted);">
      <i class="fas fa-folder-open" style="font-size:32px;margin-bottom:12px;display:block;opacity:0.4;"></i>
      <div style="font-size:13px;">Belum ada dokumen.</div>
      ${SES.role==="admin_utama"?'<div style="font-size:12px;margin-top:4px;">Klik <b>Tambah Dokumen</b> untuk tambah pautan fail.</div>':""}
    </div>`;
  }
  return `<div style="display:grid;gap:8px;">
    ${files.map((f,i)=>`
    <div style="display:flex;align-items:center;gap:12px;padding:12px 14px;border:1px solid var(--border);border-radius:9px;background:#fafafa;transition:all .2s;" onmouseover="this.style.background='#f0f7f4';this.style.borderColor='#0E7C61'" onmouseout="this.style.background='#fafafa';this.style.borderColor='var(--border)'">
      <div style="width:38px;height:38px;border-radius:8px;background:${f.warna||'#0E7C61'}18;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fas ${f.ikon||'fa-file-pdf'}" style="color:${f.warna||'#0E7C61'};font-size:.95rem;"></i>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-weight:600;font-size:.88rem;color:var(--navy);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${f.nama}</div>
        <div style="font-size:.72rem;color:var(--muted);margin-top:1px;">${f.keterangan||""} ${f.tarikh?'· '+f.tarikh:""}</div>
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0;">
        <a href="${f.url}" target="_blank" class="btn btn-out btn-sm"><i class="fas fa-download"></i> Muat Turun</a>
        ${SES.role==="admin_utama"?`<button onclick="hapusDokumen(${i})" class="btn btn-danger btn-sm btn-xs"><i class="fas fa-trash"></i></button>`:""}
      </div>
    </div>`).join("")}
  </div>`;
}

function setupDrive(){
  const saved = localStorage.getItem("drive_url")||"";
  document.getElementById("modal-wrap").innerHTML = `
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:500px">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display font-700 text-lg text-navy-800"><i class="fab fa-google-drive text-amb-500 mr-2"></i>Tetapkan Folder Google Drive</h3>
        <button onclick="closeModal()" class="text-gray-400"><i class="fas fa-times"></i></button>
      </div>
      <div class="space-y-4">
        <div>
          <label class="fl">Pautan Folder Google Drive</label>
          <input type="text" id="drive-url-input" class="fi" value="${saved}" placeholder="https://drive.google.com/drive/folders/...">
          <div style="font-size:.75rem;color:var(--muted);margin-top:4px;"><i class="fas fa-info-circle mr-1"></i>Pastikan folder ditetapkan "Anyone with link can view"</div>
        </div>
        <div class="flex gap-3">
          <button onclick="closeModal()" class="btn btn-ghost flex-1 justify-center">Batal</button>
          <button onclick="simpanDrive()" class="btn btn-pri flex-1 justify-center"><i class="fas fa-save"></i> Simpan</button>
        </div>
      </div>
    </div>
  </div>`;
}

function simpanDrive(){
  const url = document.getElementById("drive-url-input").value.trim();
  if(!url){ toast("Sila masukkan pautan Google Drive","err"); return; }
  localStorage.setItem("drive_url", url);
  DRIVE_FOLDER_URL = url;
  closeModal();
  navTo(SES.pg);
  toast("Folder Google Drive disimpan","ok");
}

function tambahDokumen(){
  document.getElementById("modal-wrap").innerHTML = `
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:500px">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display font-700 text-lg text-navy-800"><i class="fas fa-plus text-pri-500 mr-2"></i>Tambah Dokumen</h3>
        <button onclick="closeModal()" class="text-gray-400"><i class="fas fa-times"></i></button>
      </div>
      <div class="space-y-3">
        <div><label class="fl">Nama Dokumen <span class="text-red-400">*</span></label>
          <input type="text" id="doc-nama" class="fi" placeholder="Contoh: Borang Temujanji Kaunseling"></div>
        <div><label class="fl">Pautan Google Drive / URL <span class="text-red-400">*</span></label>
          <input type="text" id="doc-url" class="fi" placeholder="https://drive.google.com/file/d/..."></div>
        <div><label class="fl">Keterangan</label>
          <input type="text" id="doc-keterangan" class="fi" placeholder="Borang untuk pelajar IPGKPM"></div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="fl">Jenis Fail</label>
            <select id="doc-ikon" class="fi">
              <option value="fa-file-pdf,#EF4444">PDF</option>
              <option value="fa-file-word,#3B82F6">Word (.docx)</option>
              <option value="fa-file-excel,#16A34A">Excel (.xlsx)</option>
              <option value="fa-file-powerpoint,#E88D3A">PowerPoint</option>
              <option value="fa-file-image,#8B5CF6">Imej</option>
              <option value="fa-file,#6B7280">Lain-lain</option>
            </select>
          </div>
          <div><label class="fl">Tarikh</label>
            <input type="date" id="doc-tarikh" class="fi" value="${new Date().toISOString().split('T')[0]}"></div>
        </div>
        <div class="flex gap-3 pt-1">
          <button onclick="closeModal()" class="btn btn-ghost flex-1 justify-center">Batal</button>
          <button onclick="simpanDokumen()" class="btn btn-pri flex-1 justify-center"><i class="fas fa-save"></i> Simpan</button>
        </div>
      </div>
    </div>
  </div>`;
}

function simpanDokumen(){
  const nama = document.getElementById("doc-nama").value.trim();
  const url  = document.getElementById("doc-url").value.trim();
  if(!nama||!url){ toast("Nama dan URL diperlukan","err"); return; }
  const ikonVal = document.getElementById("doc-ikon").value.split(",");
  const tarikh = document.getElementById("doc-tarikh").value;
  const files = JSON.parse(localStorage.getItem("drive_files")||"[]");
  files.push({
    nama, url,
    keterangan: document.getElementById("doc-keterangan").value.trim(),
    ikon: ikonVal[0], warna: ikonVal[1],
    tarikh: tarikh ? new Date(tarikh).toLocaleDateString("ms-MY") : ""
  });
  localStorage.setItem("drive_files", JSON.stringify(files));
  closeModal();
  document.getElementById("dokumen-list").innerHTML = renderDokumenList();
  toast("Dokumen ditambah","ok");
}

function hapusDokumen(idx){
  if(!confirm("Padam dokumen ini?")) return;
  const files = JSON.parse(localStorage.getItem("drive_files")||"[]");
  files.splice(idx,1);
  localStorage.setItem("drive_files", JSON.stringify(files));
  document.getElementById("dokumen-list").innerHTML = renderDokumenList();
  toast("Dokumen dipadam","ok");
}

function padamDataPKP(tab){
  if(!confirm('Padam & refresh data '+tab.toUpperCase()+'? Data akan dimuatkan semula dari Google Sheets.')) return;
  SHEETS_CACHE[tab] = null;
  window["_pkp_"+tab] = null;
  localStorage.removeItem("csv_"+tab+"_date");
  if(typeof idbDelete==="function"){
    idbDelete("csv_"+tab).then(()=>{
      toast("Cache "+tab.toUpperCase()+" dipadam — memuatkan semula...","ok");
      navTo(SES.pg);
    });
  } else {
    navTo(SES.pg);
  }
}

// ══════════════════════════════════════════
// HERO CAROUSEL
// Saiz gambar: 320 x 160 px (JPEG/PNG)
// ══════════════════════════════════════════
let _hcIdx = 0;
let _hcTimer = null;
const HC_W = 420;
const HC_H = 160;

function hcInit(){
  const slides = getHebItems().filter(h => h.gambar);
  const wrap   = document.getElementById("hc-slides");
  const dots   = document.getElementById("hc-dots");
  const empty  = document.getElementById("hc-empty");
  const prev   = document.getElementById("hc-prev");
  const next   = document.getElementById("hc-next");
  if(!wrap) return;

  if(!slides.length){
    wrap.innerHTML = "";
    if(dots) dots.innerHTML = "";
    if(empty) empty.style.display = "flex";
    if(prev) prev.style.display = "none";
    if(next) next.style.display = "none";
    return;
  }

  if(empty) empty.style.display = "none";

  // Build slides
  wrap.style.width = (slides.length * 420) + "px";
  wrap.innerHTML = slides.map((h,i) => `
    <div style="width:${HC_W}px;height:${HC_H}px;flex-shrink:0;position:relative;cursor:pointer;"
         onclick="${h.url ? 'window.open("'+h.url+'","_blank")' : ''}">
      <img src="${h.gambar}" alt="${h.tajuk||''}"
           style="width:100%;height:100%;object-fit:cover;display:block;">
      ${h.tajuk ? `<div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.65));padding:8px 10px 6px;color:#fff;font-size:11px;font-weight:600;line-height:1.3;">${h.tajuk}</div>` : ""}
    </div>`).join("");

  // Dots
  if(dots){
    dots.innerHTML = slides.map((_,i) => `
      <div onclick="hcGo(${i})" style="width:6px;height:6px;border-radius:50%;background:${i===0?"#fff":"rgba(255,255,255,.4)"};cursor:pointer;transition:background .3s;" id="hc-dot-${i}"></div>
    `).join("");
  }

  if(prev) prev.style.display = slides.length > 1 ? "flex" : "none";
  if(next) next.style.display = slides.length > 1 ? "flex" : "none";

  _hcIdx = 0;
  hcGo(0);

  // Auto-play every 4 seconds
  if(_hcTimer) clearInterval(_hcTimer);
  if(slides.length > 1){
    _hcTimer = setInterval(() => hcMove(1), 4000);
  }
}

function hcGo(i){
  const slides = getHebItems().filter(h => h.gambar);
  if(!slides.length) return;
  _hcIdx = (i + slides.length) % slides.length;
  const wrap = document.getElementById("hc-slides");
  if(wrap) wrap.style.transform = `translateX(-${_hcIdx * 420}px)`;
  // Update dots
  slides.forEach((_,j) => {
    const dot = document.getElementById("hc-dot-"+j);
    if(dot) dot.style.background = j === _hcIdx ? "#fff" : "rgba(255,255,255,.4)";
  });
}

function hcMove(dir){
  const slides = getHebItems().filter(h => h.gambar);
  hcGo(_hcIdx + dir);
  // Reset timer on manual nav
  if(_hcTimer){ clearInterval(_hcTimer); _hcTimer = setInterval(()=>hcMove(1),4000); }
}

function getHebItems(){
  try { return JSON.parse(localStorage.getItem("hebahan_gambar")||"[]"); }
  catch(e){ return []; }
}


