<!DOCTYPE html>
<html lang="ms">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MyKaunseling — Unit Psikologi dan Kaunseling IPGKPM</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
<link rel="stylesheet" href="https://use.fontawesome.com/releases/v6.5.0/css/all.css" crossorigin="anonymous">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<script>
tailwind.config={theme:{extend:{colors:{
  pri:{50:"#E6F5F0",100:"#B3E2D2",200:"#80CFB4",300:"#4DBC96",400:"#26AD80",500:"#0E7C61",600:"#0B634D",700:"#084A39",800:"#053125",900:"#021912"},
  navy:{50:"#E8ECF2",100:"#C5CDE0",200:"#A2AECF",300:"#7F8FBE",400:"#5C70AD",500:"#3D5490",600:"#2E4070",700:"#1F2C50",800:"#132238",900:"#081222"},
  amb:{50:"#FDF3E6",100:"#FAE0BF",200:"#F7CD98",300:"#F4BA71",400:"#F1A74A",500:"#E88D3A",600:"#C47428",700:"#9A5A1E",800:"#704014",900:"#46260A"}
},fontFamily:{display:["Outfit","sans-serif"],body:["DM Sans","sans-serif"]}}}}
</script>
<style>
:root{--pri:#0E7C61;--pri-dark:#084A39;--navy:#132238;--amb:#E88D3A;--bg:#F0F2F5;--card:#fff;--border:#E2E8F0;--text:#1A2332;--muted:#64748B;--danger:#DC2626;--success:#16A34A;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:"DM Sans",sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}
h1,h2,h3,h4,h5,h6{font-family:"Outfit",sans-serif;}
.hidden{display:none!important;}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:#CBD5E1;border-radius:3px}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.afu{animation:fadeUp .45s ease both}.d1{animation-delay:.08s}.d2{animation-delay:.16s}.d3{animation-delay:.24s}.d4{animation-delay:.32s}

/* ── SIDEBAR ── */
.sidebar{width:256px;height:100vh;background:var(--navy);position:fixed;left:0;top:0;z-index:40;overflow:hidden;transition:transform .3s ease;display:flex;flex-direction:column;}
.sb-logo{padding:16px 18px;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;gap:10px;}
.sb-logo-icon{width:36px;height:36px;border-radius:8px;background:var(--pri);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sb-logo-text{font-family:"Outfit",sans-serif;font-weight:700;color:#fff;font-size:.9rem;line-height:1.2;}
.sb-logo-role{font-size:.7rem;color:rgba(255,255,255,0.4);margin-top:1px;}
.sb-section{padding:16px 18px 4px;font-size:.65rem;font-weight:700;color:rgba(255,255,255,0.25);text-transform:uppercase;letter-spacing:.1em;}
.sb-link{display:flex;align-items:center;gap:10px;padding:9px 18px;color:rgba(255,255,255,0.5);border-radius:8px;margin:1px 10px;font-size:.84rem;cursor:pointer;transition:all .2s ease;border-left:3px solid transparent;}
.sb-link:hover{color:#fff;background:rgba(255,255,255,0.07);}
.sb-link.active{color:#fff;background:var(--pri);border-left-color:rgba(255,255,255,0.3);box-shadow:0 3px 12px rgba(14,124,97,0.35);}
.sb-link i{width:18px;text-align:center;font-size:.85rem;}
.sb-badge{margin-left:auto;background:var(--amb);color:#fff;font-size:.65rem;padding:1px 6px;border-radius:8px;font-weight:700;}
.sb-footer{flex-shrink:0;margin-top:auto;padding:12px;border-top:1px solid rgba(255,255,255,0.08);}
.sb-user{padding:10px 12px;border-radius:8px;background:rgba(255,255,255,0.05);margin-bottom:8px;}
.sb-user-name{font-size:.82rem;color:#fff;font-weight:600;}
.sb-user-kampus{font-size:.7rem;color:rgba(255,255,255,0.4);margin-top:2px;line-height:1.3;}

/* ── TOPBAR ── */
.topbar{background:#fff;border-bottom:1px solid var(--border);padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:20;}
.topbar-title{font-family:"Outfit",sans-serif;font-weight:700;font-size:1rem;color:var(--navy);}
.topbar-crumb{font-size:.72rem;color:var(--muted);margin-top:1px;}

/* ── MAIN ── */
.main-wrap{margin-left:256px;min-height:100vh;}
.page-body{padding:20px 24px;}

/* ── STAT CARDS ── */
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:18px;position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s;}
.stat-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,0.07);}
.stat-card::after{content:"";position:absolute;top:0;left:0;right:0;height:3px;border-radius:12px 12px 0 0;}
.sc-pri::after{background:var(--pri)}.sc-amb::after{background:var(--amb)}.sc-navy::after{background:var(--navy)}.sc-red::after{background:var(--danger)}
.stat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;margin-bottom:10px;}
.stat-val{font-family:"Outfit",sans-serif;font-size:1.7rem;font-weight:800;color:var(--navy);line-height:1;}
.stat-lbl{font-size:.78rem;color:var(--muted);margin-top:4px;}
.stat-sub{font-size:.72rem;margin-top:5px;}

/* ── CARD ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.card-head{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-family:"Outfit",sans-serif;font-size:.9rem;font-weight:700;color:var(--navy);}
.card-body{padding:16px 18px;}

/* ── TABLE ── */
.tbl{width:100%;border-collapse:collapse;font-size:.82rem;}
.tbl thead th{background:#F8FAFC;padding:10px 12px;text-align:left;font-size:.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid var(--border);white-space:nowrap;}
.tbl tbody td{padding:10px 12px;border-bottom:1px solid #F1F5F9;vertical-align:middle;}
.tbl tbody tr:last-child td{border-bottom:none;}
.tbl tbody tr:hover td{background:#FAFCFB;}

/* ── BADGE ── */
.bdg{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:.7rem;font-weight:600;}
.bdg-green{background:rgba(22,163,74,.1);color:#16A34A;}
.bdg-amber{background:rgba(232,141,58,.1);color:#C47428;}
.bdg-red{background:rgba(220,38,38,.1);color:#DC2626;}
.bdg-blue{background:rgba(59,130,246,.1);color:#3B82F6;}
.bdg-gray{background:rgba(100,116,139,.1);color:#475569;}
.bdg-navy{background:rgba(19,34,56,.1);color:#132238;}
.bdg-pri{background:rgba(14,124,97,.1);color:#0E7C61;}

/* ── FORMS ── */
.fi{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:7px;font-size:.85rem;font-family:"DM Sans",sans-serif;transition:border-color .2s,box-shadow .2s;background:#fff;color:var(--text);}
.fi:focus{outline:none;border-color:var(--pri);box-shadow:0 0 0 3px rgba(14,124,97,.1);}
.fl{display:block;font-size:.78rem;font-weight:600;margin-bottom:4px;color:var(--text);}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:7px;font-size:.84rem;font-weight:600;cursor:pointer;border:none;font-family:"DM Sans",sans-serif;transition:all .2s ease;}
.btn-pri{background:var(--pri);color:#fff;}.btn-pri:hover{background:var(--pri-dark);transform:translateY(-1px);box-shadow:0 4px 14px rgba(14,124,97,.3);}
.btn-out{background:transparent;color:var(--pri);border:1.5px solid var(--pri);}.btn-out:hover{background:var(--pri);color:#fff;}
.btn-danger{background:var(--danger);color:#fff;}.btn-danger:hover{background:#b91c1c;}
.btn-ghost{background:transparent;color:var(--muted);border:1.5px solid var(--border);}.btn-ghost:hover{background:#F8FAFC;color:var(--text);}
.btn-sm{padding:5px 12px!important;font-size:.76rem!important;}
.btn-xs{padding:3px 8px!important;font-size:.72rem!important;border-radius:5px!important;}

/* ── MODAL ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.45);backdrop-filter:blur(3px);z-index:50;display:flex;align-items:center;justify-content:center;animation:fadeIn .2s ease;}
.modal-box{background:#fff;border-radius:14px;padding:24px;width:90%;max-height:88vh;overflow-y:auto;animation:fadeUp .3s ease both;}

/* ── TOAST ── */
.toast{position:fixed;bottom:20px;right:20px;z-index:9999;padding:12px 20px;border-radius:9px;color:#fff;font-size:.84rem;font-weight:500;display:flex;align-items:center;gap:8px;animation:fadeUp .35s ease both;box-shadow:0 6px 24px rgba(0,0,0,.18);}
.toast.ok{background:var(--success)}.toast.err{background:var(--danger)}.toast.inf{background:var(--pri)}

/* ── LINK CARD (portal awam) ── */
.link-card{background:#fff;border:1px solid var(--border);border-radius:11px;padding:18px;display:flex;align-items:center;gap:13px;cursor:pointer;text-decoration:none;color:var(--text);transition:all .2s ease;}
.link-card:hover{border-color:var(--pri);box-shadow:0 4px 14px rgba(14,124,97,.1);transform:translateY(-2px);}
.lc-icon{width:44px;height:44px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:1.05rem;flex-shrink:0;}
.link-card.placeholder{border-style:dashed;border-color:#CBD5E1;background:#FAFBFC;opacity:.55;cursor:default;}
.link-card.placeholder:hover{transform:none;box-shadow:none;border-color:#CBD5E1;}

/* ── MARQUEE ── */
.marquee-wrap{overflow:hidden;flex:1;}
.marquee-track{display:flex;white-space:nowrap;animation:marquee 35s linear infinite;}

/* ── STATUS DOT ── */
.dot-on{width:7px;height:7px;border-radius:50%;background:#16A34A;display:inline-block;}
.dot-off{width:7px;height:7px;border-radius:50%;background:#94A3B8;display:inline-block;}

/* ── AVATAR ── */
.ava{width:28px;height:28px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:700;flex-shrink:0;}

/* ── PROGRESS ── */
.prog{height:6px;background:#E2E8F0;border-radius:3px;overflow:hidden;}
.prog-fill{height:100%;border-radius:3px;transition:width .6s ease;}

@media(max-width:1024px){.sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0)}.main-wrap{margin-left:0}}
@media(prefers-reduced-motion:reduce){*{animation-duration:.01ms!important;transition-duration:.01ms!important}}
</style>
<style id="print-base">
  @media print {
    .sidebar, #sidebar, .topbar, button, .btn,
    #modal-wrap, #toast-wrap, input, select,
    .card-head button, [onclick] { display:none !important; }
    .main-wrap { margin-left:0 !important; }
    .page-body { padding:4px !important; }
    .stat-card, .card { break-inside:avoid; margin-bottom:8px; }
    canvas { max-width:100% !important; }
    body { font-size:10px !important; }
    .afu { -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  }
</style>
</head>
<body>
<div id="toast-wrap"></div>
<div id="modal-wrap"></div>
<div class="sidebar-overlay" id="sb-overlay" onclick="toggleSb()"></div>

<!-- ══════════════════════════════════════════
     PORTAL AWAM
══════════════════════════════════════════ -->
<div id="public-view">

  <!-- Header Banner -->
  <div style="line-height:0;background:#0a0a2e;">
    <img src="data:image/png;base64," alt="MyKaunseling Banner" style="display:block;width:100%;height:auto;">
  </div>

  <!-- Nav Bar -->
  <nav style="background:var(--navy);border-bottom:1px solid rgba(255,255,255,0.08);">
    <div class="max-w-7xl mx-auto px-5 flex items-center justify-between h-11">
      <div class="flex items-center gap-5">
        <a href="https://mypdpp.moe.gov.my/myipg/index.cfm" target="_blank" class="text-white/50 hover:text-white/80 text-xs transition flex items-center gap-1.5"><i class="fas fa-external-link-alt text-xs"></i>myIPG</a>
        <span class="text-white/15">|</span>
        <a href="https://e2pk.moe.gov.my" target="_blank" class="text-white/50 hover:text-white/80 text-xs transition flex items-center gap-1.5"><i class="fas fa-graduation-cap text-xs"></i>e2PK 3.0</a>
      </div>
      <button onclick="showLogin()" class="bg-pri-600 hover:bg-pri-500 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition">
        <i class="fas fa-sign-in-alt mr-1"></i>Log Masuk
      </button>
    </div>
  </nav>

  <!-- Hebahan -->
  <div style="background:#FDF3E6;border-bottom:1px solid #FAE0BF;overflow:hidden;">
    <div class="py-2 px-4 flex items-center gap-3">
      <span style="background:var(--amb);color:#fff;font-size:.7rem;font-weight:700;padding:3px 10px;border-radius:4px;flex-shrink:0;"><i class="fas fa-bullhorn mr-1"></i>HEBAHAN</span>
      <div class="marquee-wrap"><div id="pub-hebahan" class="marquee-track"></div></div>
    </div>
  </div>

  <!-- Kandungan -->
  <main class="max-w-7xl mx-auto px-4 sm:px-5 py-8">

    <!-- Hero -->
    <div class="afu bg-gradient-to-br from-navy-800 via-navy-700 to-pri-700 rounded-2xl p-7 mb-8 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-1/3 w-40 h-40 bg-white/5 rounded-full translate-y-1/2"></div>
      <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex-1">
          <div class="inline-flex items-center gap-2 bg-white/10 text-white/70 text-xs px-3 py-1 rounded-full mb-3">
            <i class="fas fa-shield-halved text-amb-400"></i> Portal Rasmi IPGKPM — KPM
          </div>
          <h2 class="font-display font-800 text-white text-2xl md:text-3xl mb-2">Unit Psikologi dan Kaunseling</h2>
          <p class="text-white/60 text-sm max-w-xl leading-relaxed">Akses perkhidmatan psikopendidikan, ujian psikologi dalam talian dan temujanji kaunseling untuk seluruh warga Institut Pendidikan Guru Malaysia.</p>
        </div>
        <!-- Carousel Hebahan -->
        <div id="hero-carousel" style="width:420px;flex-shrink:0;border-radius:10px;overflow:hidden;position:relative;height:160px;background:rgba(0,0,0,0.3);">
          <!-- Slides -->
          <div id="hc-slides" style="display:flex;height:100%;transition:transform .5s ease;">
          </div>
          <!-- Placeholder bila tiada gambar -->
          <div id="hc-empty" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:rgba(255,255,255,0.35);font-size:12px;text-align:center;padding:12px;">
            <i class="fas fa-image" style="font-size:28px;margin-bottom:8px;opacity:.4;"></i>
            <div>Tiada hebahan bergambar</div>
            <div style="font-size:10px;margin-top:3px;opacity:.6;">Admin Utama boleh tambah melalui menu Hebahan Portal</div>
          </div>
          <!-- Dots -->
          <div id="hc-dots" style="position:absolute;bottom:6px;left:0;right:0;display:flex;justify-content:center;gap:5px;"></div>
          <!-- Arrows -->
          <button id="hc-prev" onclick="hcMove(-1)" style="position:absolute;left:4px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.4);color:#fff;border:none;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:11px;display:none;">‹</button>
          <button id="hc-next" onclick="hcMove(1)" style="position:absolute;right:4px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.4);color:#fff;border:none;border-radius:50%;width:26px;height:26px;cursor:pointer;font-size:11px;display:none;">›</button>
        </div>
      </div>
    </div>

    <!-- Pautan Capaian -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-5"><div class="w-1 h-6 bg-pri-500 rounded-full"></div><h3 class="font-display font-700 text-lg text-navy-800">Pautan Capaian</h3></div>
      <div class="grid md:grid-cols-2 gap-7" id="pub-pautan"></div>
    </div>

    <!-- Sistem Berkaitan -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-5"><div class="w-1 h-6 bg-navy-500 rounded-full"></div><h3 class="font-display font-700 text-lg text-navy-800">Sistem Berkaitan</h3></div>
      <div class="grid md:grid-cols-2 gap-4 mb-4" id="pub-sys-berkaitan"></div>
    </div>

    <!-- Hubungi -->
    <div class="bg-white rounded-2xl border border-gray-100 p-6">
      <div class="flex items-center gap-2 mb-4"><div class="w-1 h-6 bg-amb-500 rounded-full"></div><h3 class="font-display font-700 text-lg text-navy-800">Hubungi Kami</h3></div>
      <div id="pub-hubungi" class="grid sm:grid-cols-3 gap-5 text-sm"></div>
    </div>
  </main>

  <footer style="background:var(--navy);padding:20px 24px;">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
      <div><div class="text-white/70 text-sm font-semibold font-display">MyKaunseling — IPGKPM</div><div class="text-white/30 text-xs mt-1">Unit Psikologi dan Kaunseling, Institut Pendidikan Guru Kampus Pendidikan Islam</div></div>
      <div class="text-white/25 text-xs text-right">&copy; 2025 Bahagian Pendidikan Guru, KPM<br>Versi 2.0 &nbsp;|&nbsp; Dasar Privasi &nbsp;|&nbsp; Penafian</div>
    </div>
  </footer>
</div>

<!-- ══════════════════════════════════════════
     SISTEM DALAMAN (ADMIN KAMPUS & ADMIN UTAMA)
══════════════════════════════════════════ -->
<div id="sys-view" class="hidden">

  <!-- Sidebar -->
  <aside id="sidebar" class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-icon"><i class="fas fa-brain text-white text-sm"></i></div>
      <div>
        <div class="sb-logo-text">MyKaunseling</div>
        <div class="sb-logo-role" id="sb-role-lbl"></div>
      </div>
    </div>
    <nav id="sb-nav" class="py-2" style="flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,0.15) transparent;"></nav>
    <div class="sb-footer">
      <div class="sb-user">
        <div class="sb-user-name" id="sb-user-name"></div>
        <div class="sb-user-kampus" id="sb-user-kampus"></div>
      </div>
      <button onclick="doLogout()" class="sb-link !m-0 !text-red-400 hover:!bg-red-500/10 hover:!text-red-300 w-full">
        <i class="fas fa-sign-out-alt"></i><span>Log Keluar</span>
      </button>
    </div>
  </aside>
  <div id="sb-overlay" class="hidden fixed inset-0 bg-black/50 z-30 lg:hidden" onclick="closeSb()"></div>

  <!-- Main -->
  <div class="main-wrap">
    <div class="topbar">
      <div class="flex items-center gap-4">
        <button onclick="toggleSb()" class="lg:hidden text-navy-700 text-lg"><i class="fas fa-bars"></i></button>
        <div>
          <div class="topbar-title" id="pg-title">Dashboard</div>
          <div class="topbar-crumb" id="pg-crumb"></div>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div id="hdr-kampus-chip" class="hidden items-center gap-2 bg-pri-50 text-pri-700 px-3 py-1 rounded-lg text-xs font-medium">
          <i class="fas fa-building text-xs"></i><span id="hdr-kampus-txt"></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="dot-on" id="db-dot"></span>
          <span class="text-xs text-gray-400" id="db-txt">Aktif</span>
        </div>
      </div>
    </div>
    <div id="pg-body" class="page-body"></div>
  </div>
</div>

<script>
// ══════════════════════════════════════════
// DATA KONFIGURASI & DEFAULTS
// ══════════════════════════════════════════
const SK = "mykaunseling_v3";

const DFLT = {
  hebahan:[
    "Selamat datang ke MyKaunseling — Sistem Pengurusan Unit Psikologi dan Kaunseling IPGKPM.",
    "Perkhidmatan kaunseling dalam talian kini tersedia. Sila jadualkan temujanji melalui pautan di bawah.",
    "Program Kesihatan Mental Pelajar 2025 — Daftar sekarang melalui portal ini.",
    "Bengkel Psikopendidikan Staf IPG — Sila rujuk jadual terkini."
  ],
  pautan:{
    pelajar:[
      {id:"p1",nama:"Ujian Psikologi Dalam Talian",desk:"Jalani penilaian diri — stres, personaliti & kerjaya",ikon:"fa-clipboard-check",warna:"pri",aksi:"ujian"},
      {id:"p2",nama:"Temujanji Kaunseling",desk:"Jadualkan sesi bersemuka atau dalam talian",ikon:"fa-calendar-check",warna:"amb",aksi:"temujanji"},
      {id:"p3",nama:"Maklumat Psikopendidikan",desk:"Artikel, panduan & sumber psikologi",ikon:"fa-book-open",warna:"blue",aksi:"artikel"},
