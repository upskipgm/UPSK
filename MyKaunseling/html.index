        ].map(s=>`
        <div style="background:${s.bg};border-radius:8px;padding:12px;border-left:3px solid ${s.c};">
          <div style="font-size:.72rem;color:var(--muted);margin-bottom:2px;">${s.l}</div>
          <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:${s.c};">${s.v}</div>
          <div class="prog" style="margin-top:5px;"><div class="prog-fill" style="width:${st.total?((s.v/st.total)*100).toFixed(0):0}%;background:${s.c};"></div></div>
          <div style="font-size:.68rem;color:var(--muted);margin-top:2px;">${st.total?((s.v/st.total)*100).toFixed(1):0}%</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-venus-mars text-amb-500 mr-2"></i>Jantina & Aliran Sekolah</span></div>
      <div class="card-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
          <div style="text-align:center;background:#E8ECF2;border-radius:8px;padding:12px;">
            <div style="font-size:1.7rem;font-weight:800;font-family:'Outfit',sans-serif;color:#132238;">${st.L}</div>
            <div style="font-size:.72rem;color:var(--muted);"><i class="fas fa-mars text-blue-500 mr-1"></i>Lelaki</div>
            <div style="font-size:.7rem;color:#3B82F6;font-weight:600;">${st.total?((st.L/st.total)*100).toFixed(1):0}%</div>
          </div>
          <div style="text-align:center;background:#FDF3E6;border-radius:8px;padding:12px;">
            <div style="font-size:1.7rem;font-weight:800;font-family:'Outfit',sans-serif;color:#C47428;">${st.P}</div>
            <div style="font-size:.72rem;color:var(--muted);"><i class="fas fa-venus text-amb-500 mr-1"></i>Perempuan</div>
            <div style="font-size:.7rem;color:#E88D3A;font-weight:600;">${st.total?((st.P/st.total)*100).toFixed(1):0}%</div>
          </div>
        </div>
        <div style="font-size:.75rem;font-weight:700;color:var(--text);margin-bottom:8px;">Aliran Sekolah</div>
        ${[{l:"Sekolah Kebangsaan (SK)",v:st.sk,c:"#0E7C61"},{l:"SJK Cina (SJKC)",v:st.sjkc,c:"#E88D3A"},{l:"SJK Tamil (SJKT)",v:st.sjkt,c:"#8B5CF6"}].map(a=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
          <div style="width:9px;height:9px;border-radius:50%;background:${a.c};flex-shrink:0;"></div>
          <div style="font-size:.78rem;flex:1;">${a.l}</div>
          <span style="font-size:.78rem;font-weight:700;color:${a.c};">${a.v}</span>
          <div style="width:70px;"><div class="prog"><div class="prog-fill" style="width:${st.total?((a.v/st.total)*100).toFixed(0):0}%;background:${a.c};"></div></div></div>
          <div style="font-size:.7rem;color:var(--muted);width:36px;text-align:right;">${st.total?((a.v/st.total)*100).toFixed(1):0}%</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Program + Sesi -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-graduation-cap text-pri-500 mr-2"></i>Enrolmen Mengikut Program</span></div>
      <div class="card-body"><canvas id="ch-prog" height="220"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-calendar-alt text-navy-500 mr-2"></i>Enrolmen Mengikut Sesi Ambilan</span></div>
      <div class="card-body"><canvas id="ch-sesi" height="220"></canvas></div>
    </div>
  </div>

  <!-- Opsyen + Negeri -->
  <div style="display:grid;grid-template-columns:${isUtama?"1fr 1fr":"1fr"};gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-list-check text-amb-500 mr-2"></i>Top Opsyen Pengajian</span></div>
      <div class="card-body">
        ${topOpsyen.map(([ops,bil],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="width:22px;height:22px;border-radius:50%;background:${colors[i]};color:#fff;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${i+1}</div>
          <div style="font-size:.82rem;font-weight:600;flex:1;">${ops}</div>
          <div style="width:100px;"><div class="prog"><div class="prog-fill" style="width:${topOpsyen[0][1]?((bil/topOpsyen[0][1])*100).toFixed(0):0}%;background:${colors[i]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;color:var(--navy);width:28px;text-align:right;">${bil}</div>
        </div>`).join("")}
      </div>
    </div>
    ${isUtama?`<div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-map-marker-alt text-red-500 mr-2"></i>Negeri Asal Pelajar</span></div>
      <div class="card-body"><canvas id="ch-negeri" height="280"></canvas></div>
    </div>`:""}
  </div>

  <!-- Senarai Pelajar -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-pri-500 mr-2"></i>Senarai Pelajar</span>
      <div style="display:flex;gap:6px;align-items:center;">
        <span style="font-size:.72rem;color:var(--muted);">${rawData.length} rekod</span>
        <button class="btn btn-out btn-sm" onclick="exportEnrolmenCSV()"><i class="fas fa-download"></i>CSV</button>
        <button class="btn btn-ghost btn-sm" onclick="exportPagePDF()" style="font-size:11px;"><i class="fas fa-file-pdf" style="color:#DC2626;"></i> PDF</button>
      </div>
    </div>
    <div class="card-body" style="padding-bottom:8px;">
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;">
        <input type="text" class="fi" style="max-width:190px;font-size:.8rem;" placeholder="Cari nama / matrik..." id="en-cari" oninput="filterEnrolmen()">
        <select class="fi" style="width:auto;font-size:.8rem;" id="en-status" onchange="filterEnrolmen()">
          <option value="">Semua Status</option><option>AKTIF</option><option>BERHENTI</option><option>TANGGUH</option>
        </select>
        <select class="fi" style="width:auto;font-size:.8rem;" id="en-jantina" onchange="filterEnrolmen()">
          <option value="">Semua Jantina</option><option value="L">Lelaki</option><option value="P">Perempuan</option>
        </select>
        <select class="fi" style="width:auto;font-size:.8rem;" id="en-aliran" onchange="filterEnrolmen()">
          <option value="">Semua Aliran</option><option>SK</option><option>SJKC</option><option>SJKT</option>
        </select>
        <select class="fi" style="width:auto;font-size:.8rem;" id="en-prog" onchange="filterEnrolmen()">
          <option value="">Semua Program</option><option>PPISMP</option><option>PISMP</option><option>DPLI</option>
        </select>
        ${isUtama?`<select class="fi" style="width:auto;font-size:.8rem;" id="en-kampus" onchange="filterEnrolmen()">
          <option value="">Semua Kampus</option>${kampusOptgroup()}
        </select>`:""}
        <button class="btn btn-ghost btn-sm" onclick="resetFilterEnrolmen()" title="Set semula"><i class="fas fa-rotate-left"></i></button>
      </div>
      <div style="font-size:.72rem;color:var(--muted);" id="en-count">Menunjukkan ${Math.min(rawData.length,30)} daripada ${rawData.length} rekod</div>
    </div>
    <div style="overflow-x:auto;" id="en-table">${renderEnrolmenTable(rawData.slice(0,30),isUtama)}</div>
  </div>`;

  window._enRaw=rawData; window._enUtama=isUtama;

  setTimeout(()=>{
    const pl=Object.keys(st.progCount), pv=Object.values(st.progCount);
    _charts.prog=new Chart(document.getElementById("ch-prog"),{
      type:"doughnut",
      data:{labels:pl,datasets:[{data:pv,backgroundColor:["#0E7C61","#E88D3A","#3B82F6"],borderWidth:0,hoverOffset:6}]},
      options:{responsive:true,cutout:"60%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });
    const sl=sesiOrder.filter(s=>st.sesiCount[s]);
    _charts.sesi=new Chart(document.getElementById("ch-sesi"),{
      type:"bar",
      data:{labels:sl,datasets:[{data:sl.map(s=>st.sesiCount[s]||0),backgroundColor:"rgba(14,124,97,0.75)",borderRadius:5}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
    });
    if(isUtama&&document.getElementById("ch-negeri")){
      _charts.negeri=new Chart(document.getElementById("ch-negeri"),{
        type:"bar",
        data:{labels:topNegeri.map(([n])=>n),datasets:[{data:topNegeri.map(([,v])=>v),backgroundColor:"rgba(59,130,246,0.7)",borderRadius:4}]},
        options:{responsive:true,indexAxis:"y",plugins:{legend:{display:false}},scales:{x:{beginAtZero:true}}}
      });
    }
  },80);
}

function renderEnrolmenTable(data,isUtama){
  if(!data.length)return`<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod ditemui.</p>`;
  return`<table class="tbl" id="en-table-inner"><thead><tr>
    <th>No. Matrik</th><th>Nama</th><th>Jantina</th>
    ${isUtama?"<th>Kampus</th>":""}
    <th>Program</th><th>Opsyen</th><th>Aliran</th>
    <th>Sesi Ambilan</th><th>Sesi Tamat</th><th>Status</th>
  </tr></thead>
  <tbody>${data.map((d,i)=>`<tr>
    <td class="font-mono text-xs">${d.no_matrik}</td>
    <td><div style="display:flex;align-items:center;gap:6px;">
      <div class="ava" style="background:${d.jantina==="L"?"#C5CDE0":"#FAE0BF"};color:${d.jantina==="L"?"#1F2C50":"#9A5A1E"};font-size:.6rem;">${d.jantina}</div>
      <span style="font-weight:500;font-size:.79rem;">${d.nama}</span>
    </div></td>
    <td><span class="bdg ${d.jantina==="L"?"bdg-blue":"bdg-amber"}" style="font-size:.65rem;">${d.jantina==="L"?"Lelaki":"Perempuan"}</span></td>
    ${isUtama?`<td style="font-size:.72rem;white-space:nowrap;">${d.kampus_nama.replace("IPG Kampus ","")}</td>`:""}
    <td><span class="bdg bdg-pri" style="font-size:.65rem;">${d.program}</span></td>
    <td style="font-size:.78rem;font-weight:600;">${d.opsyen_1}${d.opsyen_2!=="0"?" / "+d.opsyen_2:""}</td>
    <td><span class="bdg ${d.aliran_sekolah==="SK"?"bdg-green":d.aliran_sekolah==="SJKC"?"bdg-amber":"bdg-red"}" style="font-size:.65rem;">${d.aliran_sekolah}</span></td>
    <td style="font-size:.78rem;">${d.sesi_ambilan}</td>
    <td style="font-size:.78rem;color:var(--muted);">${d.sesi_tamat}</td>
    <td><span class="bdg ${d.status_pengajian==="AKTIF"?"bdg-green":d.status_pengajian==="BERHENTI"?"bdg-red":"bdg-amber"}" style="font-size:.65rem;">${d.status_pengajian}</span></td>
  </tr>`).join("")}</tbody></table>`;
}

function filterEnrolmen(){
  let d=window._enRaw||[];
  const q=(document.getElementById("en-cari")?.value||"").toLowerCase();
  const sts=document.getElementById("en-status")?.value||"";
  const jan=document.getElementById("en-jantina")?.value||"";
  const ali=document.getElementById("en-aliran")?.value||"";
  const prg=document.getElementById("en-prog")?.value||"";
  const kid=document.getElementById("en-kampus")?.value||"";
  if(q)  d=d.filter(x=>x.nama.toLowerCase().includes(q)||x.no_matrik.toLowerCase().includes(q));
  if(sts)d=d.filter(x=>x.status_pengajian===sts);
  if(jan)d=d.filter(x=>x.jantina===jan);
  if(ali)d=d.filter(x=>x.aliran_sekolah===ali);
  if(prg)d=d.filter(x=>x.program===prg);
  if(kid)d=d.filter(x=>x.kampus_id===kid);
  const shown=d.slice(0,50);
  document.getElementById("en-table").innerHTML=renderEnrolmenTable(shown,window._enUtama||false);
  document.getElementById("en-count").textContent=`Menunjukkan ${shown.length} daripada ${d.length} rekod`;
}

function resetFilterEnrolmen(){
  ["en-cari","en-status","en-jantina","en-aliran","en-prog","en-kampus"].forEach(id=>{const el=document.getElementById(id);if(el)el.value="";});
  filterEnrolmen();
}

function exportEnrolmenCSV(){
  const d=window._enRaw||[];
  const h=["NO_MATRIK","NAMA","JANTINA","KAMPUS","ZON","PROGRAM","OPSYEN_1","OPSYEN_2","ALIRAN_SEKOLAH","SESI_AMBILAN","SESI_TAMAT","STATUS_PENGAJIAN","AGAMA","NEGERI","DAERAH"];
  const rows=d.map(x=>[x.no_matrik,`"${x.nama}"`,x.jantina,`"${x.kampus_nama}"`,x.zon,x.program,x.opsyen_1,x.opsyen_2,x.aliran_sekolah,x.sesi_ambilan,x.sesi_tamat,x.status_pengajian,x.agama_txt,x.negeri,x.daerah].join(","));
  const csv=[h.join(","),...rows].join("\n");
  const blob=new Blob([csv],{type:"text/csv;charset=utf-8;"});
  const url=URL.createObjectURL(blob);
  const a=document.createElement("a");a.href=url;a.download="Enrolmen_Pelajar_IPGKPM.csv";a.click();
  URL.revokeObjectURL(url);
  toast("Fail CSV berjaya dieksport","ok");
}


// ══════════════════════════════════════════
// KONFIGURASI SHEETS — 4 TAB
// ══════════════════════════════════════════
const SHEET_TABS = {
  enrolmen:  "ENROLMEN",
  pkpp:      "PKPP",
  pkpw:      "PKPW",
  minda:     "Minda Sihat",
  sesi:      "Sesi",
  program:   "Program",
  kaunselor: "Analisis Kaunselor"
};

// Auto-detect tab names if defaults fail
const SHEET_TAB_FALLBACKS = {
  enrolmen:  ["ENROLMEN","Sheet1","Enrolmen","DATA","Helaian1"],
  pkpp:      ["PKPP","Pkpp","PKPP Pelajar"],
  pkpw:      ["PKPW","Pkpw","PKPW Warga"],
  minda:     ["Minda Sihat","Minda","MINDA SIHAT","MindaSihat"],
  sesi:      ["Sesi","SESI","Analisis Sesi","Perkhidmatan Sesi"],
  program:   ["Program","PROGRAM","Analisis Program"],
  kaunselor: ["Analisis Kaunselor","Kaunselor","KAUNSELOR","Data Kaunselor"]
};

// ── Universal fetch dari Google Sheets untuk semua tab ──
async function fetchSheetTab(tabKey){
  // Cuba nama tab utama dulu, kemudian fallback names
  const tabNames = [SHEET_TABS[tabKey], ...(SHEET_TAB_FALLBACKS[tabKey]||[])].filter(Boolean);
  let lastErr = "";

  for(const tabName of tabNames){
    try {
      const batchSize = 5000;
      let allRows = [], headers = null, startRow = 1, hasMore = true;
      while(hasMore){
        const range = encodeURIComponent(`${tabName}!A${startRow}:CV${startRow+batchSize-1}`);
        const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEETS_CONFIG.spreadsheetId}/values/${range}?key=${SHEETS_CONFIG.apiKey}`;
        const resp = await fetch(url);
        if(!resp.ok){
          lastErr = `Tab "${tabName}": HTTP ${resp.status}`;
          break;
        }
        const json = await resp.json();
        if(!json.values || !json.values.length){ hasMore=false; break; }
        if(startRow===1){ headers=json.values[0]; allRows=allRows.concat(json.values.slice(1)); }
        else { allRows=allRows.concat(json.values); }
        if(json.values.length < batchSize) hasMore=false;
        else startRow += batchSize;
      }
      if(headers && allRows.length > 0){
        // Update tab name untuk session ini
        SHEET_TABS[tabKey] = tabName;
        console.log(`Sheets: tab "${tabName}" — ${allRows.length} baris`);
        return { headers, rows: allRows };
      }
    } catch(e){ lastErr = e.message; }
  }
  console.warn(`fetchSheetTab(${tabKey}) semua gagal. Last error: ${lastErr}`);
  return null;
}

// ── Load data untuk mana-mana tab — Sheets > IDB > CSV ──
async function loadTabData(tabKey, parseRowFn, cacheObj, cacheKey){
  // 1. Semak cache memori dulu
  // Untuk PKPW/PKPP: semak jika data ada sKesejahteraan (kalau 0 semua = stale)
  if(cacheObj[cacheKey] && cacheObj[cacheKey].length > 0){
    const cached = cacheObj[cacheKey];
    // Jika tab psikologi, semak kualiti data
    if(tabKey==="pkpp"||tabKey==="pkpw"){
      const hasScores = cached.some(d=>(d.sKesejahteraan||0)>0 || (d.extra||0)>0);
      if(hasScores) return cached; // Data baik, guna cache
      // Jika semua skor 0, buang cache dan fetch semula
      cacheObj[cacheKey] = null;
      console.log(`Cache ${tabKey} stale (skor=0), fetching fresh...`);
    } else {
      return cached;
    }
  }

  // 2. Cuba Google Sheets API
  const sheetData = await fetchSheetTab(tabKey);
  if(sheetData && sheetData.rows && sheetData.rows.length > 0){
    const hi = {};
    sheetData.headers.forEach((h,i) => { hi[h.trim().toUpperCase()] = i; });
    const parsed = sheetData.rows
      .filter(r => r && r.length > 2)
      .map(r => parseRowFn(r, hi))
      .filter(d => d.tahun || d.organisasi || d.nama);
    if(parsed.length > 0){
      cacheObj[cacheKey] = parsed;
      // Simpan ke IDB untuk offline
      if(typeof idbSave==="function"){
        idbSave("csv_"+tabKey, parsed).then(ok=>{
          if(ok) localStorage.setItem("csv_"+tabKey+"_date", new Date().toLocaleString("ms-MY")+"  ★Sheets");
        });
      }
      console.log(`Sheets: ${parsed.length} rekod ${tabKey}`);
      return parsed;
    }
  }

  // 3. Fallback: IDB (data upload sebelum ini)
  if(typeof idbLoad==="function"){
    const rec = await idbLoad("csv_"+tabKey);
    if(rec && rec.data && rec.data.length > 0){
      cacheObj[cacheKey] = rec.data;
      console.log(`IDB: ${rec.data.length} rekod ${tabKey}`);
      return rec.data;
    }
  }

  return [];
}

// Cache data setiap tab
const SHEETS_CACHE = { pkpp:null, pkpw:null, minda:null };

async function fetchTab(tabName){
  const batchSize = 5000;
  let allRows = [], headers = null, startRow = 1, hasMore = true;
  while(hasMore){
    const range = `${tabName}!A${startRow}:CV${startRow+batchSize-1}`;
    const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEETS_CONFIG.spreadsheetId}/values/${encodeURIComponent(range)}?key=${SHEETS_CONFIG.apiKey}`;
    const resp = await fetch(url);
    if(!resp.ok) throw new Error(`Tab "${tabName}": HTTP ${resp.status}`);
    const json = await resp.json();
    if(!json.values || json.values.length===0){hasMore=false;break;}
    if(startRow===1){headers=json.values[0];allRows=allRows.concat(json.values.slice(1));}
    else{allRows=allRows.concat(json.values);}
    if(json.values.length < batchSize) hasMore=false;
    else startRow += batchSize;
  }
  if(!headers) throw new Error("Tiada header");
  const hi={};headers.forEach((h,i)=>{hi[h.trim()]=i;});
  return {headers,rows:allRows,hi};
}

function g(row, hi, col){ return (row[hi[col]]||"").toString().trim(); }

// Parse PKPP/PKPW row
function parsePKPRow(row, hi){
  // Detect format: PKPW uses "name","gender","ipgKampus","jawatan"
  // PKPP uses "Nama Penuh","Jantina","IPG Kampus","Program","Semester"
  const hiKeys = Object.keys(hi);
  const hiLower = hiKeys.map(k=>k.toLowerCase());
  const isPKPW = hiLower.includes("name") || hiLower.includes("jawatan") ||
                 hiLower.includes("wellbeingtotal") || hiLower.includes("ipgkampus");

  // Safe getter - checks ALL key variants including camelCase
  const gm = (...cols) => {
    for(const c of cols){
      const variants = [c, c.toUpperCase(), c.toLowerCase(), c.trim(),
                        c.replace(/_/g," "), c.replace(/ /g,"_")];
      for(const v of variants){
        if(hi[v]!==undefined){
          const val=(row[hi[v]]||"").toString().trim().replace(/^"|"$/g,"");
          if(val) return val;
        }
      }
    }
    return "";
  };
  // Safe numeric getter
  const gn = (...cols) => {
    for(const c of cols){
      const variants = [c, c.toUpperCase(), c.toLowerCase(), c.trim(),
                        c.replace(/_/g," "), c.replace(/ /g,"_")];
      for(const v of variants){
        if(hi[v]!==undefined){
          const val=parseFloat((row[hi[v]]||"").toString().replace(/,/g,"").trim());
          if(!isNaN(val)) return val;
        }
      }
    }
    return 0;
  };

  return {
    timestamp:    gm("Timestamp","timestamp"),
    nama:         gm("Nama Penuh","name","nama"),
    jantina:      gm("Jantina","gender","jantina"),
    bangsa:       gm("Bangsa","race","bangsa"),
    agama:        gm("Agama","religion","agama"),
    kampus:       gm("IPG Kampus","ipgKampus","kampus","IPG Kampus "),
    // PKPW: jawatan + gred | PKPP: program + semester
    program:      isPKPW ? gm("jawatan","gred","Jawatan") : gm("Program","program"),
    semester:     isPKPW ? gm("gred","jawatan") : gm("Semester","semester"),
    jawatan:      gm("jawatan","Jawatan","Program","program"),
    gred:         gm("gred","Gred","Semester","semester"),
    pendapatan:   gm("Pendapatan Isi Rumah","pendapatan"),
    // Big Five scores — capped at 100 (max scale)
    extra:        Math.min(gn("Extraversion","extraversion"), 100),
    agree:        Math.min(gn("Agreeableness","agreeableness"), 100),
    consc:        Math.min(gn("Conscientiousness","conscientiousness"), 100),
    neuro:        Math.min(gn("Neuroticism","neuroticism"), 100),
    open:         Math.min(gn("Openness","openness"), 100),
    // Big Five tahap
    tExtra: gm("Tahap Extra","tahap_extraversion"),
    tAgree: gm("Tahap Agreeableness","tahap_agreeableness"),
    tConsc: gm("Tahap Consc","tahap_conscientiousness"),
    tNeuro: gm("Tahap Neuro","tahap_neuroticism"),
    tOpen:  gm("Tahap Openn","tahap_openness"),
    // Skor domain kesejahteraan
    // PKPP: individual domain scores | PKPW: wellbeingTotal + top domains
    sEmosi:       isPKPW ? 0 : gn("Skor Emosi","skor emosi","SKOR EMOSI"),
    sKendiri:     isPKPW ? 0 : gn("Skor Kendiri","skor kendiri","SKOR KENDIRI"),
    sFizikal:     isPKPW ? 0 : gn("Skor Fizikal","skor fizikal","SKOR FIZIKAL"),
    sPerhub:      isPKPW ? 0 : gn("Skor Perhubungan","skor perhubungan","SKOR PERHUBUNGAN"),
    sIntelek:     isPKPW ? 0 : gn("Skor Intelektual","skor intelektual","SKOR INTELEKTUAL"),
    sSpiritual:   isPKPW ? 0 : gn("Skor Spiritual","skor spiritual","SKOR SPIRITUAL"),
    sIdentiti:    isPKPW ? 0 : gn("Skor Identiti","skor identiti","SKOR IDENTITI"),
    sKewangan:    isPKPW ? 0 : gn("Skor Kewangan","skor kewangan","SKOR KEWANGAN"),
    sKeselarasan: isPKPW ? 0 : gn("Skor Keselarasan","skor keselarasan","SKOR KESELARASAN"),
    // Top domains (PKPW)
    domain1:      gm("domain_1","Domain 1"),
    domain2:      gm("domain_2","Domain 2"),
    domain3:      gm("domain_3","Domain 3"),
    // Skor kesejahteraan keseluruhan
    sKesejahteraan: isPKPW
      ? gn("wellbeingTotal","wellbeingtotal","WELLBEINGTOTAL",
           "SKOR KESEJAHTERAAN","SKOR KESEJAHTERAAN ")
      : gn("SKOR KESEJAHTERAAN","SKOR KESEJAHTERAAN ","wellbeingTotal"),
    // Tahap & Peratus kesejahteraan
    tKesejahteraan: gm("tahap_kesejahteraan","tahap kesejahteraan",
                       "TAHAP KESEJAHTERAAN","Tahap Kesejahteraan"),
    pKesejahteraan: isPKPW
      ? gn("wellbeingPercentage","wellbeingpercentage","WELLBEINGPERCENTAGE","Peratus Kesejahteraan")
      : gn("Peratus Kesejahteraan","PERATUS KESEJAHTERAAN","wellbeingPercentage"),
    // Tahap domain PKPP
    tEmosi:       gm("Tahap Emosi"),
    tKendiri:     gm("Tahap Kendiri"),
    tFizikal:     gm("Tahap Fizikal"),
    tPerhub:      gm("Tahap Perhubungan"),
    tIntelek:     gm("Tahap Intelektual"),
    tSpiritual:   gm("Tahap Spiritual"),
    tIdentiti:    gm("Tahap Identiti"),
    tKewangan:    gm("Tahap kewangan"),
    tKeselarasan: gm("Tahap Keselarasan"),
    // PKPW resilience
    resilienceMean: gn("resilienceMean","resilience_mean"),
    tahapDayaTahan: gm("tahap_daya_tahan","Tahap Daya Tahan"),
    // Flag format
    isPKPW,
  };
}

// Parse Minda Sihat row
function parseMindaRow(row, hi){
  // Safe getter that tries multiple variants
  const gx = (...cols) => {
    for(const c of cols){
      for(const v of [c, c.toUpperCase(), c.toLowerCase(), c.trim()]){
        if(hi[v]!==undefined){
          const val=(row[hi[v]]||"").toString().trim().replace(/^"|"$/g,"");
          if(val) return val;
        }
      }
    }
    return "";
  };
  const nx = (...cols) => {
    for(const c of cols){
      for(const v of [c, c.toUpperCase(), c.toLowerCase(), c.trim()]){
        if(hi[v]!==undefined){
          const val=parseFloat((row[hi[v]]||"").toString().replace(/,/g,"").trim());
          if(!isNaN(val)) return val;
        }
      }
    }
    return 0;
  };
  return {
    timestamp:   gx("Timestamp","TIMESTAMP","timestamp"),
    nama:        gx("NAMA PENUH","Nama Penuh","nama penuh","NAMA","nama"),
    jantina:     gx("JANTINA","Jantina","jantina","GENDER","gender"),
    bangsa:      gx("BANGSA","Bangsa","bangsa","RACE","race"),
    agama:       gx("AGAMA","Agama","agama","RELIGION","religion"),
    kampus:      gx("PILIH INSTITUT PENDIDIKAN GURU MALAYSIA KAMPUS",
                    "PILIH INSTITUT PENDIDIKAN GURU MALAYSIA KAMPUS ",
                    "IPG Kampus","IPG KAMPUS","ipgKampus","KAMPUS","kampus"),
    program:     gx("PROGRAM PENGAJIAN ","PROGRAM PENGAJIAN","Program Pengajian",
                    "PROGRAM","program"),
    bidang:      gx("BIDANG PENGAJIAN ","BIDANG PENGAJIAN","Bidang Pengajian","BIDANG"),
    kemurungan:  nx("KEMURUNGAN","Kemurungan","kemurungan","DEPRESSION"),
    kebimbangan: nx("KEBIMBANGAN","Kebimbangan","kebimbangan","ANXIETY"),
    stres:       nx("STRES","Stres","stres","STRESS"),
    tahapD:      gx("TAHAP D","Tahap D","tahap_d","TAHAP_D"),
    tahapA:      gx("TAHAP A","Tahap A","tahap_a","TAHAP_A"),
    tahapS:      gx("TAHAP S","Tahap S","tahap_s","TAHAP_S"),
    dt:          nx("DT","dt","Daya Tindak","DAYA TINDAK"),
    tahapDT:     gx("TAHAP DT","Tahap DT","tahap_dt","TAHAP_DT","TAHAP DAYA TINDAK"),
  };
}

// ── PKPP STAT helper ──
function pkpStat(data){
  const n = data.length || 1;
  const avg = (arr) => arr.reduce((s,x)=>s+x,0)/arr.length||0;
  const countTahap = (key) => {
    const c={TINGGI:0,"SEDERHANA TINGGI":0,SEDERHANA:0,"SEDERHANA RENDAH":0,RENDAH:0};
    data.forEach(d=>{ const t=d[key]||""; c[t]=(c[t]||0)+1; });
    return c;
  };
  return {
    n: data.length,
    avgKesejahteraan: avg(data.map(d=>d.sKesejahteraan)),
    avgPeratus: avg(data.map(d=>d.pKesejahteraan)),
    // Big Five avg
    avgExtra: (()=>{ const v=data.map(d=>d.extra||0).filter(x=>x>0&&x<=100); return v.length?v.reduce((s,x)=>s+x,0)/v.length:0; })(),
    avgAgree: (()=>{ const v=data.map(d=>d.agree||0).filter(x=>x>0&&x<=100); return v.length?v.reduce((s,x)=>s+x,0)/v.length:0; })(),
    avgConsc: (()=>{ const v=data.map(d=>d.consc||0).filter(x=>x>0&&x<=100); return v.length?v.reduce((s,x)=>s+x,0)/v.length:0; })(),
    avgNeuro: (()=>{ const v=data.map(d=>d.neuro||0).filter(x=>x>0&&x<=100); return v.length?v.reduce((s,x)=>s+x,0)/v.length:0; })(),
    avgOpen:  (()=>{ const v=data.map(d=>d.open||0).filter(x=>x>0&&x<=100); return v.length?v.reduce((s,x)=>s+x,0)/v.length:0; })(),
    // Domain avg
    avgEmosi:    avg(data.map(d=>d.sEmosi)),
    avgKendiri:  avg(data.map(d=>d.sKendiri)),
    avgFizikal:  avg(data.map(d=>d.sFizikal)),
    avgPerhub:   avg(data.map(d=>d.sPerhub)),
    avgIntelek:  avg(data.map(d=>d.sIntelek)),
    avgSpiritual:avg(data.map(d=>d.sSpiritual)),
    avgIdentiti: avg(data.map(d=>d.sIdentiti)),
    avgKewangan: avg(data.map(d=>d.sKewangan)),
    // Tahap kesejahteraan count
    tahapCount: countTahap("tKesejahteraan"),
    // Jantina
    L: data.filter(d=>d.jantina==="Lelaki"||d.jantina==="L"||d.jantina==="LELAKI").length,
    P: data.filter(d=>d.jantina==="Perempuan"||d.jantina==="P"||d.jantina==="PEREMPUAN").length,
    // Bangsa
    bangsa: Object.entries(data.reduce((a,d)=>{const b=d.bangsa||"Lain";a[b]=(a[b]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]).slice(0,6),
    // Kampus
    kampusCount: Object.entries(data.reduce((a,d)=>{const k=d.kampus||"?";a[k]=(a[k]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]).slice(0,10),
    // Program
    progCount: Object.entries(data.reduce((a,d)=>{const p=d.program||"?";a[p]=(a[p]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]),
    // Semester (PKPP) / Jawatan+Gred (PKPW)
    semCount: Object.entries(data.reduce((a,d)=>{
      const isPW = d.isPKPW;
      const s = isPW ? (d.jawatan||d.gred||d.program||"?") : (d.semester||"?");
      a[s]=(a[s]||0)+1; return a;
    },{})).sort((a,b)=>a[0].localeCompare(b[0])),
    // Pendapatan
    pendCount: Object.entries(data.reduce((a,d)=>{const p=d.pendapatan||"?";a[p]=(a[p]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]),
  };
}

// ── MINDA STAT helper ──
function mindaStat(data){
  const n = data.length||1;
  const avg = (arr) => (arr.reduce((s,x)=>s+x,0)/arr.length||0).toFixed(1);
  const ct = (key) => {
    const c={NORMAL:0,RINGAN:0,SEDERHANA:0,TERUK:0,"SANGAT TERUK":0};
    data.forEach(d=>{ const t=(d[key]||"").toUpperCase(); c[t]=(c[t]||0)+1; });
    return c;
  };
  return {
    n: data.length,
    avgD: avg(data.map(d=>d.kemurungan)),
    avgA: avg(data.map(d=>d.kebimbangan)),
    avgS: avg(data.map(d=>d.stres)),
    avgDT: avg(data.map(d=>d.dt)),
    ctD: ct("tahapD"), ctA: ct("tahapA"), ctS: ct("tahapS"),
    ctDT: Object.entries(data.reduce((a,d)=>{const t=d.tahapDT||"?";a[t]=(a[t]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]),
    L: data.filter(d=>["Lelaki","L","LELAKI","Laki-laki"].includes(d.jantina)).length,
    P: data.filter(d=>["Perempuan","P","PEREMPUAN"].includes(d.jantina)).length,
    kampusCount: Object.entries(data.reduce((a,d)=>{const k=d.kampus||"?";a[k]=(a[k]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]).slice(0,10),
    progCount: Object.entries(data.reduce((a,d)=>{const p=(d.program||"").split(".").pop().trim()||"?";a[p]=(a[p]||0)+1;return a;},{})).sort((a,b)=>b[1]-a[1]),
  };
}

// ══════════════════════════════════════════
// RENDER PKPP / PKPW
// ══════════════════════════════════════════
function pgAKPKPP(c){ loadAndRenderPKP(c,"pkpp",SES.kampus); }
function pgAKPKPW(c){ loadAndRenderPKP(c,"pkpw",SES.kampus); }
function pgAUPKPP(c){ loadAndRenderPKP(c,"pkpp",null); }
function pgAUPKPW(c){ loadAndRenderPKP(c,"pkpw",null); }

async function loadAndRenderPKP(c, tab, kampusFilter){
  const label = tab==="pkpp"?"PKPP — Profil Kesejahteraan & Personaliti Pelajar":"PKPW — Profil Kesejahteraan & Personaliti Warga";
  c.innerHTML=`<div style="padding:40px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:14px;display:block;color:var(--pri);"></i><div style="font-size:14px;font-weight:500;">Memuatkan ${label}...</div><div id="pkp-progress" style="font-size:12px;margin-top:6px;color:var(--muted);">Menyambung ke Google Sheets...</div></div>`;
  try {
    const parsed = await loadTabData(tab, parsePKPRow, SHEETS_CACHE, tab);
    SHEETS_CACHE[tab] = parsed;
    let data = SHEETS_CACHE[tab];
    if(kampusFilter) data = data.filter(d=>d.kampus.includes(kObj(kampusFilter).nama?.replace("IPG Kampus ","")||kampusFilter));
    if(tab==="pkpw"){
      renderPKPWDashboard(c, data, kampusFilter);
    } else {
      renderPKPDashboard(c, data, label, tab, kampusFilter);
    }
  } catch(err){
    // Tunjuk UI untuk import CSV manual
    const label = tab==="pkpp"?"PKPP":"PKPW";
    c.innerHTML = '<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:20px;max-width:560px;margin:20px auto;">'
      + '<div style="font-size:15px;font-weight:700;color:#92400e;margin-bottom:6px;"><i class="fas fa-triangle-exclamation" style="margin-right:6px;"></i>Gagal sambung ke Google Sheets</div>'
      + '<div style="font-size:12px;color:#92400e;margin-bottom:16px;">' + err.message + '<br>Muat naik CSV dari tab ' + label + ' untuk papar data.</div>'
      + '<div style="display:flex;flex-direction:column;gap:10px;">'
      + '<label id="pkp-upload-lbl" style="background:#0E7C61;color:#fff;padding:8px 16px;border-radius:7px;cursor:pointer;font-size:13px;font-weight:600;display:inline-flex;align-items:center;gap:8px;width:fit-content;">'
      + '<i class="fas fa-file-csv" style="margin-right:4px;"></i> Muat Naik CSV Tab ' + label
      + '<input type="file" accept=".csv" id="pkp-file-input" style="display:none">'
      + '</label>'
      + '<div style="font-size:11px;color:#92400e;"><b>Cara eksport CSV:</b><br>File → Download → Comma Separated Values (.csv) dalam tab <b>' + label + '</b></div>'
      + '</div></div>';
    setTimeout(function(){
      var fi = document.getElementById("pkp-file-input");
      if(fi) fi.onchange = function(){ importCSVPKP(this, tab, kampusFilter||null); };
    }, 100);
  }
}

// ══════════════════════════════════════════
// PKPW DASHBOARD — Personaliti, Kesejahteraan, Resiliens
// ══════════════════════════════════════════
function renderPKPWDashboard(c, data, kampusFilter){
  if(!data || !data.length){
    c.innerHTML += `<div style="text-align:center;padding:48px;color:var(--muted);">
      <i class="fas fa-user-shield" style="font-size:40px;display:block;margin-bottom:14px;opacity:.2;"></i>
      <div style="font-size:14px;font-weight:600;">Tiada data PKPW</div>
      <div style="font-size:12px;margin-top:4px;">Muat naik CSV tab PKPW untuk papar analisis</div>
    </div>`; return;
  }

  const n = data.length;
  // avg for general fields
  const avg = arr => arr.length ? arr.reduce((s,x)=>s+x,0)/arr.length : 0;
  // avg for Big Five — only use valid values (1-100), exclude 0 and >100
  const avgBF = (arr) => {
    const valid = arr.filter(x => x > 0 && x <= 100);
    return valid.length ? valid.reduce((s,x)=>s+x,0)/valid.length : 0;
  };

  // Stats
  const avgWellbeing     = avg(data.map(d=>d.sKesejahteraan||0));
  const avgWellbeingPct  = avg(data.map(d=>d.pKesejahteraan||0));
  const avgResilience    = avg(data.map(d=>d.resilienceMean||0));
  const avgExtra = avgBF(data.map(d=>d.extra||0));
  const avgAgree = avgBF(data.map(d=>d.agree||0));
  const avgConsc = avgBF(data.map(d=>d.consc||0));
  const avgNeuro = avgBF(data.map(d=>d.neuro||0));
  const avgOpen  = avgBF(data.map(d=>d.open||0));

  // Tahap counts
  const countTahap = key => {
    const c={};
    data.forEach(d=>{ const t=(d[key]||"").toUpperCase(); c[t]=(c[t]||0)+1; });
    return Object.entries(c).filter(([k])=>k).sort((a,b)=>b[1]-a[1]);
  };
  const tahapKesej   = countTahap("tKesejahteraan");
  const tahapTahan   = countTahap("tahapDayaTahan");
  const tahapColors  = {"TINGGI":"#0E7C61","SEDERHANA TINGGI":"#34D399","SEDERHANA":"#FBBF24","SEDERHANA RENDAH":"#F97316","RENDAH":"#EF4444"};

  // Top domain counts
  const domainCount = {};
  data.forEach(d=>{
    [d.domain1, d.domain2, d.domain3].filter(Boolean).forEach(dom=>{
      domainCount[dom] = (domainCount[dom]||0)+1;
    });
  });
  const topDomains = Object.entries(domainCount).sort((a,b)=>b[1]-a[1]).slice(0,8);

  // Jantina, jawatan, kampus
  const L = data.filter(d=>["LELAKI","L","PEREMPUAN"==="X"?"":"LELAKI"].includes((d.jantina||"").toUpperCase())).length;
  const byJantina = {};
  data.forEach(d=>{ const j=d.jantina||"?"; byJantina[j]=(byJantina[j]||0)+1; });
  const byJawatan = {};
  data.forEach(d=>{ const j=d.jawatan||"?"; byJawatan[j]=(byJawatan[j]||0)+1; });
  const byKampus = {};
  data.forEach(d=>{ const k=d.kampus||"?"; byKampus[k]=(byKampus[k]||0)+1; });

  const colors8 = ["#0E7C61","#E88D3A","#3B82F6","#8B5CF6","#EF4444","#14B8A6","#F59E0B","#6366F1"];

  c.innerHTML += `
  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,#1F2C50,#3D5490);border-radius:12px;padding:20px 24px;margin-bottom:18px;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-20px;top:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    <div style="position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="display:flex;gap:8px;margin-bottom:6px;">
          <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-size:.7rem;padding:3px 10px;border-radius:20px;font-weight:600;"><i class="fas fa-user-shield mr-1"></i>PKPW</span>
          <span style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);font-size:.7rem;padding:3px 10px;border-radius:20px;">Profil Kesejahteraan & Personaliti Warga</span>
        </div>
        <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;color:#fff;margin-bottom:3px;">PKPW — Kesejahteraan & Personaliti Warga</div>
        <div style="font-size:.78rem;color:rgba(255,255,255,0.5);">${n} responden (Pensyarah & Staf) · Min Kesejahteraan: ${avgWellbeing.toFixed(1)} · ${avgWellbeingPct.toFixed(1)}%</div>
      </div>
      <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        ${isAdmin() ? `
          <label id="pkp-upload-label-pkpw" style="background:rgba(255,255,255,0.18);color:#fff;padding:5px 12px;border-radius:7px;cursor:pointer;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;">
            <i class="fas fa-upload"></i> Kemaskini CSV
            <input type="file" accept=".csv" id="pkp-upload-input-pkpw" style="display:none">
          </label>
          <button onclick="padamDataPKP('pkpw')" style="background:rgba(220,38,38,0.3);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;">
            <i class="fas fa-trash mr-1"></i>Padam
          </button>
        ` : `
          <button onclick="exportExcelFromTable('pkpw-tbl','PKPW_'+SES.kampus)" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-excel mr-1"></i>CSV</button>
          <button onclick="exportPagePDF()" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-pdf mr-1"></i>PDF</button>
        `}
        <button onclick="SHEETS_CACHE['pkpw']=null;if(typeof idbDelete==='function')idbDelete('csv_pkpw').then(()=>navTo(SES.pg));else navTo(SES.pg);" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:6px 14px;border-radius:8px;font-size:12px;cursor:pointer;"><i class="fas fa-rotate-right mr-1"></i>Refresh</button>
      </div>
    </div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Responden",   v:n, i:"fa-users",       c:"sc-navy", bg:"bg-navy-50", fg:"text-navy-600"},
      {l:"Min Kesejahteraan",  v:avgWellbeing.toFixed(1), i:"fa-heart-pulse", c:"sc-pri", bg:"bg-pri-50", fg:"text-pri-600", sub:"daripada 500"},
      {l:"Min % Kesejahteraan",v:avgWellbeingPct.toFixed(1)+"%", i:"fa-percent", c:"sc-amber", bg:"bg-amb-50", fg:"text-amb-600"},
      {l:"Min Resiliens",      v:avgResilience.toFixed(2), i:"fa-shield-heart", c:"sc-pri", bg:"bg-green-50", fg:"text-green-600", sub:"daripada 4.0"},
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--navy);">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
      ${s.sub?`<div style="font-size:.7rem;color:var(--muted);">${s.sub}</div>`:""}
    </div>`).join("")}
  </div>

  <!-- BAHAGIAN 1: PERSONALITI BIG FIVE -->
  <div style="background:#132238;border-radius:10px;padding:10px 16px;margin-bottom:12px;">
    <div style="color:rgba(255,255,255,0.7);font-size:.72rem;font-weight:700;letter-spacing:.08em;">BAHAGIAN 1 — PROFIL PERSONALITI</div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-star text-amb-500 mr-2"></i>Profil Big Five Personality</span></div>
      <div class="card-body"><canvas id="ch-pkpw-bigfive" height="240"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-bar-chart text-pri-500 mr-2"></i>Skor Min Big Five</span></div>
      <div class="card-body">
        ${[
          {l:"Extraversion",    v:avgExtra, c:"#3B82F6"},
          {l:"Agreeableness",   v:avgAgree, c:"#0E7C61"},
          {l:"Conscientiousness",v:avgConsc,c:"#E88D3A"},
          {l:"Neuroticism",     v:avgNeuro, c:"#EF4444"},
          {l:"Openness",        v:avgOpen,  c:"#8B5CF6"},
        ].map(b=>`
        <div style="margin-bottom:12px;">
          <div style="display:flex;justify-content:space-between;font-size:.78rem;margin-bottom:4px;">
            <span style="font-weight:600;">${b.l}</span>
            <span style="font-weight:700;color:${b.c};">${b.v.toFixed(1)}</span>
          </div>
          <div class="prog"><div class="prog-fill" style="width:${Math.min(b.v,100).toFixed(0)}%;background:${b.c};"></div></div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- BAHAGIAN 2: KESEJAHTERAAN -->
  <div style="background:#084A39;border-radius:10px;padding:10px 16px;margin-bottom:12px;">
    <div style="color:rgba(255,255,255,0.7);font-size:.72rem;font-weight:700;letter-spacing:.08em;">BAHAGIAN 2 — KESEJAHTERAAN</div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-chart-pie text-pri-500 mr-2"></i>Tahap Kesejahteraan Keseluruhan</span></div>
      <div class="card-body"><canvas id="ch-pkpw-kesej" height="220"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-trophy text-amb-500 mr-2"></i>Top Domain Kesejahteraan</span></div>
      <div class="card-body">
        ${topDomains.map(([dom,bil],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="width:22px;height:22px;border-radius:50%;background:${colors8[i%8]};color:#fff;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">${i+1}</div>
          <div style="font-size:.82rem;font-weight:500;flex:1;">${dom}</div>
          <div style="width:90px;"><div class="prog"><div class="prog-fill" style="width:${topDomains[0]?((bil/topDomains[0][1])*100).toFixed(0):0}%;background:${colors8[i%8]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:36px;text-align:right;">${bil}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- BAHAGIAN 3: RESILIENS -->
  <div style="background:#1e3a8a;border-radius:10px;padding:10px 16px;margin-bottom:12px;">
    <div style="color:rgba(255,255,255,0.7);font-size:.72rem;font-weight:700;letter-spacing:.08em;">BAHAGIAN 3 — RESILIENS / DAYA TAHAN</div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-shield-heart text-blue-500 mr-2"></i>Tahap Daya Tahan</span></div>
      <div class="card-body">
        ${tahapTahan.map(([t,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:9px;">
          <div style="font-size:.82rem;flex:1;font-weight:500;">${t||"—"}</div>
          <div style="width:110px;"><div class="prog"><div class="prog-fill" style="width:${tahapTahan[0]?((v/tahapTahan[0][1])*100).toFixed(0):0}%;background:${colors8[i%8]};"></div></div></div>
          <div style="font-size:.82rem;font-weight:700;width:32px;text-align:right;">${v}</div>
          <div style="font-size:.72rem;color:var(--muted);width:36px;">${((v/n)*100).toFixed(1)}%</div>
        </div>`).join("")}
        <div style="margin-top:14px;padding:10px;background:rgba(59,130,246,0.08);border-radius:8px;text-align:center;">
          <div style="font-size:.72rem;color:var(--muted);">Min Skor Resiliens</div>
          <div style="font-family:'Outfit',sans-serif;font-size:1.6rem;font-weight:800;color:#3B82F6;">${avgResilience.toFixed(2)}</div>
          <div style="font-size:.7rem;color:var(--muted);">daripada 4.0</div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-chart-pie text-blue-500 mr-2"></i>Pecahan Tahap Daya Tahan</span></div>
      <div class="card-body"><canvas id="ch-pkpw-resiliens" height="220"></canvas></div>
    </div>
  </div>

  <!-- Profil Responden -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title">Jantina Responden</span></div>
      <div class="card-body"><canvas id="ch-pkpw-jantina" height="180"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Top Kampus</span></div>
      <div class="card-body">
        ${Object.entries(byKampus).sort((a,b)=>b[1]-a[1]).slice(0,8).map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
          <div style="font-size:.7rem;color:var(--muted);width:18px;">${i+1}</div>
          <div style="font-size:.78rem;flex:1;">${k.replace(/IPG Kampus |IPGK|IPG /gi,"").trim()}</div>
          <div style="width:80px;"><div class="prog"><div class="prog-fill" style="width:${((v/n)*100).toFixed(0)}%;background:#3D5490;"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:28px;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Senarai -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-pri-500 mr-2"></i>Senarai Responden PKPW</span>
      <span style="font-size:.72rem;color:var(--muted);">${n} rekod</span>
    </div>
    <div class="card-body" style="padding-bottom:8px;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
        <input type="text" class="fi" style="max-width:190px;font-size:.8rem;" placeholder="Cari nama..." id="pkpw-cari" oninput="filterPKPW()">
        <select class="fi" style="width:auto;font-size:.8rem;" id="pkpw-tahap" onchange="filterPKPW()">
          <option value="">Semua Tahap Kesejahteraan</option>
          <option>TINGGI</option><option>SEDERHANA TINGGI</option><option>SEDERHANA</option><option>SEDERHANA RENDAH</option><option>RENDAH</option>
        </select>
        <select class="fi" style="width:auto;font-size:.8rem;" id="pkpw-tahan" onchange="filterPKPW()">
          <option value="">Semua Daya Tahan</option>
          ${tahapTahan.map(([t])=>`<option>${t}</option>`).join("")}
        </select>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('pkpw-cari').value='';document.getElementById('pkpw-tahap').value='';document.getElementById('pkpw-tahan').value='';filterPKPW()"><i class="fas fa-rotate-left"></i></button>
        <button class="btn btn-out btn-sm" onclick="exportExcelFromTable('pkpw-tbl','PKPW_Data')"><i class="fas fa-download"></i>CSV</button>
      </div>
      <div style="font-size:.72rem;color:var(--muted);" id="pkpw-count">Menunjukkan ${Math.min(n,30)} rekod</div>
    </div>
    <div style="overflow-x:auto;" id="pkpw-tbl-wrap">${renderPKPWTable(data.slice(0,30))}</div>
  </div>`;

  window._pkpwData = data;

  // Attach CSV upload
  setTimeout(()=>{
    const fi = document.getElementById("pkp-upload-input-pkpw");
    if(fi) fi.onchange = function(){
      importCSVPKP(this,"pkpw",null);
      setTimeout(()=>{ SHEETS_CACHE["pkpw"]=null; navTo(SES.pg); },1500);
    };
  },200);

  // Charts
  setTimeout(()=>{
    // Big Five Radar
    _charts.pkpwBigfive = new Chart(document.getElementById("ch-pkpw-bigfive"),{
      type:"radar",
      data:{
        labels:["Extraversion","Agreeableness","Conscientiousness","Neuroticism","Openness"],
        datasets:[{
          label:"Min Skor",
          data:[avgExtra,avgAgree,avgConsc,avgNeuro,avgOpen],
          borderColor:"#3D5490",backgroundColor:"rgba(61,84,144,0.15)",
          pointBackgroundColor:"#3D5490",pointRadius:4
        }]
      },
      options:{responsive:true,scales:{r:{beginAtZero:true,max:100,ticks:{stepSize:20,font:{size:9}},pointLabels:{font:{size:10}}}},plugins:{legend:{display:false}}}
    });

    // Tahap Kesejahteraan donut
    const kLabels = tahapKesej.map(([k])=>k);
    const kVals   = tahapKesej.map(([,v])=>v);
    _charts.pkpwKesej = new Chart(document.getElementById("ch-pkpw-kesej"),{
      type:"doughnut",
      data:{labels:kLabels,datasets:[{data:kVals,backgroundColor:kLabels.map(l=>tahapColors[l]||"#CBD5E1"),borderWidth:0,hoverOffset:6}]},
      options:{responsive:true,cutout:"60%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });

    // Resiliens donut
    const rLabels = tahapTahan.map(([k])=>k||"—");
    const rVals   = tahapTahan.map(([,v])=>v);
    _charts.pkpwResiliens = new Chart(document.getElementById("ch-pkpw-resiliens"),{
      type:"doughnut",
      data:{labels:rLabels,datasets:[{data:rVals,backgroundColor:colors8.slice(0,rLabels.length),borderWidth:0,hoverOffset:6}]},
      options:{responsive:true,cutout:"55%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });

    // Jantina pie
    const jLabels = Object.keys(byJantina);
    const jVals   = Object.values(byJantina);
    _charts.pkpwJantina = new Chart(document.getElementById("ch-pkpw-jantina"),{
      type:"pie",
      data:{labels:jLabels,datasets:[{data:jVals,backgroundColor:["#3B82F6","#E88D3A","#0E7C61"],borderWidth:0}]},
      options:{responsive:true,plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });
  },80);
}

function renderPKPWTable(data){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod.</p>`;
  const tc = t => t==="TINGGI"?"bdg-green":t==="RENDAH"?"bdg-red":t&&t.includes("SEDERHANA")?"bdg-amber":"bdg-gray";
  return `<table class="tbl" id="pkpw-tbl">
    <thead><tr>
      <th>Nama</th><th>Jawatan</th><th>Gred</th><th>Kampus</th>
      <th>Skor Kesej.</th><th>% Kesej.</th><th>Tahap Kesej.</th>
      <th>Resiliens</th><th>Tahap Tahan</th>
      <th>Extra</th><th>Agree</th><th>Consc</th><th>Neuro</th><th>Open</th>
    </tr></thead>
    <tbody>${data.map(d=>`<tr>
      <td style="font-weight:600;font-size:.8rem;">${d.nama}</td>
      <td style="font-size:.72rem;">${d.jawatan||"—"}</td>
      <td><span class="bdg bdg-navy" style="font-size:.65rem;">${d.gred||"—"}</span></td>
      <td style="font-size:.72rem;">${(d.kampus||"").replace(/IPG Kampus |IPGK/gi,"").trim()}</td>
      <td style="font-weight:700;">${d.sKesejahteraan||"—"}</td>
      <td><span class="bdg ${tc(d.tKesejahteraan)}" style="font-size:.65rem;">${d.pKesejahteraan?d.pKesejahteraan+"%":"—"}</span></td>
      <td><span class="bdg ${tc(d.tKesejahteraan)}" style="font-size:.65rem;">${d.tKesejahteraan||"—"}</span></td>
      <td style="font-weight:700;color:#3B82F6;">${d.resilienceMean?d.resilienceMean.toFixed(2):"—"}</td>
      <td><span class="bdg bdg-blue" style="font-size:.65rem;">${d.tahapDayaTahan||"—"}</span></td>
      <td style="font-size:.78rem;">${d.extra||0}</td>
      <td style="font-size:.78rem;">${d.agree||0}</td>
      <td style="font-size:.78rem;">${d.consc||0}</td>
      <td style="font-size:.78rem;">${d.neuro||0}</td>
      <td style="font-size:.78rem;">${d.open||0}</td>
    </tr>`).join("")}
    </tbody></table>`;
}

function filterPKPW(){
  let d = window._pkpwData||[];
  const q=(document.getElementById("pkpw-cari")?.value||"").toLowerCase();
  const tahap=document.getElementById("pkpw-tahap")?.value||"";
  const tahan=document.getElementById("pkpw-tahan")?.value||"";
  if(q)    d=d.filter(x=>x.nama.toLowerCase().includes(q));
  if(tahap)d=d.filter(x=>(x.tKesejahteraan||"").toUpperCase()===tahap.toUpperCase());
  if(tahan)d=d.filter(x=>(x.tahapDayaTahan||"").toUpperCase()===tahan.toUpperCase());
  const shown=d.slice(0,50);
  document.getElementById("pkpw-tbl-wrap").innerHTML=renderPKPWTable(shown);
  document.getElementById("pkpw-count").textContent=`Menunjukkan ${shown.length} daripada ${d.length} rekod`;
}


function renderPKPDashboard(c, data, label, tab, kampusFilter){
  const st = pkpStat(data);
  const colors8 = ["#0E7C61","#E88D3A","#3B82F6","#8B5CF6","#EF4444","#14B8A6","#F59E0B","#6366F1"];
  const tahapColors = {"TINGGI":"#0E7C61","SEDERHANA TINGGI":"#34D399","SEDERHANA":"#FBBF24","SEDERHANA RENDAH":"#F97316","RENDAH":"#EF4444"};
  const domains = [
    {k:"avgEmosi",l:"Emosi",c:"#0E7C61"},{k:"avgKendiri",l:"Kendiri",c:"#E88D3A"},
    {k:"avgFizikal",l:"Fizikal",c:"#3B82F6"},{k:"avgPerhub",l:"Perhubungan",c:"#8B5CF6"},
    {k:"avgIntelek",l:"Intelektual",c:"#EF4444"},{k:"avgSpiritual",l:"Spiritual",c:"#14B8A6"},
    {k:"avgIdentiti",l:"Identiti",c:"#F59E0B"},{k:"avgKewangan",l:"Kewangan",c:"#6366F1"}
  ];

  c.innerHTML=`
  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,${tab==="pkpp"?"#084A39,#0E7C61":"#1F2C50,#3D5490"});border-radius:12px;padding:20px 24px;margin-bottom:18px;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-20px;top:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    <div style="position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="display:flex;gap:8px;margin-bottom:6px;">
          <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-size:.7rem;padding:3px 10px;border-radius:20px;font-weight:600;"><i class="fas fa-heart-pulse mr-1"></i>${tab.toUpperCase()}</span>
          <span style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);font-size:.7rem;padding:3px 10px;border-radius:20px;">Google Sheets Live</span>
        </div>
        <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;color:#fff;margin-bottom:3px;">${label}</div>
        <div style="font-size:.78rem;color:rgba(255,255,255,0.5);">${st.n} responden · Min skor kesejahteraan: ${st.avgKesejahteraan.toFixed(1)} · ${st.avgPeratus.toFixed(1)}%</div>
      </div>
      <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
        ${isAdmin() ? `
          <label id="pkp-upload-label-${tab}" style="background:rgba(255,255,255,0.18);color:#fff;padding:5px 12px;border-radius:7px;cursor:pointer;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;">
            <i class="fas fa-upload"></i> Kemaskini CSV
            <input type="file" accept=".csv" id="pkp-upload-input-${tab}" style="display:none">
          </label>
          <button onclick="padamDataPKP('${tab}')" style="background:rgba(220,38,38,0.3);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;">
            <i class="fas fa-trash mr-1"></i>Padam Data
          </button>
        ` : `
          <button onclick="exportExcelFromTable('pkp-tbl-inner','${tab.toUpperCase()}_'+SES.kampus)" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-excel mr-1"></i>CSV</button>
          <button onclick="exportPagePDF()" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-pdf mr-1"></i>PDF</button>
        `}
        <button onclick="SHEETS_CACHE['${tab}']=null;if(typeof idbDelete==='function')idbDelete('csv_${tab}').then(()=>navTo(SES.pg));else navTo(SES.pg);" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:6px 14px;border-radius:8px;font-size:12px;cursor:pointer;"><i class="fas fa-rotate-right mr-1"></i>Refresh</button>
      </div>
    </div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Responden",v:st.n,i:"fa-users",bg:"bg-pri-50",fg:"text-pri-600",c:"sc-pri"},
      {l:"Min Skor Kesejahteraan",v:st.avgKesejahteraan.toFixed(1),i:"fa-heart-pulse",bg:"bg-amb-50",fg:"text-amb-600",c:"sc-amber",sub:"daripada 500"},
      {l:"Min Peratus Kesejahteraan",v:st.avgPeratus.toFixed(1)+"%",i:"fa-percent",bg:"bg-green-50",fg:"text-green-600",c:"sc-pri"},
      {l:tab==="pkpw"?"Tahap Kesejahteraan Tertinggi":"Tahap Tertinggi",v:Object.entries(st.tahapCount).sort((a,b)=>b[1]-a[1])[0]?.[0]||"—",i:"fa-trophy",bg:"bg-navy-50",fg:"text-navy-600",c:"sc-navy"}
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--navy);line-height:1.1;">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
    </div>`).join("")}
  </div>

  <!-- Row 1: Tahap Kesejahteraan + Big Five -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-chart-pie text-pri-500 mr-2"></i>Tahap Kesejahteraan Keseluruhan</span></div>
      <div class="card-body"><canvas id="ch-tkesej" height="220"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-star text-amb-500 mr-2"></i>Profil Personaliti Big Five</span></div>
      <div class="card-body"><canvas id="ch-bigfive" height="220"></canvas></div>
    </div>
  </div>

  <!-- Row 2: 8 Domain Skor -->
  <div class="card" style="margin-bottom:14px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-layer-group text-pri-500 mr-2"></i>Skor Min 8 Domain Kesejahteraan</span></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px;">
        ${domains.map(d=>`
        <div style="background:rgba(0,0,0,0.02);border-radius:8px;padding:12px;border-left:3px solid ${d.c};">
          <div style="font-size:.72rem;color:var(--muted);margin-bottom:2px;">${d.l}</div>
          <div style="font-family:'Outfit',sans-serif;font-size:1.3rem;font-weight:800;color:${d.c};">${st[d.k].toFixed(1)}</div>
          <div class="prog" style="margin-top:5px;"><div class="prog-fill" style="width:${Math.min(st[d.k]/70*100,100).toFixed(0)}%;background:${d.c};"></div></div>
        </div>`).join("")}
      </div>
      <canvas id="ch-domain" height="160"></canvas>
    </div>
  </div>

  <!-- Row 3: Profil Responden -->
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title">Jantina</span></div>
      <div class="card-body"><canvas id="ch-jantina" height="180"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Bangsa</span></div>
      <div class="card-body"><canvas id="ch-bangsa" height="180"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Pendapatan Isi Rumah</span></div>
      <div class="card-body"><canvas id="ch-pendapatan" height="180"></canvas></div>
    </div>
  </div>

  <!-- Row 4: Kampus + Semester -->
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title">Top Kampus Responden</span></div>
      <div class="card-body">
        ${st.kampusCount.map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <div style="font-size:.7rem;color:var(--muted);width:20px;text-align:right;">${i+1}</div>
          <div style="font-size:.78rem;flex:1;font-weight:500;">${k.replace(/IPG Kampus |IPGK|IPG /gi,"").trim()}</div>
          <div style="width:100px;"><div class="prog"><div class="prog-fill" style="width:${st.kampusCount[0]?((v/st.kampusCount[0][1])*100).toFixed(0):0}%;background:${colors8[i%8]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:30px;text-align:right;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">${tab==="pkpw"?"Jawatan / Gred":"Semester"}</span></div>
      <div class="card-body"><canvas id="ch-semester" height="220"></canvas></div>
    </div>
  </div>

  <!-- Senarai -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-pri-500 mr-2"></i>Senarai Responden</span>
      <span style="font-size:.72rem;color:var(--muted);">${data.length} rekod</span>
    </div>
    <div class="card-body" style="padding-bottom:8px;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
        <input type="text" class="fi" style="max-width:190px;font-size:.8rem;" placeholder="Cari nama..." id="pkp-cari" oninput="filterPKP('${tab}')">
        <select class="fi" style="width:auto;font-size:.8rem;" id="pkp-tahap" onchange="filterPKP('${tab}')">
          <option value="">Semua Tahap</option>
          <option>TINGGI</option><option>SEDERHANA TINGGI</option><option>SEDERHANA</option><option>SEDERHANA RENDAH</option><option>RENDAH</option>
        </select>
        <select class="fi" style="width:auto;font-size:.8rem;" id="pkp-jantina" onchange="filterPKP('${tab}')">
          <option value="">Semua Jantina</option><option value="L">Lelaki</option><option value="P">Perempuan</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="resetPKPFilter('${tab}')"><i class="fas fa-rotate-left"></i></button>
      </div>
      <div style="font-size:.72rem;color:var(--muted);" id="pkp-count">Menunjukkan ${Math.min(data.length,30)} rekod</div>
    </div>
    <div style="overflow-x:auto;" id="pkp-table">${renderPKPTable(data.slice(0,30))}</div>
  </div>`;

  window[`_pkp_${tab}`] = data;
  window._pkpTab = tab;
  // Attach file input after DOM renders
  setTimeout(()=>{
    const fi = document.getElementById("pkp-upload-input-"+tab);
    if(fi) fi.onchange = function(){
      importCSVPKP(this, tab, null);
      setTimeout(()=>{ SHEETS_CACHE[tab]=null; navTo(SES.pg); }, 1500);
    };
  }, 200);

  setTimeout(()=>{
    // Tahap Kesejahteraan donut
    const tLabels=Object.keys(st.tahapCount).filter(k=>st.tahapCount[k]>0);
    const tVals=tLabels.map(k=>st.tahapCount[k]);
    _charts.tkesej=new Chart(document.getElementById("ch-tkesej"),{
      type:"doughnut",
      data:{labels:tLabels,datasets:[{data:tVals,backgroundColor:tLabels.map(l=>tahapColors[l]||"#CBD5E1"),borderWidth:0,hoverOffset:6}]},
      options:{responsive:true,cutout:"60%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });
    // Big Five radar
    _charts.bigfive=new Chart(document.getElementById("ch-bigfive"),{
      type:"radar",
      data:{labels:["Extraversion","Agreeableness","Conscientiousness","Neuroticism","Openness"],
        datasets:[{label:"Min Skor",data:[st.avgExtra,st.avgAgree,st.avgConsc,st.avgNeuro,st.avgOpen],
          borderColor:tab==="pkpp"?"#0E7C61":"#3D5490",backgroundColor:tab==="pkpp"?"rgba(14,124,97,0.15)":"rgba(61,84,144,0.15)",
          pointBackgroundColor:tab==="pkpp"?"#0E7C61":"#3D5490",pointRadius:4}]},
      options:{responsive:true,scales:{r:{beginAtZero:true,max:100,ticks:{stepSize:20,font:{size:9}},pointLabels:{font:{size:10}}}},plugins:{legend:{display:false}}}
    });
    // Domain bar
    _charts.domain=new Chart(document.getElementById("ch-domain"),{
      type:"bar",
      data:{labels:domains.map(d=>d.l),datasets:[{data:domains.map(d=>st[d.k].toFixed(1)),backgroundColor:domains.map(d=>d.c),borderRadius:4}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,max:70}}}
    });
    // Jantina
    _charts.jantina=new Chart(document.getElementById("ch-jantina"),{
      type:"pie",
      data:{labels:["Lelaki","Perempuan"],datasets:[{data:[st.L,st.P],backgroundColor:["#3B82F6","#E88D3A"],borderWidth:0}]},
      options:{responsive:true,plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}
    });
    // Bangsa
    _charts.bangsa=new Chart(document.getElementById("ch-bangsa"),{
      type:"doughnut",
      data:{labels:st.bangsa.map(([k])=>k),datasets:[{data:st.bangsa.map(([,v])=>v),backgroundColor:colors8,borderWidth:0}]},
      options:{responsive:true,cutout:"50%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:10}}}}}
    });
    // Pendapatan
    _charts.pend=new Chart(document.getElementById("ch-pendapatan"),{
      type:"bar",
      data:{labels:st.pendCount.map(([k])=>k.replace(/RM|,/g,"").trim().slice(0,15)),datasets:[{data:st.pendCount.map(([,v])=>v),backgroundColor:"rgba(14,124,97,0.75)",borderRadius:4}]},
      options:{responsive:true,indexAxis:"y",plugins:{legend:{display:false}},scales:{x:{beginAtZero:true}}}
    });
    // Semester
    _charts.sem=new Chart(document.getElementById("ch-semester"),{
      type:"bar",
      data:{labels:st.semCount.map(([k])=>k.replace("Semester","Sem")),datasets:[{data:st.semCount.map(([,v])=>v),backgroundColor:"rgba(61,84,144,0.75)",borderRadius:4}]},
      options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}
    });
  },80);
}

function renderPKPTable(data, tab){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod.</p>`;
  const isPKPW = tab === "pkpw";
  const tahapColor = t => t==="TINGGI"?"bdg-green":t==="RENDAH"?"bdg-red":t.includes("SEDERHANA")?"bdg-amber":"bdg-gray";
  const jL = d => d.jantina==="Lelaki"||d.jantina==="LELAKI"||d.jantina==="L";
  const col3Label = isPKPW ? "Jawatan / Kategori" : "Program";
  const col4Label = isPKPW ? "Bidang" : "Semester";
  return `<table class="tbl" id="pkp-tbl-inner">
    <thead><tr>
      <th>Nama</th><th>Kampus</th>
      <th>${col3Label}</th><th>${col4Label}</th>
      <th>Skor Kesej.</th><th>% Kesej.</th><th>Tahap Kesejahteraan</th>
      <th>Emosi</th><th>Fizikal</th><th>Kewangan</th>
    </tr></thead>
    <tbody>${data.map((d,i)=>`<tr>
      <td><div style="display:flex;align-items:center;gap:6px;">
        <div class="ava" style="background:${jL(d)?"#C5CDE0":"#FAE0BF"};color:${jL(d)?"#1F2C50":"#9A5A1E"};font-size:.6rem;">${jL(d)?"L":"P"}</div>
        <span style="font-size:.79rem;font-weight:500;">${d.nama}</span>
      </div></td>
      <td style="font-size:.72rem;">${d.kampus.replace(/IPG Kampus |IPGK/gi,"").trim()}</td>
      <td style="font-size:.72rem;">${isPKPW ? (d.jawatan||d.program||"—") : d.program}</td>
      <td style="font-size:.72rem;">${isPKPW ? (d.gred||"—") : d.semester}</td>
      <td style="font-size:.82rem;font-weight:700;">${d.sKesejahteraan}</td>
      <td><span class="bdg ${tahapColor(d.tKesejahteraan||"")}" style="font-size:.65rem;">${d.pKesejahteraan}%</span></td>
      <td><span class="bdg ${tahapColor(d.tKesejahteraan||"")}" style="font-size:.65rem;">${d.tKesejahteraan||"—"}</span></td>
      <td style="font-size:.78rem;">${d.sEmosi}</td>
      <td style="font-size:.78rem;">${d.sFizikal}</td>
      <td style="font-size:.78rem;">${d.sKewangan}</td>
    </tr>`).join("")}
    </tbody></table>`;
}

function importCSVPKP(input, tab, kampusFilter){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      // Handle BOM + normalize line endings
      let text = e.target.result.replace(/\uFEFF/g,"").replace(/\r/g,"");
      const lines = text.split("\n").filter(l=>l.trim());
      if(lines.length < 2){ toast("Fail CSV kosong","err"); return; }

      // Detect separator
      const tabCols = lines[0].split("\t").length;
      const commaCols = lines[0].split(",").length;
      const sep = tabCols >= commaCols ? "\t" : ",";

      // Parse CSV line with quote handling
      const parseCSVLine = (line) => {
        const result = []; let cur = ""; let inQ = false;
        for(let i=0;i<line.length;i++){
          const ch=line[i];
          if(ch==='"'){ inQ=!inQ; }
          else if(!inQ && line.slice(i,i+sep.length)===sep){ result.push(cur.trim()); cur=""; i+=sep.length-1; }
          else { cur+=ch; }
        }
        result.push(cur.trim());
        return result;
      };

      // Build header index map with multiple variants
      const rawHeaders = parseCSVLine(lines[0]);
      const hi = {};
      rawHeaders.forEach((h,i)=>{
        const norm = h.replace(/\n/g," ").trim();
        hi[norm] = i;
        hi[norm.toUpperCase()] = i;
        hi[norm.toLowerCase()] = i;
      });

      const parsed = lines.slice(1).filter(l=>l.trim()).map(line=>{
        const row = parseCSVLine(line);
        return parsePKPRow(row, hi);
      }).filter(d => d.nama && d.nama.length > 1);

      if(parsed.length === 0){
        toast("0 rekod ditemui — semak format CSV", "err");
        return;
      }

      SHEETS_CACHE[tab] = parsed;
      window["_pkp_"+tab] = parsed;

      try {
        if(typeof idbSave === "function"){
          idbSave("csv_"+tab, parsed).then(ok => {
            if(ok) localStorage.setItem("csv_"+tab+"_date", new Date().toLocaleString("ms-MY"));
          });
        }
      } catch(saveErr){ console.warn("Save error:", saveErr); }
      localStorage.setItem("csv_"+tab+"_date", new Date().toLocaleString("ms-MY"));
      toast(parsed.length.toLocaleString("ms-MY") + " rekod " + tab.toUpperCase() + " berjaya diimport","ok");
      loadAndRenderPKP(document.getElementById("pg-body"), tab, kampusFilter||null);
    } catch(err){ toast("Gagal baca CSV: "+err.message,"err"); }
  };
  reader.readAsText(file, "UTF-8");
}


function filterPKP(tab){
  let d = window[`_pkp_${tab}`]||[];
  const q=(document.getElementById("pkp-cari")?.value||"").toLowerCase();
  const tahap=document.getElementById("pkp-tahap")?.value||"";
  const jan=document.getElementById("pkp-jantina")?.value||"";
  if(q) d=d.filter(x=>x.nama.toLowerCase().includes(q));
  if(tahap) d=d.filter(x=>x.tKesejahteraan===tahap);
  if(jan) d=d.filter(x=>{const j=x.jantina.toUpperCase();return jan==="L"?(j==="LELAKI"||j==="L"):(j==="PEREMPUAN"||j==="P");});
  document.getElementById("pkp-table").innerHTML=renderPKPTable(d.slice(0,50),window._pkpTab||"pkpp");
  document.getElementById("pkp-count").textContent=`Menunjukkan ${Math.min(d.length,50)} daripada ${d.length} rekod`;
}
function resetPKPFilter(tab){
  ["pkp-cari","pkp-tahap","pkp-jantina"].forEach(id=>{const el=document.getElementById(id);if(el)el.value="";});
  filterPKP(tab);
}

// ══════════════════════════════════════════
// RENDER MINDA SIHAT
// ══════════════════════════════════════════
function pgAKMinda(c){ loadAndRenderMinda(c, SES.kampus); }
function pgAUMinda(c){ loadAndRenderMinda(c, null); }

async function loadAndRenderMinda(c, kampusFilter){
  c.innerHTML=`<div style="padding:40px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:14px;display:block;color:var(--pri);"></i><div style="font-size:14px;font-weight:500;">Memuatkan data Minda Sihat...</div></div>`;
  try {
    const parsedMinda = await loadTabData("minda", parseMindaRow, SHEETS_CACHE, "minda");
    SHEETS_CACHE.minda = parsedMinda;
    let data = SHEETS_CACHE.minda;
    if(kampusFilter) data = data.filter(d=>d.kampus.includes(kObj(kampusFilter).nama?.replace("IPG Kampus ","")||kampusFilter));
    renderMindaDashboard(c, data, kampusFilter);
  } catch(err){
    c.innerHTML = '<div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:20px;max-width:560px;margin:20px auto;">'
      + '<div style="font-size:15px;font-weight:700;color:#92400e;margin-bottom:6px;"><i class="fas fa-triangle-exclamation" style="margin-right:6px;"></i>Gagal sambung ke Google Sheets</div>'
      + '<div style="font-size:12px;color:#92400e;margin-bottom:16px;">' + err.message + '<br>Muat naik CSV dari tab <b>Minda Sihat</b> untuk papar data.</div>'
      + '<div style="display:flex;flex-direction:column;gap:10px;">'
      + '<label style="background:#5a2d82;color:#fff;padding:8px 16px;border-radius:7px;cursor:pointer;font-size:13px;font-weight:600;display:inline-flex;align-items:center;gap:8px;width:fit-content;">'
      + '<i class="fas fa-file-csv" style="margin-right:4px;"></i> Muat Naik CSV Minda Sihat'
      + '<input type="file" accept=".csv" id="minda-file-input-err" style="display:none">'
      + '</label>'
      + '<div style="font-size:11px;color:#92400e;"><b>Cara eksport CSV:</b> File → Download → Comma Separated Values (.csv) dalam tab <b>Minda Sihat</b></div>'
      + '</div></div>';
    setTimeout(function(){
      var fi = document.getElementById("minda-file-input-err");
      if(fi) fi.onchange = function(){ importCSVMinda(this, kampusFilter||null); };
    }, 100);
  }
}

function renderMindaDashboard(c, data, kampusFilter){
  const st = mindaStat(data);
  const dassColors = {NORMAL:"#0E7C61",RINGAN:"#FBBF24",SEDERHANA:"#F97316",TERUK:"#EF4444","SANGAT TERUK":"#7F1D1D"};
  const dassLabel = {NORMAL:"Normal",RINGAN:"Ringan",SEDERHANA:"Sederhana",TERUK:"Teruk","SANGAT TERUK":"Sangat Teruk"};

  c.innerHTML=`
  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,#1F2C50,#5a2d82);border-radius:12px;padding:20px 24px;margin-bottom:18px;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-20px;top:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    <div style="position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div>
        <div style="display:flex;gap:8px;margin-bottom:6px;">
          <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-size:.7rem;padding:3px 10px;border-radius:20px;font-weight:600;"><i class="fas fa-brain mr-1"></i>MINDA SIHAT</span>
          <span style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);font-size:.7rem;padding:3px 10px;border-radius:20px;">Saringan DASS-21</span>
        </div>
        <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;color:#fff;margin-bottom:3px;">Saringan Minda Sihat — ${kampusFilter?kObj(kampusFilter).nama:"Semua Kampus"}</div>
        <div style="font-size:.78rem;color:rgba(255,255,255,0.5);">${st.n} responden · Min D: ${st.avgD} · Min A: ${st.avgA} · Min S: ${st.avgS}</div>
      </div>
      <div style="display:flex;gap:6px;align-items:center;">
        ${!isAdmin()?`<button onclick="exportExcelFromTable('minda-tbl-inner','MindaSihat_'+SES.kampus)" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-excel mr-1"></i>CSV</button>
        <button onclick="exportPagePDF()" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:5px 12px;border-radius:7px;font-size:11px;cursor:pointer;"><i class="fas fa-file-pdf mr-1"></i>PDF</button>`:""}
        <button onclick="SHEETS_CACHE.minda=null;navTo(SES.pg)" style="background:rgba(255,255,255,0.15);color:#fff;border:none;padding:6px 14px;border-radius:8px;font-size:12px;cursor:pointer;"><i class="fas fa-rotate-right mr-1"></i>Refresh</button>
      </div>
    </div>
  </div>

  <!-- KPI DASS -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Responden",v:st.n,i:"fa-users",bg:"bg-navy-50",fg:"text-navy-600",c:"sc-navy"},
      {l:"Min Skor Kemurungan (D)",v:st.avgD,i:"fa-face-sad-tear",bg:"bg-red-50",fg:"text-red-600",c:"sc-red",sub:"DASS-21"},
      {l:"Min Skor Kebimbangan (A)",v:st.avgA,i:"fa-face-anxious-sweat",bg:"bg-amb-50",fg:"text-amb-600",c:"sc-amber",sub:"DASS-21"},
      {l:"Min Skor Stres (S)",v:st.avgS,i:"fa-head-side-brain",bg:"bg-pri-50",fg:"text-pri-600",c:"sc-pri",sub:"DASS-21"}
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.4rem;font-weight:800;color:var(--navy);line-height:1.1;">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
    </div>`).join("")}
  </div>

  <!-- Row 1: D, A, S charts -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:14px;">
    ${["D","A","S"].map((x,i)=>{
      const keys = {D:"ctD",A:"ctA",S:"ctS"};
      const labels_ms = {D:"Kemurungan",A:"Kebimbangan",S:"Stres"};
      const ct = st[keys[x]];
      const labels = Object.keys(ct).filter(k=>ct[k]>0);
      const vals = labels.map(k=>ct[k]);
      return `<div class="card">
        <div class="card-head"><span class="card-title">${labels_ms[x]} (${x})</span><span class="bdg bdg-gray" style="font-size:.65rem;">Min: ${st["avg"+x]}</span></div>
        <div class="card-body"><canvas id="ch-dass${x}" height="200"></canvas></div>
      </div>`;
    }).join("")}
  </div>

  <!-- Row 2: Tahap DT + Jantina + Kampus -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-gauge text-purple-500 mr-2"></i>Tahap Daya Tindak (DT)</span></div>
      <div class="card-body">
        ${st.ctDT.map(([t,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:9px;">
          <div style="font-size:.78rem;flex:1;font-weight:500;">${t}</div>
          <div style="width:120px;"><div class="prog"><div class="prog-fill" style="width:${st.ctDT[0]?((v/st.ctDT[0][1])*100).toFixed(0):0}%;background:${"#0E7C61,#3B82F6,#FBBF24,#EF4444".split(",")[i%4]};"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:30px;text-align:right;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Top Kampus Responden</span></div>
      <div class="card-body">
        ${st.kampusCount.map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
          <div style="font-size:.7rem;color:var(--muted);width:18px;">${i+1}</div>
          <div style="font-size:.78rem;flex:1;font-weight:500;">${k.replace(/IPGMK |IPGK |IPG Kampus /gi,"").trim()}</div>
          <div style="width:80px;"><div class="prog"><div class="prog-fill" style="width:${st.kampusCount[0]?((v/st.kampusCount[0][1])*100).toFixed(0):0}%;background:#5a2d82;"></div></div></div>
          <div style="font-size:.78rem;font-weight:700;width:28px;text-align:right;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <!-- Senarai -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-purple-500 mr-2"></i>Senarai Responden</span>
      <span style="font-size:.72rem;color:var(--muted);">${data.length} rekod</span>
    </div>
    <div class="card-body" style="padding-bottom:8px;">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
        <input type="text" class="fi" style="max-width:190px;font-size:.8rem;" placeholder="Cari nama..." id="minda-cari" oninput="filterMinda()">
        <select class="fi" style="width:auto;font-size:.8rem;" id="minda-tahapD" onchange="filterMinda()">
          <option value="">Semua Tahap D</option><option>NORMAL</option><option>RINGAN</option><option>SEDERHANA</option><option>TERUK</option><option>SANGAT TERUK</option>
        </select>
        <button class="btn btn-ghost btn-sm" onclick="document.getElementById('minda-cari').value='';document.getElementById('minda-tahapD').value='';filterMinda()"><i class="fas fa-rotate-left"></i></button>
      </div>
      <div style="font-size:.72rem;color:var(--muted);" id="minda-count">Menunjukkan ${Math.min(data.length,30)} rekod</div>
    </div>
    <div style="overflow-x:auto;" id="minda-table">${renderMindaTable(data.slice(0,30))}</div>
  </div>`;

  window._mindaData = data;

  setTimeout(()=>{
    ["D","A","S"].forEach(x=>{
      const keys={D:"ctD",A:"ctA",S:"ctS"};
      const ct=st[keys[x]];
      const labels=Object.keys(ct).filter(k=>ct[k]>0);
      const vals=labels.map(k=>ct[k]);
      _charts["dass"+x]=new Chart(document.getElementById("ch-dass"+x),{
        type:"pie",
        data:{labels:labels.map(l=>dassLabel[l]||l),datasets:[{data:vals,backgroundColor:labels.map(l=>dassColors[l]||"#CBD5E1"),borderWidth:0}]},
        options:{responsive:true,plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:10}}}}}
      });
    });
  },80);
}

function renderMindaTable(data){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod.</p>`;
  const tc = t=>t==="NORMAL"?"bdg-green":t==="RINGAN"?"bdg-amber":t==="SEDERHANA"?"bdg-amber":"bdg-red";
  return `<table class="tbl"><thead><tr>
    <th>Nama</th><th>Kampus</th><th>Program</th><th>Jantina</th>
    <th>D</th><th>Tahap D</th><th>A</th><th>Tahap A</th><th>S</th><th>Tahap S</th><th>DT</th><th>Tahap DT</th>
  </tr></thead><tbody>
  ${data.map((d,i)=>`<tr>
    <td style="font-size:.79rem;font-weight:500;">${d.nama}</td>
    <td style="font-size:.7rem;">${d.kampus.replace(/IPGMK |IPGK |IPG Kampus /gi,"").trim()}</td>
    <td style="font-size:.7rem;">${(d.program||"").split(".").pop().trim()}</td>
    <td><span class="bdg ${d.jantina.toUpperCase()==="PEREMPUAN"||d.jantina==="P"?"bdg-amber":"bdg-blue"}" style="font-size:.65rem;">${d.jantina}</span></td>
    <td style="font-size:.82rem;font-weight:700;">${d.kemurungan}</td>
    <td><span class="bdg ${tc(d.tahapD)}" style="font-size:.65rem;">${d.tahapD}</span></td>
    <td style="font-size:.82rem;font-weight:700;">${d.kebimbangan}</td>
    <td><span class="bdg ${tc(d.tahapA)}" style="font-size:.65rem;">${d.tahapA}</span></td>
    <td style="font-size:.82rem;font-weight:700;">${d.stres}</td>
    <td><span class="bdg ${tc(d.tahapS)}" style="font-size:.65rem;">${d.tahapS}</span></td>
    <td style="font-size:.82rem;">${d.dt}</td>
    <td><span class="bdg bdg-gray" style="font-size:.65rem;">${d.tahapDT}</span></td>
  </tr>`).join("")}</tbody></table>`;
}

function importCSVMinda(input, kampusFilter){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      let text = e.target.result.replace(/\uFEFF/g,"").replace(/\r/g,"");
      const lines = text.split("\n").filter(l=>l.trim());
      if(lines.length < 2){ toast("Fail CSV kosong","err"); return; }

      const tabCols = lines[0].split("\t").length;
      const commaCols = lines[0].split(",").length;
      const sep = tabCols >= commaCols ? "\t" : ",";

      const parseCSVLine = (line) => {
        const result=[]; let cur=""; let inQ=false;
        for(let i=0;i<line.length;i++){
          const ch=line[i];
          if(ch==='"'){ inQ=!inQ; }
          else if(!inQ && line.slice(i,i+sep.length)===sep){ result.push(cur.trim()); cur=""; i+=sep.length-1; }
          else { cur+=ch; }
        }
        result.push(cur.trim());
        return result;
      };

      const rawHeaders = parseCSVLine(lines[0]);
      const hi = {};
      rawHeaders.forEach((h,i)=>{
        const norm = h.replace(/\n/g," ").trim();
        hi[norm] = i;
        hi[norm.toUpperCase()] = i;
        hi[norm.toLowerCase()] = i;
      });

      const parsed = lines.slice(1).filter(l=>l.trim()).map(line=>{
        const row = parseCSVLine(line);
        return parseMindaRow(row, hi);
      }).filter(d=>d.nama && d.nama.length > 1);

      if(parsed.length === 0){ toast("0 rekod ditemui — semak format CSV","err"); return; }

      SHEETS_CACHE.minda = parsed;
      try {
        if(typeof idbSave==="function") idbSave("csv_minda", parsed).then(ok=>{
          if(ok) localStorage.setItem("csv_minda_date", new Date().toLocaleString("ms-MY"));
        });
      } catch(e){}
      localStorage.setItem("csv_minda_date", new Date().toLocaleString("ms-MY"));
      toast(parsed.length.toLocaleString("ms-MY")+" rekod Minda Sihat berjaya diimport","ok");
      loadAndRenderMinda(document.getElementById("pg-body"), kampusFilter||null);
    } catch(err){ toast("Gagal baca CSV: "+err.message,"err"); }
  };
  reader.readAsText(file, "UTF-8");
}


function filterMinda(){
  let d=window._mindaData||[];
  const q=(document.getElementById("minda-cari")?.value||"").toLowerCase();
  const tahapD=document.getElementById("minda-tahapD")?.value||"";
  if(q) d=d.filter(x=>x.nama.toLowerCase().includes(q));
  if(tahapD) d=d.filter(x=>x.tahapD.toUpperCase()===tahapD);
  document.getElementById("minda-table").innerHTML=renderMindaTable(d.slice(0,50));
  document.getElementById("minda-count").textContent=`Menunjukkan ${Math.min(d.length,50)} daripada ${d.length} rekod`;
}

