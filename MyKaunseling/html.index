// ENROLMEN KAUNSELOR (Data CSV sebenar)
// ══════════════════════════════════════════
function pgAKKaunselor(c){ loadAndRenderKaunselor(c, SES.kampus); }
function pgAUKaunselor(c){ loadAndRenderKaunselor(c, null); }

async function loadAndRenderKaunselor(c, kampusFilter){
  c.innerHTML = `<div style="padding:40px;text-align:center;color:var(--muted);">
    <i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:14px;display:block;color:var(--pri);"></i>
    <div style="font-size:14px;font-weight:500;">Memuatkan data kaunselor...</div>
  </div>`;

  const parsed = await loadTabData("kaunselor", parseKaunselorRow, KAUNS_CACHE, "kaunselor");
  KAUNS_CACHE.kaunselor = parsed;

  let data = parsed || [];
  if(kampusFilter){
    const kNm = (kObj(kampusFilter).nama||"").replace("IPG Kampus ","").toLowerCase();
    data = data.filter(d =>
      (d.organisasi||"").toLowerCase().includes(kNm) ||
      (d.institusi||"").toLowerCase().includes(kNm) ||
      (d.zon||"").toLowerCase().includes(kampusFilter.toLowerCase())
    );
  }

  renderKaunselorPage(c, data, kampusFilter);
}

function renderKaunselorPage(c, enriched, kampusFilter){
  // Separate KOSONG from actual staff
  const isKosong = u => !u.nama || u.nama.toUpperCase()==="KOSONG" || u.nama.trim()==="-" || u.nama.trim()==="";
  const staff  = enriched.filter(u => !isKosong(u));
  const kosong = enriched.filter(u =>  isKosong(u));

  // Stats
  // Kira HANYA kaunselor aktif (bukan KOSONG)
  const byZon = {};
  staff.forEach(u => { const z=u.zon||"—"; byZon[z] = (byZon[z]||0)+1; });
  const byKampus = {};
  staff.forEach(u => { const k=u.organisasi||"—"; byKampus[k] = (byKampus[k]||0)+1; });

  // Vacancy analysis by kampus
  const kampusMap = {};
  enriched.forEach(u => {
    const k = u.organisasi||"—";
    if(!kampusMap[k]) kampusMap[k] = {zon:u.zon||"—",negeri:u.negeri||"—",staff:[],kosong:[]};
    if(isKosong(u)) kampusMap[k].kosong.push(u.jawatan||"—");
    else kampusMap[k].staff.push(u);
  });
  const kampusKosong = Object.entries(kampusMap).filter(([,v])=>v.kosong.length>0).sort((a,b)=>b[1].kosong.length-a[1].kosong.length);
  const kampusPenuh  = Object.entries(kampusMap).filter(([,v])=>v.kosong.length===0);

  const L = staff.filter(u=>(u.jantina||"").toUpperCase()==="LELAKI").length;
  const P = staff.filter(u=>(u.jantina||"").toUpperCase()==="PEREMPUAN").length;
  const date = localStorage.getItem("csv_kaunselor_date")||"";

  const isSheets = date && date.includes("★Sheets");
  const totalKampus = Object.keys(kampusMap).length;

  c.innerHTML = `
  <!-- Notice bar -->
  <div style="background:${enriched.length?(isSheets?"rgba(59,130,246,0.07)":"rgba(14,124,97,0.07)"):"#fffbeb"};border:1px solid ${enriched.length?(isSheets?"rgba(59,130,246,0.2)":"rgba(14,124,97,0.2)"):"#fde68a"};border-radius:8px;padding:10px 14px;margin-bottom:14px;display:flex;align-items:center;flex-wrap:wrap;gap:8px;">
    <i class="fas ${enriched.length?(isSheets?"fa-table":"fa-circle-check"):"fa-triangle-exclamation"}" style="color:${enriched.length?(isSheets?"#3B82F6":"#0E7C61"):"#D97706"};"></i>
    <span style="font-size:12px;font-weight:600;color:${enriched.length?(isSheets?"#1D4ED8":"#0B634D"):"#92400e"};">
      ${staff.length} kaunselor aktif · ${kosong.length} jawatan kosong${isSheets?" · Google Sheets":""}
    </span>
    ${date?`<span style="font-size:11px;color:#64748B;"><i class="fas fa-clock mr-1"></i>${date.replace(" ★Sheets","")}</span>`:""}
    <div style="margin-left:auto;display:flex;gap:6px;">
      <label style="background:#0E7C61;color:#fff;padding:4px 12px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;">
        <i class="fas fa-upload"></i>Kemaskini CSV
        <input type="file" accept=".csv" style="display:none" id="kaun-csv-inp">
      </label>
      <button onclick="exportExcelFromTable('tbl-kaunselor-main','Kaunselor_IPGKPM')" class="btn btn-out btn-sm" style="font-size:11px;"><i class="fas fa-download"></i>CSV</button>
      <button onclick="exportPagePDF()" class="btn btn-ghost btn-sm" style="font-size:11px;"><i class="fas fa-file-pdf" style="color:#DC2626;"></i></button>
    </div>
  </div>

  <!-- Banner -->
  <div class="afu" style="background:linear-gradient(135deg,#132238,#1F2C50);border-radius:12px;padding:18px 24px;margin-bottom:18px;color:#fff;">
    <div style="font-size:.7rem;color:rgba(255,255,255,0.5);margin-bottom:4px;"><i class="fas fa-user-tie mr-2"></i>ENROLMEN KAUNSELOR</div>
    <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">${kampusFilter ? kNama(kampusFilter) : "Semua Kampus IPG Malaysia"}</div>
    <div style="font-size:.78rem;color:rgba(255,255,255,0.5);margin-top:3px;">${staff.length} aktif · ${kosong.length} kosong · ${L} L / ${P} P</div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    <div class="stat-card sc-pri afu d1">
      <div class="stat-icon bg-pri-50"><i class="fas fa-user-tie text-pri-600"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:var(--navy);">${staff.length}</div>
      <div class="stat-lbl">Kaunselor Aktif</div>
    </div>
    <div class="stat-card sc-amber afu d2">
      <div class="stat-icon bg-amb-50"><i class="fas fa-building text-amb-600"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:var(--navy);">${totalKampus}</div>
      <div class="stat-lbl">Jumlah Kampus</div>
    </div>
    <div class="stat-card sc-navy afu d3" style="border-top:3px solid #EF4444;">
      <div class="stat-icon bg-red-50"><i class="fas fa-user-slash text-red-500"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:#EF4444;">${kosong.length}</div>
      <div class="stat-lbl" style="color:#EF4444;">Jawatan Kosong</div>
    </div>
    <div class="stat-card sc-amber afu d4" style="border-top:3px solid ${kampusPenuh.length===totalKampus?"#0E7C61":"#F59E0B"};">
      <div class="stat-icon" style="background:${kampusPenuh.length===totalKampus?"#f0fdf4":"#fffbeb"};"><i class="fas fa-check-circle" style="color:${kampusPenuh.length===totalKampus?"#0E7C61":"#F59E0B"};"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.5rem;font-weight:800;color:var(--navy);">${kampusPenuh.length}</div>
      <div class="stat-lbl">Kampus Lengkap</div>
    </div>
  </div>

  <!-- Jawatan Kosong per Kampus -->
  ${kampusKosong.length ? `
  <div class="card" style="margin-bottom:14px;border-left:4px solid #EF4444;">
    <div class="card-head" style="background:#fef2f2;">
      <span class="card-title" style="color:#DC2626;"><i class="fas fa-triangle-exclamation mr-2"></i>Kampus Dengan Jawatan Kosong (${kampusKosong.length} kampus)</span>
    </div>
    <div class="card-body" style="padding:0;">
      <table class="tbl">
        <thead><tr>
          <th>Kampus</th><th>Zon</th>
          <th style="text-align:center;">Ketua Kaunselor</th>
          <th style="text-align:center;">Kaunselor (Pentadbiran)</th>
          <th style="text-align:center;">Kaunselor (Pelajar)</th>
          <th style="text-align:center;">Jumlah Kosong</th>
        </tr></thead>
        <tbody>
        ${kampusKosong.map(([org,v])=>{
          const hasKetua = v.staff.some(s=>(s.jawatan||"").toUpperCase().includes("KETUA"));
          const hasPentadbiran = v.staff.some(s=>(s.jawatan||"").toUpperCase().includes("PENTADBIRAN"));
          const hasPelajar = v.staff.some(s=>(s.jawatan||"").toUpperCase().includes("PELAJAR")||(s.jawatan||"").toUpperCase().includes("MURID"));
          const tick = `<span style="color:#0E7C61;font-size:1rem;">✓</span>`;
          const cross = `<span style="background:#FEE2E2;color:#DC2626;font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:4px;">KOSONG</span>`;
          return `<tr>
            <td style="font-weight:600;font-size:.82rem;">${org}</td>
            <td><span class="bdg bdg-navy" style="font-size:.65rem;">${v.zon}</span></td>
            <td style="text-align:center;">${hasKetua?tick:cross}</td>
            <td style="text-align:center;">${hasPentadbiran?tick:cross}</td>
            <td style="text-align:center;">${hasPelajar?tick:cross}</td>
            <td style="text-align:center;font-weight:700;color:#DC2626;">${v.kosong.length}</td>
          </tr>`;
        }).join("")}
        </tbody>
      </table>
    </div>
  </div>` : `
  <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:14px;font-size:13px;color:#15803d;">
    <i class="fas fa-circle-check mr-2"></i> Semua kampus mempunyai perjawatan lengkap.
  </div>`}

  <!-- Kampus Lengkap -->
  ${kampusPenuh.length ? `
  <div class="card" style="margin-bottom:14px;border-left:4px solid #0E7C61;">
    <div class="card-head" style="background:#f0fdf4;">
      <span class="card-title" style="color:#0E7C61;"><i class="fas fa-circle-check mr-2"></i>Kampus Perjawatan Lengkap (${kampusPenuh.length} kampus)</span>
    </div>
    <div class="card-body">
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        ${kampusPenuh.map(([org])=>`<span style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:.75rem;padding:4px 10px;border-radius:6px;font-weight:500;">${org}</span>`).join("")}
      </div>
    </div>
  </div>` : ""}

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head">
        <span class="card-title"><i class="fas fa-chart-bar text-pri-500 mr-2"></i>Kaunselor Mengikut Zon</span>
      </div>
      <div class="card-body">
        ${Object.entries(byZon).sort((a,b)=>b[1]-a[1]).map(([z,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:9px;">
          <div style="font-size:.78rem;flex:1;font-weight:500;">${z}</div>
          <div style="width:120px;">
            <div class="prog"><div class="prog-fill" style="width:${((v/enriched.length)*100).toFixed(0)}%;background:#0E7C61;"></div></div>
          </div>
          <div style="font-size:.78rem;font-weight:700;width:24px;text-align:right;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
    <div class="card">
      <div class="card-head">
        <span class="card-title"><i class="fas fa-building text-amb-500 mr-2"></i>Bilangan Kaunselor / Kampus</span>
      </div>
      <div class="card-body">
        ${Object.entries(byKampus).sort((a,b)=>b[1]-a[1]).slice(0,10).map(([k,v],i)=>`
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
          <div style="font-size:.7rem;color:var(--muted);width:18px;">${i+1}</div>
          <div style="font-size:.78rem;flex:1;">${k.replace("IPG Kampus ","")}</div>
          <div style="width:80px;">
            <div class="prog"><div class="prog-fill" style="width:${((v/Math.max(...Object.values(byKampus)))*100).toFixed(0)}%;background:#E88D3A;"></div></div>
          </div>
          <div style="font-size:.78rem;font-weight:700;width:24px;text-align:right;">${v}</div>
        </div>`).join("")}
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-table text-pri-500 mr-2"></i>Senarai Kaunselor</span>
      <div style="display:flex;gap:6px;align-items:center;">
        <input type="text" class="fi" style="max-width:180px;font-size:.8rem;" placeholder="Cari nama / ID..." id="kaun-cari" oninput="filterKaunselor()">
        <button class="btn btn-pri btn-sm" onclick="navTo('au-pengguna')">
          <i class="fas fa-plus"></i> Tambah
        </button>
      </div>
    </div>
    <div style="overflow-x:auto;" id="kaun-table">${renderKaunselorTable(enriched)}</div>
  </div>`;

  window._kaunData = enriched;

  // Attach CSV upload handler
  setTimeout(()=>{
    const fi = document.getElementById("kaun-csv-inp");
    if(fi) fi.onchange = function(){
      importCSVKauns(this, "kaunselor");
    };
  },100);
}

function renderKaunselorTable(data){
  if(!data.length) return `<p class="text-sm text-gray-400 p-4 text-center">Tiada kaunselor.</p>`;
  return `<table class="tbl" id="tbl-kaunselor-main">
    <thead><tr>
      <th>#</th><th>Nama</th><th>Jawatan</th><th>Gred</th>
      <th>Organisasi</th><th>Zon</th><th>Negeri</th>
      <th>No. Kaunselor</th><th>Bimbit</th><th>Email</th><th>Sasaran Sesi</th>
    </tr></thead>
    <tbody>${data.map((u,i)=>`<tr>
      <td style="color:var(--muted);font-size:.72rem;">${i+1}</td>
      <td style="font-weight:600;font-size:.82rem;">${u.nama}</td>
      <td style="font-size:.75rem;">${u.jawatan}</td>
      <td><span class="bdg bdg-navy" style="font-size:.65rem;">${u.gred}</span></td>
      <td style="font-size:.72rem;">${u.organisasi}</td>
      <td><span class="bdg bdg-pri" style="font-size:.65rem;">${u.zon}</span></td>
      <td style="font-size:.72rem;">${u.negeri}</td>
      <td style="font-size:.72rem;font-family:monospace;">${u.noKaunselor}</td>
      <td style="font-size:.72rem;">${u.bimbit}</td>
      <td style="font-size:.7rem;color:#0E7C61;">${u.email}</td>
      <td style="text-align:center;font-weight:700;">${u.sasaranSesi||"—"}</td>
    </tr>`).join("")}</tbody>
  </table>`;
}

function filterKaunselor(){
  const q = (document.getElementById("kaun-cari")?.value||"").toLowerCase();
  let d = window._kaunData||[];
  if(q) d = d.filter(u=>(u.nama+u.jawatan+u.organisasi+u.zon+u.negeri+u.noKaunselor).toLowerCase().includes(q));
  document.getElementById("kaun-table").innerHTML = renderKaunselorTable(d);
}

