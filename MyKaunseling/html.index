// ══════════════════════════════════════════
// KONFIGURASI GOOGLE SHEETS API
// ══════════════════════════════════════════
const SHEETS_CONFIG = {
  apiKey: "AIzaSyCVR7ilnItnTL7Ogh7Fo4ZE-Bb-w7U-B5E",
  spreadsheetId: "1guGwHIr1qGy9QiJgLklrRBA6HBhAl0wkSgqU1kFzzZY",
  range: "Sheet1!A:AE",
  altRanges: ["DATA MyPKPP!A:AE","Sheet1!A:AE","Tab!A:AE"],
  url: function(range){
    const r = range || this.range;
    return `https://sheets.googleapis.com/v4/spreadsheets/${this.spreadsheetId}/values/${encodeURIComponent(r)}?key=${this.apiKey}`;
  }
};

// Status sync
let _sheetsLoaded = false;
let _sheetsLoading = false;
let _sheetsError = null;

// Fetch data dari Google Sheets API
async function fetchSheetsData(){
  if(_sheetsLoading) return;
  _sheetsLoading = true;
  _sheetsError = null;
  try {
    // Detect tab name
    let tabName = "Sheet1";
    const tabsToTry = ["Sheet1","DATA MyPKPP","Helaian1","Tab1","Data"];
    for(const tab of tabsToTry){
      try {
        const testUrl = SHEETS_CONFIG.url(tab+"!A1:B2");
        const testResp = await fetch(testUrl);
        if(testResp.ok){ tabName = tab; break; }
      } catch(e){}
    }

    // Fetch semua data dalam batch (setiap batch 10,000 baris)
    // Google Sheets API tak ada had bilangan baris — A:AE fetch semua
    const batchSize = 10000;
    let allRows = [];
    let headers = null;
    let startRow = 1;
    let hasMore = true;

    // Update loading indicator jika ada
    const loadEl = document.querySelector('#sheets-load-progress');
    if(loadEl) loadEl.textContent = 'Memuatkan data...';

    while(hasMore){
      const endRow = startRow + batchSize - 1;
      const range = `${tabName}!A${startRow}:AE${endRow}`;
      const url = SHEETS_CONFIG.url(range);
      const resp = await fetch(url);
      if(!resp.ok) throw new Error(`HTTP ${resp.status}: ${resp.statusText}`);
      const json = await resp.json();

      if(!json.values || json.values.length === 0){
        hasMore = false; break;
      }

      const batchRows = json.values;

      // Baris pertama batch pertama = header
      if(startRow === 1){
        headers = batchRows[0];
        allRows = allRows.concat(batchRows.slice(1));
      } else {
        allRows = allRows.concat(batchRows);
      }

      // Jika batch kurang dari batchSize, bermakna dah habis
      if(batchRows.length < batchSize){ hasMore = false; }
      else { startRow += batchSize; }

      // Update progress
      if(loadEl) loadEl.textContent = `Memuatkan... ${allRows.length.toLocaleString()} rekod`;
    }

    if(!headers) throw new Error("Tiada header dalam sheet");
    if(allRows.length === 0) throw new Error("Tiada data dalam sheet");

    // Map header index
    const hi = {};
    headers.forEach((h,i) => { hi[h.trim().toUpperCase()] = i; });

    // Parse semua baris
    const parsed = allRows.filter(r => r && r.length > 3).map(r => {
      const g = (col) => (r[hi[col]]||"").toString().trim();
      const ipgk = g("IPGK") || g("KOD_IPG") || "";
      const kobj = KAMPUS.find(k => "IPGK"+k.id === ipgk || k.id === ipgk.replace(/^IPGK/,"K")) || {};
      return {
        no_matrik:        g("NO_MATRIK"),
        nama:             g("NAMA"),
        jantina:          g("JANTINA"),
        tel:              g("NO TELEFON HP") || g("TELEFON") || "0",
        emel:             g("EMEL"),
        kod_ipg:          g("KOD_IPG"),
        ipgk:             ipgk,
        zon:              g("ZON"),
        kampus_id:        kobj.id || ipgk.replace(/^IPGK/,"K"),
        kampus_nama:      kobj.nama || ipgk,
        aliran_sekolah:   g("ALIRAN SEKOLAH") || g("ALIRAN_SEKOLAH") || g("ALIRAN"),
        kod_program:      g("KOD_PROGRAM"),
        mod_pengajian:    g("MOD PENGAJIAN") || g("MOD_PENGAJIAN"),
        opsyen_1:         g("KOD_OPSYEN_1"),
        opsyen_2:         g("KOD_OPSYEN_2"),
        opsyen_3:         g("KOD_OPSYEN_3"),
        sesi_ambilan:     g("SESI_AMBILAN_PENGAJIAN"),
        sesi_tamat:       g("SESI_TAMAT_PENGAJIAN"),
        status_pengajian: g("STATUS_PENGAJIAN") || g("STATUS PENGAJIAN"),
        agama:            g("AGAMA"),
        agama_txt:        {"1":"Islam","2":"Kristian","3":"Buddha","4":"Hindu","5":"Lain-lain"}[g("AGAMA")] || g("AGAMA"),
        program:          g("PROGRAM"),
        tahun:            g("TAHUN"),
        daerah:           g("DAERAH"),
        negeri:           g("NEGERI"),
        lat:              parseFloat(g("LATITUDE")) || 0,
        lng:              parseFloat(g("LONGITUDE")) || 0
      };
    }).filter(r => r.no_matrik || r.nama);

    window.ENROLMEN_LIVE = parsed;
    _sheetsLoaded = true;
    _sheetsLoading = false;
    console.log(`Sheets: ${parsed.length} rekod dimuatkan dari tab "${tabName}"`);
    return parsed;

  } catch(err) {
    _sheetsError = err.message;
    _sheetsLoading = false;
    console.error("Sheets API error:", err);
    return null;
  }
}

// Wrapper: guna data live jika ada, fallback ke data sampel
function getEnrolmenData(kampusId){
  const src = window.ENROLMEN_LIVE || ENROLMEN_DATA;
  return kampusId ? src.filter(d=>d.kampus_id===kampusId) : src;
}

// ══════════════════════════════════════════
// DATA ENROLMEN — Struktur Google Sheets MyPKPP
// Lajur: NO_KP, NO_MATRIK, NAMA, JANTINA,
//   TELEFON, EMEL, KOD_IPG, IPGK, ZON,
//   ALIRAN_SEKOLAH, KOD_PROGRAM, MOD_PENGAJIAN,
//   OPSYEN_1/2/3, SESI_AMBILAN, SESI_TAMAT,
//   STATUS_PENGAJIAN, AGAMA, PROGRAM, TAHUN,
//   DAERAH, NEGERI, LATITUDE, LONGITUDE
// ══════════════════════════════════════════

const ENROLMEN_DATA = (function(){
  const nL=["AHMAD FAUZI","MUHAMMAD HAZIQ","MOHD AMIN","RASHDAN MALIK","ADAM AZIM","ATIQ MUSTAQIM","KHAIRUL NIZAM","ZULHILMI","HAFIZUDDIN","IZZAT HAZWAN"];
  const nP=["NURUL AISYAH","SITI BALQIS","NUR AFIQAH","FARAH AIN","NORAINI","ADLINA BATRISYIA","AIDA MAISARAH","AINA BATRISYIA","AISHAH DINI","ALIA QISTINA","ALYA INSYIRAH","AMIRAH ARDINI","ANIS NAJWA","KAVITHA A/P RAJAN","PRIYA A/P MUTHU","SITI NURBAYA"];
  const opsyen=["TSLB","ETSLB","PK","BM","BI","MT","SC","PJ","PSV","KH","TMK","SEJ","GEO","PI","BC","BT","ERT","RBT"];
  const prog=["PPISMP","PISMP","DPLI"];
  const aliran=["SK","SJKC","SJKT"];
  const agMap={1:"Islam",2:"Kristian",3:"Buddha",4:"Hindu",5:"Lain-lain"};
  const negeri=["KUALA LUMPUR","SELANGOR","JOHOR","PERAK","KEDAH","PULAU PINANG","KELANTAN","TERENGGANU","PAHANG","NEGERI SEMBILAN","MELAKA","SABAH","SARAWAK","PERLIS"];
  const daerah=["LEMBAH PANTAI","KEPONG","CHERAS","TITIWANGSA","SEPUTEH","PETALING","GOMBAK","KLANG"];
  const sesiList=["OGOS 2023","JAN 2024","OGOS 2024","JAN 2025","OGOS 2025"];
  const sesiTamat={"OGOS 2023":"JULAI 2027","JAN 2024":"DIS 2027","OGOS 2024":"JULAI 2028","JAN 2025":"DIS 2028","OGOS 2025":"JULAI 2026"};
  const data=[]; let c=1;
  KAMPUS.forEach((k,ki)=>{
    const n=18+Math.floor(((k.id.charCodeAt(0)*7+ki*11)%15));
    for(let i=0;i<n;i++){
      const s=k.id.charCodeAt(0)*31+i*17+ki*7;
      const j=(s%4===0)?"L":"P";
      const nm=(j==="L"?nL:nP)[(s+i)%(j==="L"?nL.length:nP.length)];
      const pr=prog[s%3];
      const si=sesiList[(s+i)%5];
      const ag=(s%10<7)?1:(s%10<8)?2:(s%10<9)?3:4;
      const sts=(s%20===0)?"BERHENTI":(s%15===0)?"TANGGUH":"AKTIF";
      const ops1=opsyen[s%opsyen.length];
      const ops2=opsyen[(s+3)%opsyen.length];
      const al=aliran[s%3];
      data.push({
        no_matrik:"P"+String(2024000+c).padStart(9,"0").slice(0,9),
        nama:nm+" BIN"+(j==="P"?"TI ":" ")+"PLACEHOLDER",
        jantina:j,
        tel:(s%5===0)?String(60000000+s%40000000):"0",
        emel:nm.split(" ")[0].toLowerCase()+(s%99)+"@gmail.com",
        kod_ipg:"IPGK_"+k.id.replace(/^K/,""),
        ipgk:"IPGK"+k.id,
        zon:k.zona.toUpperCase(),
        kampus_id:k.id,
        kampus_nama:k.nama,
        aliran_sekolah:al,
        kod_program:pr==="PPISMP"?101:pr==="PISMP"?102:201,
        mod_pengajian:1,
        opsyen_1:ops1,
        opsyen_2:(al!=="SK"&&s%3===0)?"0":ops2,
        opsyen_3:"0",
        sesi_ambilan:si,
        sesi_tamat:sesiTamat[si],
        status_pengajian:sts,
        agama:ag,
        agama_txt:agMap[ag],
        program:pr,
        tahun:pr==="PPISMP"?"PPISMP/T"+(s%2+1):pr==="PISMP"?"PISMP/T"+(s%4+1):"DPLI/T1",
        daerah:daerah[s%daerah.length],
        negeri:negeri[(s+ki)%negeri.length],
        lat:3.0+(s%100)/200,
        lng:101.5+(s%100)/200
      });
      c++;
    }
  });
  return data;
})();

function enrolmenStat(data){
  const aktif=data.filter(d=>d.status_pengajian==="AKTIF").length;
  const berhenti=data.filter(d=>d.status_pengajian==="BERHENTI").length;
  const tangguh=data.filter(d=>d.status_pengajian==="TANGGUH").length;
  const tamat=data.filter(d=>d.status_pengajian==="TAMAT").length;
  const L=data.filter(d=>d.jantina==="L").length;
  const P=data.filter(d=>d.jantina==="P").length;
  const sk=data.filter(d=>d.aliran_sekolah==="SK").length;
  const sjkc=data.filter(d=>d.aliran_sekolah==="SJKC").length;
  const sjkt=data.filter(d=>d.aliran_sekolah==="SJKT").length;
  const progCount={};data.forEach(d=>{progCount[d.program]=(progCount[d.program]||0)+1;});
  const sesiCount={};data.forEach(d=>{sesiCount[d.sesi_ambilan]=(sesiCount[d.sesi_ambilan]||0)+1;});
  const negeriCount={};data.forEach(d=>{negeriCount[d.negeri]=(negeriCount[d.negeri]||0)+1;});
  const opsCount={};data.forEach(d=>{if(d.opsyen_1&&d.opsyen_1!=="0")opsCount[d.opsyen_1]=(opsCount[d.opsyen_1]||0)+1;});
  return{total:data.length,aktif,berhenti,tangguh,tamat,L,P,sk,sjkc,sjkt,progCount,sesiCount,negeriCount,opsCount};
}

function pgAKEnrolmen(c){
  c.innerHTML=`<div style="padding:40px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:14px;display:block;color:var(--pri);"></i><div style="font-size:14px;font-weight:500;">Memuatkan data dari Google Sheets...</div><div id="sheets-load-progress" style="font-size:12px;margin-top:6px;color:var(--muted);">Menyambung ke pangkalan data...</div><div style="font-size:11px;margin-top:10px;color:var(--muted);opacity:0.6;">36,000 rekod pelajar — sila tunggu sebentar</div></div>`;
  loadAndRenderEnrolmen(c, SES.kampus);
}

function pgAUEnrolmen(c){
  c.innerHTML=`<div style="padding:40px;text-align:center;color:var(--muted);"><i class="fas fa-spinner fa-spin" style="font-size:28px;margin-bottom:14px;display:block;color:var(--pri);"></i><div style="font-size:14px;font-weight:500;">Memuatkan data dari Google Sheets...</div><div id="sheets-load-progress" style="font-size:12px;margin-top:6px;color:var(--muted);">Menyambung ke pangkalan data...</div><div style="font-size:11px;margin-top:10px;color:var(--muted);opacity:0.6;">36,000 rekod pelajar seluruh negara — sila tunggu sebentar</div></div>`;
  loadAndRenderEnrolmen(c, null);
}

async function loadAndRenderEnrolmen(c, kampusId){
  // Cuba API dulu jika ada data live atau belum cuba
  // Load Enrolmen: Sheets > IDB > sampel
  const enrolmenParsed = await loadTabData("enrolmen", _parseEnrolmenRow, {_e: window.ENROLMEN_LIVE||[]}, "_e");
  if(enrolmenParsed && enrolmenParsed.length > 0){
    window.ENROLMEN_LIVE = enrolmenParsed;
    window.ENROLMEN_CSV  = enrolmenParsed;
    _sheetsLoaded = true;
  }

  // Tentukan sumber data
  let raw, tajuk, sumber;
  if(window.ENROLMEN_LIVE && window.ENROLMEN_LIVE.length > 0){
    raw = kampusId ? window.ENROLMEN_LIVE.filter(d=>d.kampus_id===kampusId) : window.ENROLMEN_LIVE;
    tajuk = kampusId ? kObj(kampusId).nama : "Semua Kampus IPG Malaysia";
    sumber = "live";
  } else if(window.ENROLMEN_CSV && window.ENROLMEN_CSV.length > 0){
    raw = kampusId ? window.ENROLMEN_CSV.filter(d=>d.kampus_id===kampusId) : window.ENROLMEN_CSV;
    tajuk = kampusId ? kObj(kampusId).nama : "Semua Kampus IPG Malaysia";
    sumber = "csv";
  } else {
    raw = ENROLMEN_DATA.filter(d=>kampusId?d.kampus_id===kampusId:true);
    tajuk = kampusId ? kObj(kampusId).nama : "Semua Kampus IPG Malaysia";
    sumber = "sampel";
  }

  renderEnrolmenPage(c, raw, tajuk, !kampusId);

  // Notice bar mengikut sumber
  const notice = document.createElement("div");
  if(sumber === "live"){
    notice.style.cssText="background:rgba(22,163,74,0.08);border:1px solid rgba(22,163,74,0.2);border-radius:8px;padding:8px 14px;font-size:12px;color:#166534;margin-bottom:14px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;";
    notice.innerHTML=`<i class="fas fa-circle-check"></i><span>Data <b>Google Sheets</b> — ${raw.length} rekod</span>
      <button onclick="window.ENROLMEN_LIVE=null;_sheetsLoaded=false;_sheetsError=null;navTo(SES.pg)" style="font-size:11px;background:rgba(22,163,74,0.15);color:#166534;border:none;padding:3px 10px;border-radius:6px;cursor:pointer;margin-left:auto;"><i class="fas fa-rotate-right"></i> Refresh</button>`;
  } else {
    notice.style.cssText="background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:12px 16px;font-size:12px;color:#92400e;margin-bottom:14px;";
    const kid = kampusId || "";
    const errMsg = _sheetsError || "";
    const isCsv = (sumber === "csv");
    const noticeTitle = isCsv ? "Data CSV dimuatkan — " + raw.length + " rekod" : "Menggunakan data sampel";
    const errHtml = errMsg ? ' <span style="color:#991b1b;font-size:11px;">(' + errMsg + ')</span>' : '';
    const deleteBtn = isCsv ? '<button onclick="localStorage.removeItem(&quot;csv_enrolmen_data&quot;);localStorage.removeItem(&quot;csv_enrolmen_date&quot;);window.ENROLMEN_LIVE=null;window.ENROLMEN_CSV=null;_sheetsLoaded=false;navTo(SES.pg);" style="font-size:11px;color:#991b1b;border:1px solid #fca5a5;padding:4px 10px;border-radius:6px;background:#fff;cursor:pointer;"><i class=\"fas fa-trash\"></i> Padam</button>' : '';
    const lastDate = localStorage.getItem("csv_enrolmen_date") || "";
    const dateHtml = lastDate ? '<div style="font-size:10px;color:#666;margin-top:2px;"><i class=\"fas fa-clock\"></i> Dikemaskini: ' + lastDate + '</div>' : '';
    notice.innerHTML = '<div style="margin-bottom:10px;"><b>' + noticeTitle + '</b>' + errHtml + dateHtml + (sumber==="sampel"?'<div style="margin-top:4px;">Muat naik CSV untuk papar data sebenar.</div>':'') + '</div>'
      + '<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">'
      + '<label id="enrol-upload-lbl" style="background:#0E7C61;color:#fff;padding:5px 14px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;display:inline-flex;align-items:center;gap:6px;">'
      + '<i class=\"fas fa-file-csv\"></i> ' + (isCsv?"Kemaskini":"Muat Naik") + ' CSV'
      + '<input type=\"file\" accept=\".csv\" id=\"enrol-file-input\" style=\"display:none\">'
      + '</label>'
      + '<a href="https://docs.google.com/spreadsheets/d/1guGwHIr1qGy9QiJgLklrRBA6HBhAl0wkSgqU1kFzzZY/export?format=csv" target="_blank" style="font-size:11px;color:#0E7C61;border:1px solid #0E7C61;padding:4px 10px;border-radius:6px;text-decoration:none;display:inline-flex;align-items:center;gap:4px;"><i class=\"fas fa-download\"></i> Muat Turun CSV</a>'
      + deleteBtn
      + '<button onclick="_sheetsError=null;_sheetsLoading=false;navTo(SES.pg)" style="font-size:11px;color:#666;border:1px solid #ddd;padding:4px 10px;border-radius:6px;background:#fff;cursor:pointer;"><i class=\"fas fa-rotate-right\"></i> Cuba Semula</button>'
      + '</div>';
    // Attach file input handler after DOM insert (done below)
    setTimeout(function(){
      var fi = document.getElementById("enrol-file-input");
      if(fi) fi.onchange = function(){ importCSVEnrolmen(this, kid); };
    }, 100);
  }
  c.insertBefore(notice, c.firstChild);
}

function importCSVEnrolmen(input, kampusFilter){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const text = e.target.result;
      const lines = text.replace(/\r/g,"").split("\n").filter(l=>l.trim());
      if(lines.length < 2){ toast("Fail CSV kosong atau tidak sah","err"); return; }
      const headers = lines[0].split(",").map(h=>h.trim().replace(/^"|"$/g,""));
      const hi = {}; headers.forEach((h,i)=>{ hi[h.toUpperCase()] = i; });
      const g = (row,col) => (row[hi[col.toUpperCase()]]||"").toString().replace(/^"|"$/g,"").trim();
      const parsed = lines.slice(1).filter(l=>l.trim()).map(line=>{
        // Handle CSV with quoted fields
        const row = line.match(/(".*?"|[^,]+|(?<=,)(?=,)|(?<=,)$|^(?=,))/g)||line.split(",");
        const ipgk = g(row,"IPGK") || g(row,"KOD_IPG") || "";
        const kobj = KAMPUS.find(k=>"IPGK"+k.id===ipgk || k.id===ipgk.replace(/^IPGK/,"K")) || {};
        return {
          no_matrik: g(row,"NO_MATRIK"),
          nama: g(row,"NAMA"),
          jantina: g(row,"JANTINA"),
          ipgk, zon: g(row,"ZON"),
          kampus_id: kobj.id || ipgk.replace(/^IPGK/,"K"),
          kampus_nama: kobj.nama || ipgk,
          aliran_sekolah: g(row,"ALIRAN SEKOLAH") || g(row,"ALIRAN_SEKOLAH"),
          opsyen_1: g(row,"KOD_OPSYEN_1"),
          opsyen_2: g(row,"KOD_OPSYEN_2"),
          sesi_ambilan: g(row,"SESI_AMBILAN_PENGAJIAN"),
          sesi_tamat: g(row,"SESI_TAMAT_PENGAJIAN"),
          status_pengajian: g(row,"STATUS_PENGAJIAN") || g(row,"STATUS PENGAJIAN"),
          agama: g(row,"AGAMA"),
          agama_txt: {"1":"Islam","2":"Kristian","3":"Buddha","4":"Hindu","5":"Lain-lain"}[g(row,"AGAMA")] || g(row,"AGAMA"),
          program: g(row,"PROGRAM"),
          tahun: g(row,"TAHUN"),
          daerah: g(row,"DAERAH"),
          negeri: g(row,"NEGERI"),
          lat: parseFloat(g(row,"LATITUDE"))||0,
          lng: parseFloat(g(row,"LONGITUDE"))||0
        };
      }).filter(r=>r.no_matrik||r.nama);
      window.ENROLMEN_CSV = parsed;
      _sheetsLoaded = true;
      window.ENROLMEN_LIVE = parsed;
      // Simpan ke IndexedDB (500MB+) dengan safe check
      try {
        if(typeof idbSave === "function"){
          idbSave("csv_enrolmen", parsed).then(ok => {
            if(ok) localStorage.setItem("csv_enrolmen_date", new Date().toLocaleString("ms-MY"));
          });
        }
      } catch(e){ console.warn("Enrolmen save:", e); }
      localStorage.setItem("csv_enrolmen_date", new Date().toLocaleString("ms-MY"));
      toast(parsed.length.toLocaleString("ms-MY") + " rekod enrolmen berjaya diimport","ok");
      navTo(SES.pg);
    } catch(err){
      toast("Gagal baca CSV: "+err.message,"err");
    }
  };
  reader.readAsText(file);
}

function renderEnrolmenPage(c,rawData,tajuk,isUtama){
  const st=enrolmenStat(rawData);
  const sesiOrder=["OGOS 2023","JAN 2024","OGOS 2024","JAN 2025","OGOS 2025"];
  const topNegeri=Object.entries(st.negeriCount).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const topOpsyen=Object.entries(st.opsCount).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const colors=["#0E7C61","#E88D3A","#3B82F6","#8B5CF6","#EF4444","#14B8A6","#F59E0B","#6366F1"];

  c.innerHTML=`
  ${!isUtama ? viewerExportBar("Enrolmen_"+SES.kampus,"en-table-inner") : ""}
  <div class="afu" style="background:linear-gradient(135deg,#132238 0%,#0E7C61 100%);border-radius:12px;padding:20px 24px;margin-bottom:18px;position:relative;overflow:hidden;">
    <div style="position:absolute;right:-20px;top:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    <div style="position:relative;z-index:1;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
        <span style="background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.85);font-size:.7rem;padding:3px 10px;border-radius:20px;font-weight:600;"><i class="fas fa-chart-column mr-1"></i>ANALISIS ENROLMEN</span>
        <span style="background:rgba(14,124,97,0.4);color:#B3E2D2;font-size:.7rem;padding:3px 10px;border-radius:20px;">Sumber: Google Sheets MyPKPP</span>
      </div>
      <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.25rem;color:#fff;margin-bottom:3px;">Enrolmen Pelajar — ${tajuk}</div>
      <div style="font-size:.78rem;color:rgba(255,255,255,0.5);">Analisis data enrolmen berasaskan struktur data MyPKPP · ${rawData.length} rekod pelajar</div>
    </div>
  </div>

  <!-- KPI -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px;">
    ${[
      {l:"Jumlah Enrolmen",v:st.total,i:"fa-users",c:"sc-pri",bg:"bg-pri-50",fg:"text-pri-600",sub:"Keseluruhan pelajar"},
      {l:"Pelajar Aktif",v:st.aktif,i:"fa-circle-check",c:"sc-pri",bg:"bg-green-50",fg:"text-green-600",sub:((st.aktif/st.total)*100).toFixed(1)+"% daripada jumlah"},
      {l:"Berhenti / Tangguh",v:st.berhenti+st.tangguh,i:"fa-circle-pause",c:"sc-amber",bg:"bg-amb-50",fg:"text-amb-600",sub:st.berhenti+" berhenti · "+st.tangguh+" tangguh"},
      {l:"Nisbah L : P",v:st.L+" : "+st.P,i:"fa-venus-mars",c:"sc-navy",bg:"bg-navy-50",fg:"text-navy-600",sub:((st.L/st.total)*100).toFixed(0)+"% L · "+((st.P/st.total)*100).toFixed(0)+"% P"}
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div style="font-family:'Outfit',sans-serif;font-size:1.45rem;font-weight:800;color:var(--navy);line-height:1.1;">${s.v}</div>
      <div class="stat-lbl">${s.l}</div>
      <div style="font-size:.7rem;color:var(--muted);margin-top:3px;">${s.sub}</div>
    </div>`).join("")}
  </div>

  <!-- Status + Jantina -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
    <div class="card">
      <div class="card-head"><span class="card-title"><i class="fas fa-circle-half-stroke text-pri-500 mr-2"></i>Status Pengajian</span></div>
      <div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        ${[
          {l:"Aktif",v:st.aktif,c:"#0E7C61",bg:"rgba(14,124,97,0.08)"},
          {l:"Berhenti",v:st.berhenti,c:"#DC2626",bg:"rgba(220,38,38,0.08)"},
          {l:"Tangguh",v:st.tangguh,c:"#E88D3A",bg:"rgba(232,141,58,0.08)"},
