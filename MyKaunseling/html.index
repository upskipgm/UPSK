function pgAUCSV(c){
  const tabs = [
    {id:"enrolmen",  label:"Enrolmen Pelajar",            icon:"fa-user-graduate",     color:"#0E7C61",
     desc:"Data enrolmen pelajar (Sheet1)"},
    {id:"pkpp",      label:"PKPP — Kesejahteraan Pelajar", icon:"fa-heart-pulse",       color:"#0E7C61",
     desc:"Profil Kesejahteraan & Personaliti Pelajar"},
    {id:"pkpw",      label:"PKPW — Kesejahteraan Warga",  icon:"fa-user-shield",       color:"#3D5490",
     desc:"Profil Kesejahteraan & Personaliti Warga"},
    {id:"minda",     label:"Minda Sihat",                 icon:"fa-brain",             color:"#5a2d82",
     desc:"Saringan DASS-21 & Daya Tindak"},
    {id:"sesi",      label:"Analisis Sesi",               icon:"fa-calendar-check",    color:"#0E7C61",
     desc:"Perkhidmatan Sesi Kaunseling (36,789 rekod)"},
    {id:"program",   label:"Analisis Program",            icon:"fa-chalkboard-teacher",color:"#3B82F6",
     desc:"Program Kaunseling (1,015 rekod)"},
    {id:"kaunselor", label:"Data Kaunselor",              icon:"fa-user-tie",          color:"#132238",
     desc:"Maklumat Kaunselor Berdaftar (84 rekod)"},
  ];

  function getInfo(id){
    let data;
    if(id==="enrolmen") data = window.ENROLMEN_LIVE||window.ENROLMEN_CSV;
    else if(id==="sesi"||id==="program"||id==="kaunselor") data = KAUNS_CACHE[id];
    else data = SHEETS_CACHE[id];
    const count = data ? data.length : 0;
    const date = localStorage.getItem("csv_"+id+"_date") || "";
    return {date, count, hasData: count > 0};
  }

  c.innerHTML=`
  <!-- Info Banner -->
  <div style="background:linear-gradient(135deg,#132238,#1F2C50);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;">
    <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.1rem;margin-bottom:4px;"><i class="fas fa-database mr-2"></i>Pengurusan Data CSV</div>
    <div style="font-size:.78rem;color:rgba(255,255,255,0.55);">Data CSV disimpan dalam pelayar (localStorage) — kekal sehingga anda membersihkan cache pelayar atau memadam secara manual.</div>
  </div>

  <!-- Cara Eksport -->
  <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:14px 18px;margin-bottom:18px;">
    <div style="font-size:13px;font-weight:700;color:#92400e;margin-bottom:8px;"><i class="fas fa-lightbulb mr-2"></i>Cara Eksport CSV dari Google Sheets</div>
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;font-size:11px;color:#78350f;">
      ${["1. Buka Google Sheets anda","2. Klik tab yang dikehendaki (Enrolmen / PKPP / PKPW / Minda Sihat)","3. File → Download → Comma Separated Values (.csv)","4. Muat naik fail CSV di bawah"].map((s,i)=>`
      <div style="background:rgba(255,255,255,0.6);border-radius:6px;padding:8px;display:flex;gap:6px;">
        <span style="font-weight:800;font-size:14px;color:#d97706;">${i+1}</span>
        <span>${s}</span>
      </div>`).join("")}
    </div>
  </div>

  <!-- Tab Cards -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;" id="csv-cards">
    ${tabs.map(t=>{
      const info = getInfo(t.id);
      return `<div class="card" style="border-top:3px solid ${t.color};">
        <div class="card-body">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
            <div style="width:40px;height:40px;border-radius:9px;background:${t.color}20;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <i class="fas ${t.icon}" style="color:${t.color};"></i>
            </div>
            <div>
              <div style="font-family:'Outfit',sans-serif;font-weight:700;font-size:.9rem;color:var(--navy);">${t.label}</div>
              <div style="font-size:.72rem;color:var(--muted);">${t.desc}</div>
            </div>
          </div>

          <!-- Status -->
          <div style="background:${info.hasData?"rgba(22,163,74,0.08)":"rgba(100,116,139,0.08)"};border:1px solid ${info.hasData?"rgba(22,163,74,0.2)":"rgba(100,116,139,0.15)"};border-radius:7px;padding:10px 12px;margin-bottom:12px;">
            <div style="display:flex;align-items:center;gap:6px;font-size:12px;color:${info.hasData?"#166534":"#475569"};">
              <i class="fas ${info.hasData?"fa-circle-check":"fa-circle-xmark"}"></i>
              <span style="font-weight:600;">${info.hasData?info.count.toLocaleString("ms-MY")+" rekod tersedia":"Tiada data"}</span>
            </div>
            ${info.date?`<div style="font-size:10px;color:#666;margin-top:3px;"><i class="fas fa-clock mr-1"></i>Dikemaskini: ${info.date}</div>`:""}
          </div>

          <!-- Butang -->
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <label style="background:${t.color};color:#fff;padding:5px 12px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;flex:1;justify-content:center;">
              <i class="fas fa-upload"></i>${info.hasData?"Kemaskini":"Muat Naik"} CSV
              <input type="file" accept=".csv" style="display:none" onchange="handleCSVUpload(this,'${t.id}')">
            </label>
            <a href="${t.sheetUrl}" target="_blank" style="background:#f8f9fa;color:var(--navy);padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;display:inline-flex;align-items:center;gap:5px;border:1px solid var(--border);text-decoration:none;">
              <i class="fas fa-download"></i>CSV
            </a>
            ${info.hasData?`<button onclick="clearCSVData('${t.id}')" style="background:#fff;color:#991b1b;padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;border:1px solid #fca5a5;cursor:pointer;">
              <i class="fas fa-trash"></i>
            </button>`:""}
          </div>
        </div>
      </div>`;
    }).join("")}
  </div>

  <!-- Storage Info -->
  <div class="card" style="margin-top:12px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-hdd text-pri-500 mr-2"></i>Penggunaan Storan Pelayar</span></div>
    <div class="card-body" id="storage-info">${getStorageInfo()}</div>
  </div>`;
}

function getStorageInfo(){
  // Use in-memory counts — IndexedDB is async so we show what's loaded
  const tabs = [
    {id:"enrolmen", label:"Enrolmen",
     count: (window.ENROLMEN_LIVE||window.ENROLMEN_CSV||[]).length,
     date: localStorage.getItem("csv_enrolmen_date")||""},
    {id:"pkpp",     label:"PKPP",     count:(SHEETS_CACHE.pkpp||[]).length,  date:localStorage.getItem("csv_pkpp_date")||""},
    {id:"pkpw",     label:"PKPW",     count:(SHEETS_CACHE.pkpw||[]).length,  date:localStorage.getItem("csv_pkpw_date")||""},
    {id:"minda",    label:"Minda Sihat", count:(SHEETS_CACHE.minda||[]).length, date:localStorage.getItem("csv_minda_date")||""},
  ];
  const total = tabs.reduce((s,t)=>s+t.count,0);
  return `
  <div style="background:rgba(14,124,97,0.06);border:1px solid rgba(14,124,97,0.15);border-radius:8px;padding:10px 14px;margin-bottom:12px;font-size:12px;">
    <i class="fas fa-database" style="color:#0E7C61;margin-right:6px;"></i>
    <b>IndexedDB</b> — storan pelayar tanpa had saiz (gantikan localStorage 5MB)
    · Jumlah rekod dimuatkan: <b>${total.toLocaleString("ms-MY")}</b>
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
    ${tabs.map(t=>`<div style="text-align:center;background:#f8fafc;border-radius:6px;padding:10px;border:1px solid var(--border);">
      <div style="font-size:.72rem;color:var(--muted);margin-bottom:3px;">${t.label}</div>
      <div style="font-size:1rem;font-weight:800;color:${t.count>0?"#0E7C61":"#CBD5E1"};">${t.count>0?t.count.toLocaleString("ms-MY"):"—"}</div>
      <div style="font-size:.65rem;color:var(--muted);margin-top:2px;">${t.count>0?"rekod":"Kosong"}</div>
      ${t.date?`<div style="font-size:.6rem;color:#9CA3AF;margin-top:2px;">${t.date}</div>`:""}
    </div>`).join("")}
  </div>`;
}

function handleCSVUpload(input, tabId){
  if(tabId==="enrolmen"){
    importCSVEnrolmen(input, null);
  } else if(tabId==="pkpp"||tabId==="pkpw"){
    importCSVPKP(input, tabId, null);
  } else if(tabId==="minda"){
    importCSVMinda(input, null);
  } else if(tabId==="sesi"||tabId==="program"||tabId==="kaunselor"){
    importCSVKauns(input, tabId);
  }
  setTimeout(()=>navTo("au-csv"), 1200);
}

function clearCSVData(tabId){
  if(!confirm('Padam data CSV "'+tabId.toUpperCase()+'"? Data akan hilang dari storan pelayar.')) return;
  idbDelete("csv_"+tabId).then(()=>{
    if(tabId==="enrolmen"){ window.ENROLMEN_LIVE=null; window.ENROLMEN_CSV=null; _sheetsLoaded=false; }
    else if(tabId==="sesi"||tabId==="program"||tabId==="kaunselor"){ KAUNS_CACHE[tabId]=null; }
    else { SHEETS_CACHE[tabId]=null; }
    toast("Data "+tabId.toUpperCase()+" dipadam","ok");
    navTo("au-csv");
  });
}


