// ══════════════════════════════════════════
// LOAD / SAVE DATA
// ══════════════════════════════════════════
function loadApp(){
  try{const s=localStorage.getItem(SK);if(s)return{...DFLT,...JSON.parse(s)};}catch(e){}
  return JSON.parse(JSON.stringify(DFLT));
}
function saveApp(silent=false){
  localStorage.setItem(SK,JSON.stringify(APP));
  if(!silent) toast("Data disimpan","ok");
}
let APP=loadApp();

// Ensure kampusData populated for all 27
KAMPUS.forEach(k=>{
  if(!APP.kampusData[k.id])APP.kampusData[k.id]=genKampusData(k.id);
});

// ══════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════
let _charts={};
function destroyCharts(){Object.values(_charts).forEach(c=>{try{c.destroy();}catch(e){}});_charts={};}
function fmt(n){return Number(n).toLocaleString("ms-MY");}
function kNama(id){return KAMPUS.find(k=>k.id===id)?.nama||id;}
function kObj(id){return KAMPUS.find(k=>k.id===id)||{};}
function closeModal(){document.getElementById("modal-wrap").innerHTML="";}
function toast(msg,type="inf"){
  const w=document.getElementById("toast-wrap"),e=document.createElement("div");
  e.className=`toast ${type}`;
  e.innerHTML=`<i class="fas ${type==="ok"?"fa-check-circle":type==="err"?"fa-times-circle":"fa-info-circle"}"></i>${msg}`;
  w.appendChild(e);
  setTimeout(()=>{e.style.opacity="0";e.style.transform="translateY(8px)";e.style.transition="all .35s";setTimeout(()=>e.remove(),400);},3200);
}
function kampusOptgroup(selectedId=""){
  return KLIST.map(z=>`<optgroup label="${z}">${KAMPUS.filter(k=>k.zona===z).map(k=>`<option value="${k.id}"${k.id===selectedId?" selected":""}>${k.nama}</option>`).join("")}</optgroup>`).join("");
}
function avaBg(i){return["#B3E2D2","#FAE0BF","#C5CDE0","#fdd0d0","#d0e8fd","#e0d0fd"][i%6];}
function avaFg(i){return["#0B634D","#9A5A1E","#2E4070","#991b1b","#1e40af","#5b21b6"][i%6];}
function initials(n){return n.split(" ").slice(0,2).map(w=>w[0]).join("").toUpperCase();}

// ══════════════════════════════════════════
// SESSION STATE
// ══════════════════════════════════════════
let SES={role:null,nama:null,kampus:null,pg:null};

// ── ROLE HELPERS ──
function isAdmin(){ return SES.role==="admin_utama"; }
function isKampus(){ return SES.role==="admin_kampus"; }

// ── EXPORT HELPERS ──
function exportPDF(judulEl, contentEl){
  window.print();
}

function exportExcelFromTable(tableId, filename){
  const tbl = document.getElementById(tableId);
  if(!tbl){ toast("Jadual tidak dijumpai","err"); return; }
  let csv = "";
  const rows = tbl.querySelectorAll("tr");
  rows.forEach(row=>{
    const cols = row.querySelectorAll("th,td");
    const vals = Array.from(cols).map(c=>'"'+c.innerText.replace(/"/g,'""')+'"');
    csv += vals.join(",")+"\n";
  });
  const blob = new Blob(["\uFEFF"+csv],{type:"text/csv;charset=utf-8;"});
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement("a");
  a.href=url; a.download=(filename||"data")+".csv"; a.click();
  URL.revokeObjectURL(url);
  toast("Fail CSV berjaya dimuat turun","ok");
}

function exportPagePDF(){
  const style = document.createElement("style");
  style.id = "print-style";
  style.innerHTML = `
    @media print {
      .sidebar, .topbar, .btn, button, .card-head button,
      #modal-wrap, #toast-wrap, input, select { display:none !important; }
      .main-wrap { margin-left:0 !important; }
      .page-body { padding:8px !important; }
      .stat-card, .card { break-inside:avoid; }
      body { font-size:11px; }
    }
  `;
  document.head.appendChild(style);
  window.print();
  setTimeout(()=>{ const s=document.getElementById("print-style"); if(s)s.remove(); }, 1000);
}

// Export bar HTML untuk admin kampus (viewer mode)
function viewerExportBar(label, tableId){
  return `<div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:#f0f7f4;border-radius:8px;margin-bottom:12px;flex-wrap:wrap;">
    <i class="fas fa-eye" style="color:#0E7C61;"></i>
    <span style="font-size:12px;color:#0B634D;font-weight:600;">Mod Tontonan Sahaja</span>
    <span style="font-size:11px;color:#64748B;">— Data kampus ${kNama(SES.kampus)}</span>
    <div style="margin-left:auto;display:flex;gap:6px;">
      <button onclick="exportExcelFromTable('${tableId}','${label}')" class="btn btn-out btn-sm" style="font-size:11px;">
        <i class="fas fa-file-excel" style="color:#16A34A;"></i> Excel/CSV
      </button>
      <button onclick="exportPagePDF()" class="btn btn-ghost btn-sm" style="font-size:11px;">
        <i class="fas fa-file-pdf" style="color:#DC2626;"></i> PDF
      </button>
    </div>
  </div>`;
}

// ══════════════════════════════════════════
// PORTAL AWAM RENDER
// ══════════════════════════════════════════
function renderPortal(){
  // Hebahan
  const h=document.getElementById("pub-hebahan");
  const t=APP.hebahan.map(x=>`<span class="text-amb-800 text-sm font-medium mx-8"><i class="fas fa-chevron-right text-amb-400 mr-1 text-xs"></i>${x}</span>`).join("");
  h.innerHTML=t+t;

  // Pautan
  const secs=[{key:"pelajar",lbl:"Untuk Pelajar IPGKPM",ikon:"fa-user-graduate",w:"pri"},{key:"staf",lbl:"Untuk Pensyarah / Pegawai / AKP",ikon:"fa-users",w:"amb"}];
  document.getElementById("pub-pautan").innerHTML=secs.map((s,si)=>{
    const items=APP.pautan[s.key]||[];
    return`<div class="afu d${si+1}">
      <div class="flex items-center gap-2 mb-3"><div class="w-7 h-7 rounded-lg bg-${s.w}-100 flex items-center justify-center"><i class="fas ${s.ikon} text-${s.w}-600 text-xs"></i></div><h4 class="font-display font-700 text-${s.w}-700">${s.lbl}</h4></div>
      <div class="space-y-2">
        ${items.map(it=>`<div class="link-card" onclick="handleAksi('${it.aksi}')">
          <div class="lc-icon bg-${it.warna}-100 text-${it.warna}-600"><i class="fas ${it.ikon}"></i></div>
          <div class="flex-1"><div class="font-semibold text-sm">${it.nama}</div><div class="text-xs text-gray-400 mt-0.5">${it.desk}</div></div>
          <i class="fas fa-chevron-right text-gray-300 text-xs"></i>
        </div>`).join("")}
        <div class="link-card placeholder"><div class="lc-icon bg-gray-100 text-gray-300"><i class="fas fa-plus"></i></div><div class="text-sm text-gray-400 font-medium">Pautan Akan Datang</div></div>
      </div>
    </div>`;
  }).join("");

  // Sistem Berkaitan
  document.getElementById("pub-sys-berkaitan").innerHTML=(APP.sysBerkaitan||[]).map(s=>`
    <a href="${s.url}" class="link-card group">
      <div class="lc-icon bg-${s.warna}-100 text-${s.warna}-600 text-xl"><i class="fas ${s.ikon}"></i></div>
      <div class="flex-1">
        <div class="font-display font-700 text-sm text-navy-800 group-hover:text-pri-600 transition">${s.nama}</div>
        <div class="text-xs text-gray-400 mt-0.5">${s.desk}</div>
        <div class="text-xs text-pri-600 font-600 mt-1"><i class="fas fa-users mr-1"></i>${s.bil} &nbsp;·&nbsp; Kemaskini: ${s.tarikh}</div>
      </div>
      <i class="fas fa-arrow-right text-gray-300 text-sm group-hover:text-pri-500 transition"></i>
    </a>`).join("");

  // Hubungi
  document.getElementById("pub-hubungi").innerHTML=`
    <div class="flex items-start gap-3"><i class="fas fa-envelope text-pri-500 mt-0.5"></i><div><div class="font-semibold text-navy-800 mb-0.5">E-mel</div><div class="text-gray-500 text-xs">${APP.hubungi.emel}</div></div></div>
    <div class="flex items-start gap-3"><i class="fas fa-phone text-pri-500 mt-0.5"></i><div><div class="font-semibold text-navy-800 mb-0.5">Telefon</div><div class="text-gray-500 text-xs">${APP.hubungi.tel}</div></div></div>
    <div class="flex items-start gap-3"><i class="fas fa-map-marker-alt text-pri-500 mt-0.5"></i><div><div class="font-semibold text-navy-800 mb-0.5">Alamat</div><div class="text-gray-500 text-xs">${APP.hubungi.alamat}</div></div></div>`;
}

function handleAksi(a){
  if(a==="ujian")showUjianModal();
  else if(a==="temujanji")showTemujanjiModal();
  else if(a==="artikel")showArtikelModal();
  else toast("Akan tersedia tidak lama lagi","inf");
}

// ══════════════════════════════════════════
// LOGIN MODAL
// ══════════════════════════════════════════
function showLogin(){
  document.getElementById("modal-wrap").innerHTML=`
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:440px">
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-3">
          <div style="width:36px;height:36px;border-radius:8px;background:var(--pri);display:flex;align-items:center;justify-content:center;"><i class="fas fa-brain text-white text-sm"></i></div>
          <div><div class="font-display font-700 text-navy-800">Log Masuk Sistem</div><div class="text-xs text-gray-400">MyKaunseling IPGKPM</div></div>
        </div>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 text-lg"><i class="fas fa-times"></i></button>
      </div>

      <div class="space-y-4">
        <div>
          <label class="fl">Jenis Akaun</label>
          <select id="lg-role" class="fi" onchange="toggleLgKampus()">
            <option value="">— Pilih jenis akaun —</option>
            <option value="admin_kampus">Admin Kampus</option>
            <option value="admin_utama">Admin Utama (Kebangsaan)</option>
          </select>
        </div>
        <div id="lg-kampus-row" class="hidden">
          <label class="fl">Kampus</label>
          <select id="lg-kampus" class="fi"><option value="">— Pilih Kampus —</option>${kampusOptgroup()}</select>
        </div>
        <div>
          <label class="fl">ID Pengguna</label>
          <input type="text" id="lg-id" class="fi" placeholder="ID Pengguna">
        </div>
        <div>
          <label class="fl">Kata Laluan</label>
          <input type="password" id="lg-pw" class="fi" placeholder="Masukkan kata laluan">
        </div>
        
        <button onclick="doLogin()" class="btn btn-pri w-full justify-center"><i class="fas fa-sign-in-alt"></i>Log Masuk</button>
        <div style="display:flex;align-items:center;gap:10px;margin-top:12px;">
          <div style="flex:1;height:1px;background:var(--border);"></div>
          <span style="font-size:.72rem;color:var(--muted);">atau</span>
          <div style="flex:1;height:1px;background:var(--border);"></div>
        </div>
        <button onclick="demoLogin()" style="width:100%;margin-top:12px;padding:10px;border:2px dashed var(--border);border-radius:9px;background:transparent;cursor:pointer;font-size:.85rem;font-weight:600;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:8px;transition:all .2s;" onmouseover="this.style.borderColor='#0E7C61';this.style.color='#0E7C61'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
          <i class="fas fa-eye"></i> Cuba Mod Demo
        </button>
      </div>
    </div>
  </div>`;
}

function toggleLgKampus(){
  const r=document.getElementById("lg-role").value;
  document.getElementById("lg-kampus-row").classList.toggle("hidden",r!=="admin_kampus");
}

function demoLogin(){
  // Masuk sebagai Admin Utama demo tanpa tunjuk credentials
  const u = APP.pengguna.find(p=>p.id==="admin"&&p.peranan==="admin_utama");
  if(!u){ toast("Akaun demo tidak dijumpai","err"); return; }
  SES = { loggedIn:true, peranan:"admin_utama", id:"admin",
           nama:"Demo — Admin Utama", kampus:null, pg:"au-enrolmen", isDemo:true };
  saveApp();
  navTo("au-enrolmen");
  toast("Mod Demo — paparan sahaja","inf");
}

function doLogin(){
  const role=document.getElementById("lg-role").value;
  const id=document.getElementById("lg-id").value.trim();
  const pw=document.getElementById("lg-pw").value.trim();
  const kampus=document.getElementById("lg-kampus")?.value||null;
  if(!role){toast("Sila pilih jenis akaun","err");return;}
  if(!id||!pw){toast("Sila masukkan ID dan kata laluan","err");return;}
  if(role==="admin_kampus"&&!kampus){toast("Sila pilih kampus","err");return;}
  const u=APP.pengguna.find(x=>x.id===id&&x.kataLaluan===pw&&x.peranan===role);
  if(!u){toast("ID atau kata laluan tidak sah","err");return;}
  SES.role=role; SES.nama=u.nama;
  SES.kampus=role==="admin_kampus"?kampus:null;
  closeModal();
  document.getElementById("public-view").classList.add("hidden");
  document.getElementById("sys-view").classList.remove("hidden");
  initSys();
  toast(`Selamat datang, ${u.nama}`,"ok");
}

function doLogout(){
  SES={role:null,nama:null,kampus:null,pg:null};
  destroyCharts();
  document.getElementById("sys-view").classList.add("hidden");
  document.getElementById("public-view").classList.remove("hidden");
  toast("Anda telah log keluar","inf");
}

// ══════════════════════════════════════════
// INIT SISTEM DALAMAN
// ══════════════════════════════════════════
function initSys(){
  const isUtama=SES.role==="admin_utama";
  document.getElementById("sb-role-lbl").textContent=isUtama?"Admin Utama — Kebangsaan":"Admin Kampus";
  document.getElementById("sb-user-name").textContent=SES.nama;
  document.getElementById("sb-user-kampus").textContent=isUtama?"Semua 27 Kampus IPG":kNama(SES.kampus);

  const kc=document.getElementById("hdr-kampus-chip");
  if(!isUtama){kc.classList.remove("hidden");kc.style.display="flex";document.getElementById("hdr-kampus-txt").textContent=kNama(SES.kampus);}
  else{kc.classList.add("hidden");}

  // Build sidebar nav
  const nav=document.getElementById("sb-nav");
  if(isUtama){
    nav.innerHTML=`
      <div class="sb-section">Enrolmen</div>
      <div class="sb-link active" onclick="navTo('au-enrolmen')"><i class="fas fa-user-graduate"></i><span>Pelajar</span></div>
      <div class="sb-link" onclick="navTo('au-staf')"><i class="fas fa-id-badge"></i><span>Pensyarah & Pegawai</span></div>
      <div class="sb-link" onclick="navTo('au-kaunselor')"><i class="fas fa-user-tie"></i><span>Kaunselor</span></div>
      <div class="sb-section">Dashboard Psikologi</div>
      <div class="sb-link" onclick="navTo('au-pkpp')"><i class="fas fa-heart-pulse"></i><span>PKPP</span></div>
      <div class="sb-link" onclick="navTo('au-pkpw')"><i class="fas fa-user-shield"></i><span>PKPW</span></div>
      <div class="sb-link" onclick="navTo('au-minda')"><i class="fas fa-brain"></i><span>Minda Sihat</span></div>
      <div class="sb-link" onclick="navTo('au-kerjaya')"><i class="fas fa-compass"></i><span>Kerjaya</span></div>
      <div class="sb-section">Pengurusan Kaunseling</div>
      <div class="sb-link" onclick="navTo('au-sesi')"><i class="fas fa-calendar-check"></i><span>Analisis Sesi</span></div>
      <div class="sb-link" onclick="navTo('au-program')"><i class="fas fa-chalkboard-teacher"></i><span>Analisis Program</span></div>
      <div class="sb-section">Pengurusan Sistem</div>
      <div class="sb-link" onclick="navTo('au-hebahan')"><i class="fas fa-bullhorn"></i><span>Hebahan Portal</span></div>
      <div class="sb-link" onclick="navTo('au-maklumat-kampus')"><i class="fas fa-map-marker-alt"></i><span>Maklumat Kampus</span></div>
      <div class="sb-link" onclick="navTo('au-pengguna')"><i class="fas fa-users-cog"></i><span>Pengguna Sistem</span></div>
      <div class="sb-link" onclick="navTo('au-hubungi')"><i class="fas fa-address-book"></i><span>Maklumat Hubungi</span></div>
      <div class="sb-link" onclick="navTo('au-csv')"><i class="fas fa-database"></i><span>Urus Data CSV</span></div>
      <div class="sb-section">Dokumen</div>
      <div class="sb-link" onclick="navTo('au-dokumen')"><i class="fas fa-folder-open"></i><span>Muat Turun Dokumen</span></div>`;
    navTo("au-enrolmen");
  } else {
    nav.innerHTML=`
      <div class="sb-section">Enrolmen</div>
      <div class="sb-link active" onclick="navTo('ak-enrolmen')"><i class="fas fa-user-graduate"></i><span>Pelajar</span></div>
      <div class="sb-link" onclick="navTo('ak-staf')"><i class="fas fa-id-badge"></i><span>Pensyarah & Pegawai</span></div>
      <div class="sb-link" onclick="navTo('ak-kaunselor')"><i class="fas fa-user-tie"></i><span>Kaunselor</span></div>
      <div class="sb-section">Dashboard Psikologi</div>
      <div class="sb-link" onclick="navTo('ak-pkpp')"><i class="fas fa-heart-pulse"></i><span>PKPP — Kesejahteraan Pelajar</span></div>
      <div class="sb-link" onclick="navTo('ak-pkpw')"><i class="fas fa-user-shield"></i><span>PKPW — Kesejahteraan Warga</span></div>
      <div class="sb-link" onclick="navTo('ak-minda')"><i class="fas fa-brain"></i><span>Minda Sihat</span></div>
      <div class="sb-link" onclick="navTo('ak-kerjaya')"><i class="fas fa-compass"></i><span>Kerjaya</span></div>
      <div class="sb-section">Pengurusan Kaunseling</div>
      <div class="sb-link" onclick="navTo('ak-sesi')"><i class="fas fa-calendar-check"></i><span>Analisis Sesi</span></div>
      <div class="sb-link" onclick="navTo('ak-program')"><i class="fas fa-chalkboard-teacher"></i><span>Analisis Program</span></div>
      <div class="sb-section">Pengurusan Sistem</div>
      <div class="sb-link" onclick="navTo('ak-laporan')"><i class="fas fa-chart-bar"></i><span>Laporan Kampus</span></div>
      <div class="sb-section">Dokumen</div>
      <div class="sb-link" onclick="navTo('ak-dokumen')"><i class="fas fa-folder-open"></i><span>Muat Turun Dokumen</span></div>`;
    navTo("ak-enrolmen");
  }
}

function navTo(pg){
  SES.pg=pg;
  destroyCharts();
  document.querySelectorAll(".sb-link").forEach(e=>e.classList.remove("active"));
  document.querySelectorAll(".sb-link").forEach(e=>{if(e.getAttribute("onclick")?.includes(`'${pg}'`))e.classList.add("active");});
  const titles={
    "ak-dashboard":"Dashboard Kampus","ak-pelajar":"Rekod Pelajar","ak-staf":"Rekod Pensyarah & Pegawai","ak-laporan":"Laporan Kampus",
    "au-dashboard":"Dashboard Kebangsaan","au-kampus":"Semua Kampus","au-pelajar":"Data Pelajar","au-staf":"Data Pensyarah & Pegawai","au-laporan":"Laporan Kebangsaan",
    "ak-enrolmen":"Enrolmen — Pelajar",
    "ak-kaunselor":"Enrolmen — Kaunselor",
    "ak-kerjaya":"Kerjaya","ak-sesi":"Analisis Perkhidmatan Sesi","ak-program":"Analisis Program","au-sesi":"Analisis Perkhidmatan Sesi — Kebangsaan","au-program":"Analisis Program — Kebangsaan",
    "ak-dokumen":"Muat Turun Dokumen",
    "au-kaunselor":"Enrolmen — Kaunselor",
    "au-kerjaya":"Kerjaya",
    "au-dokumen":"Muat Turun Dokumen",
    "ak-pkpp":"PKPP — Profil Kesejahteraan & Personaliti Pelajar",
    "ak-pkpw":"PKPW — Profil Kesejahteraan & Personaliti Warga",
    "ak-minda":"Minda Sihat Pelajar",
    "au-enrolmen":"Enrolmen Pelajar — Kebangsaan",
    "au-pkpp":"PKPP — Kesejahteraan Pelajar (Kebangsaan)",
    "au-pkpw":"PKPW — Kesejahteraan Warga (Kebangsaan)",
    "au-minda":"Minda Sihat — Kebangsaan",
    "au-hebahan":"Pengurusan Hebahan","au-maklumat-kampus":"Maklumat Kampus","au-pengguna":"Pengurusan Pengguna","au-hubungi":"Maklumat Hubungi"
  };
  const crumbs={
    "ak-dashboard":"Admin Kampus / Dashboard","ak-pelajar":"Admin Kampus / Rekod Pelajar","ak-staf":"Admin Kampus / Enrolmen / Pensyarah & Pegawai","ak-laporan":"Admin Kampus / Laporan",
    "au-dashboard":"Admin Utama / Dashboard Kebangsaan","au-kampus":"Admin Utama / Semua Kampus","au-pelajar":"Admin Utama / Data Pelajar","au-staf":"Admin Utama / Enrolmen / Pensyarah & Pegawai","au-laporan":"Admin Utama / Laporan",
    "ak-enrolmen":"Admin Kampus / Enrolmen / Pelajar",
    "ak-kaunselor":"Admin Kampus / Enrolmen / Kaunselor",
    "ak-kerjaya":"Admin Kampus / Dashboard Psikologi / Kerjaya","ak-sesi":"Admin Kampus / Pengurusan Kaunseling / Sesi","ak-program":"Admin Kampus / Pengurusan Kaunseling / Program","au-sesi":"Admin Utama / Pengurusan Kaunseling / Sesi","au-program":"Admin Utama / Pengurusan Kaunseling / Program",
    "ak-dokumen":"Admin Kampus / Dokumen",
    "au-kaunselor":"Admin Utama / Enrolmen / Kaunselor",
    "au-kerjaya":"Admin Utama / Dashboard Psikologi / Kerjaya",
    "au-dokumen":"Admin Utama / Dokumen",
    "ak-pkpp":"Admin Kampus / Analisis / PKPP",
    "ak-pkpw":"Admin Kampus / Analisis / PKPW",
    "ak-minda":"Admin Kampus / Analisis / Minda Sihat",
    "au-enrolmen":"Admin Utama / Enrolmen / Pelajar",
    "au-pkpp":"Admin Utama / Analisis / PKPP",
    "au-pkpw":"Admin Utama / Analisis / PKPW",
    "au-minda":"Admin Utama / Analisis / Minda Sihat",
    "au-hebahan":"Admin Utama / Sistem / Hebahan","au-maklumat-kampus":"Admin Utama / Sistem / Maklumat Kampus","au-pengguna":"Admin Utama / Sistem / Pengguna","au-hubungi":"Admin Utama / Sistem / Hubungi"
  };
  document.getElementById("pg-title").textContent=titles[pg]||"";
  document.getElementById("pg-crumb").textContent=crumbs[pg]||"";
  const R={
    "ak-dashboard":pgAKDashboard,"ak-pelajar":pgAKPelajar,"ak-staf":pgAKStaf,"ak-laporan":pgAKLaporan,
    "au-dashboard":pgAUDashboard,"au-kampus":pgAUKampus,"au-pelajar":pgAUPelajar,"au-staf":pgAUStaf,"au-laporan":pgAULaporan,
    "ak-enrolmen":pgAKEnrolmen,
    "ak-kaunselor":pgAKKaunselor,
    "ak-kerjaya":pgKerjaya,
    "ak-dokumen":pgDokumen,
    "au-kaunselor":pgAUKaunselor,
    "au-kerjaya":pgKerjaya,"ak-sesi":pgAKSesi,"ak-program":pgAKProgram,"au-sesi":pgAUSesi,"au-program":pgAUProgram,
    "au-dokumen":pgDokumen,
    "ak-pkpp":pgAKPKPP,
    "ak-pkpw":pgAKPKPW,
    "ak-minda":pgAKMinda,
    "au-enrolmen":pgAUEnrolmen,
    "au-pkpp":pgAUPKPP,
    "au-pkpw":pgAUPKPW,
    "au-minda":pgAUMinda,
    "au-hebahan":pgAUHebahan,"au-maklumat-kampus":pgAUMaklumatKampus,"au-pengguna":pgAUPengguna,"au-hubungi":pgAUHubungi,"au-csv":pgAUCSV
  };
  const c=document.getElementById("pg-body");
  if(R[pg])R[pg](c);else c.innerHTML="<p class='text-gray-400'>Halaman tidak dijumpai.</p>";
  closeSb();
}

// ══════════════════════════════════════════
// ADMIN KAMPUS — PAGES
// ══════════════════════════════════════════
function pgAKDashboard(c){
  const kd=APP.kampusData[SES.kampus];
  const k=kObj(SES.kampus);
  const tP=kd.pelajar.length, tT=kd.pensyarah.length, tO=kd.pegawai.length;
  const perluTindak=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length+kd.pensyarah.filter(p=>p.statusK.includes("Perlu")).length;
  c.innerHTML=`
  <div class="afu bg-gradient-to-br from-navy-800 to-pri-700 rounded-xl p-5 mb-5 text-white relative overflow-hidden">
    <div class="absolute right-0 top-0 w-40 h-40 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/4"></div>
    <div class="relative z-10">
      <div class="text-white/50 text-xs mb-1">${k.zona} &nbsp;·&nbsp; ${k.negeri}</div>
      <div class="font-display font-800 text-xl">${k.nama}</div>
      <div class="text-white/55 text-sm mt-1">Dashboard Pengurusan Kaunseling</div>
    </div>
  </div>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    ${[
      {l:"Jumlah Pelajar",v:tP,i:"fa-user-graduate",c:"sc-pri",bg:"bg-pri-50",fg:"text-pri-600"},
      {l:"Pensyarah & Pegawai",v:tT+tO,i:"fa-id-badge",c:"sc-navy",bg:"bg-navy-50",fg:"text-navy-600"},
      {l:"Sesi Kaunseling",v:kd.statsesi,i:"fa-comments",c:"sc-amb",bg:"bg-amb-50",fg:"text-amb-600"},
      {l:"Perlu Tindak Lanjut",v:perluTindak,i:"fa-triangle-exclamation",c:"sc-red",bg:"bg-red-50",fg:"text-red-500"}
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div class="stat-val">${fmt(s.v)}</div>
      <div class="stat-lbl">${s.l}</div>
    </div>`).join("")}
  </div>
  <div class="grid lg:grid-cols-2 gap-4 mb-4">
    <div class="card">
      <div class="card-head"><span class="card-title">Status Kaunseling Pelajar</span></div>
      <div class="card-body"><canvas id="ch-status" height="220"></canvas></div>
    </div>
    <div class="card">
      <div class="card-head"><span class="card-title">Pelajar Perlu Tindak Lanjut</span><span class="bdg bdg-red">${perluTindak} kes</span></div>
      <div class="card-body">
        ${kd.pelajar.filter(p=>p.statusK.includes("Perlu")).map(p=>`
        <div class="flex items-center gap-3 py-2 border-b border-gray-100 last:border-0">
          <div class="ava" style="background:${avaBg(0)};color:${avaFg(0)}">${initials(p.nama)}</div>
          <div class="flex-1 min-w-0"><div class="text-sm font-medium truncate">${p.nama}</div><div class="text-xs text-gray-400">${p.noMatrik} &nbsp;·&nbsp; ${p.program}</div></div>
          <span class="bdg bdg-amber">Susulan</span>
        </div>`).join("")||"<p class='text-sm text-gray-400 py-3 text-center'>Tiada kes perlu tindak lanjut</p>"}
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-head"><span class="card-title">Rekod Terkini Pelajar</span><button class="btn btn-out btn-sm" onclick="navTo('ak-pelajar')">Lihat Semua</button></div>
    <div class="overflow-x-auto"><table class="tbl">
      <thead><tr><th>Nama</th><th>Matrik</th><th>Program</th><th>Semester</th><th>Sesi</th><th>Status</th></tr></thead>
      <tbody>${kd.pelajar.slice(0,5).map((p,i)=>`<tr>
        <td><div class="flex items-center gap-2"><div class="ava" style="background:${avaBg(i)};color:${avaFg(i)}">${initials(p.nama)}</div><span class="font-medium">${p.nama}</span></div></td>
        <td class="font-mono text-xs">${p.noMatrik}</td><td>${p.program}</td><td>${p.semester}</td><td>${p.sesiCount}</td>
        <td><span class="bdg ${p.statusK.includes("Perlu")?"bdg-amber":"bdg-green"}">${p.statusK.includes("Perlu")?"Perlu Susulan":"Normal"}</span></td>
      </tr>`).join("")}</tbody>
    </table></div>
  </div>`;
  setTimeout(()=>{
    const normal=kd.pelajar.filter(p=>!p.statusK.includes("Perlu")).length;
    const susulan=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;
    _charts.status=new Chart(document.getElementById("ch-status"),{type:"doughnut",data:{labels:["Normal","Perlu Susulan"],datasets:[{data:[normal,susulan],backgroundColor:["#0E7C61","#E88D3A"],borderWidth:0,hoverOffset:6}]},options:{responsive:true,cutout:"65%",plugins:{legend:{position:"bottom"}}}});
  },80);
}

function pgAKPelajar(c){
  const kd=APP.kampusData[SES.kampus];
  let data=[...kd.pelajar];
  c.innerHTML=`
  ${viewerExportBar("Rekod_Pelajar_"+SES.kampus, "tbl-pelajar-main")}
  <div class="card mb-4">
    <div class="card-head">
      <span class="card-title">Rekod Pelajar — ${kNama(SES.kampus)}</span>
    </div>
    <div class="card-body pb-2">
      <div class="flex flex-wrap gap-2 mb-3">
        <input type="text" class="fi" style="max-width:220px" placeholder="Cari nama / matrik..." id="cari-pelajar" oninput="filterPelajar()">
        <select class="fi" style="width:auto" id="filter-prog" onchange="filterPelajar()">
          <option value="">Semua Program</option>
          <option>PISMP</option><option>DPLI</option><option>BPisMP</option>
        </select>
        <select class="fi" style="width:auto" id="filter-status" onchange="filterPelajar()">
          <option value="">Semua Status</option>
          <option value="susulan">Perlu Susulan</option>
          <option value="normal">Normal</option>
        </select>
      </div>
    </div>
    <div class="overflow-x-auto" id="tbl-pelajar">${renderTblPelajar(data)}</div>
  </div>`;
  window._dataPelajar=data;
}

function filterPelajar(){
  let d=window._dataPelajar||[];
  const q=document.getElementById("cari-pelajar")?.value.toLowerCase()||"";
  const prog=document.getElementById("filter-prog")?.value||"";
  const sts=document.getElementById("filter-status")?.value||"";
  if(q)d=d.filter(p=>p.nama.toLowerCase().includes(q)||p.noMatrik.toLowerCase().includes(q));
  if(prog)d=d.filter(p=>p.program===prog);
  if(sts==="susulan")d=d.filter(p=>p.statusK.includes("Perlu"));
  if(sts==="normal")d=d.filter(p=>!p.statusK.includes("Perlu"));
  document.getElementById("tbl-pelajar").innerHTML=renderTblPelajar(d);
}

function renderTblPelajar(data){
  if(!data.length)return`<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod ditemui.</p>`;
  return`<table class="tbl"><thead><tr><th>Nama</th><th>No. Matrik</th><th>Program</th><th>Sem</th><th>Ujian Terakhir</th><th>Skor</th><th>Sesi</th><th>Status</th><th></th></tr></thead>
  <tbody>${data.map((p,i)=>`<tr>
    <td><div class="flex items-center gap-2"><div class="ava" style="background:${avaBg(i)};color:${avaFg(i)}">${initials(p.nama)}</div><span class="font-medium whitespace-nowrap">${p.nama}</span></div></td>
    <td class="font-mono text-xs">${p.noMatrik}</td><td>${p.program}</td><td>${p.semester}</td>
    <td class="text-xs">${p.ujianTerakhir}</td>
    <td><span class="bdg ${p.skor>=70?"bdg-green":p.skor>=50?"bdg-amber":"bdg-red"}">${p.skor}%</span></td>
    <td>${p.sesiCount}</td>
    <td><span class="bdg ${p.statusK.includes("Perlu")?"bdg-amber":"bdg-green"}">${p.statusK.includes("Perlu")?"Susulan":"Normal"}</span></td>

  </tr>`).join("")}</tbody></table>`;
}

function modalTambahPelajar(){
  document.getElementById("modal-wrap").innerHTML=`
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:520px">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display font-700 text-lg text-navy-800">Tambah Rekod Pelajar</h3>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
      </div>
      <div class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div><label class="fl">Nama Penuh</label><input type="text" id="np-nama" class="fi" placeholder="Nama penuh pelajar"></div>
          <div><label class="fl">No. Matrik</label><input type="text" id="np-matrik" class="fi" placeholder="Contoh: KPI2024001"></div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div><label class="fl">Program</label><select id="np-prog" class="fi"><option>PISMP</option><option>DPLI</option><option>BPisMP</option></select></div>
          <div><label class="fl">Semester</label><select id="np-sem" class="fi">${[1,2,3,4,5,6,7,8].map(s=>`<option>${s}</option>`).join("")}</select></div>
          <div><label class="fl">Status Kaunseling</label><select id="np-sts" class="fi"><option value="Normal">Normal</option><option value="Aktif — Perlu Susulan">Perlu Susulan</option></select></div>
        </div>
        <div class="flex gap-3 pt-2">
          <button onclick="closeModal()" class="btn btn-ghost flex-1 justify-center">Batal</button>
          <button onclick="simpanPelajar()" class="btn btn-pri flex-1 justify-center"><i class="fas fa-save"></i>Simpan</button>
        </div>
      </div>
    </div>
  </div>`;
}

function simpanPelajar(){
  const kd=APP.kampusData[SES.kampus];
  const nama=document.getElementById("np-nama").value.trim();
  const matrik=document.getElementById("np-matrik").value.trim();
  if(!nama||!matrik){toast("Nama dan matrik diperlukan","err");return;}
  const np={id:`${SES.kampus}-P${Date.now()}`,nama,noMatrik:matrik,program:document.getElementById("np-prog").value,semester:document.getElementById("np-sem").value,statusK:document.getElementById("np-sts").value,sesiCount:0,ujianTerakhir:"—",skor:0};
  kd.pelajar.push(np);
  saveApp(); closeModal(); navTo("ak-pelajar"); toast("Rekod pelajar ditambah","ok");
}

function modalEditPelajar(kid,pid){
  const kd=APP.kampusData[kid];
  const p=kd.pelajar.find(x=>x.id===pid);
  if(!p)return;
  document.getElementById("modal-wrap").innerHTML=`
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:520px">
      <div class="flex items-center justify-between mb-5">
        <h3 class="font-display font-700 text-lg text-navy-800">Edit Rekod Pelajar</h3>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
      </div>
      <div class="space-y-3">
        <div class="grid grid-cols-2 gap-3">
          <div><label class="fl">Nama Penuh</label><input type="text" id="ep-nama" class="fi" value="${p.nama}"></div>
          <div><label class="fl">No. Matrik</label><input type="text" id="ep-matrik" class="fi" value="${p.noMatrik}"></div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div><label class="fl">Program</label><select id="ep-prog" class="fi"><option${p.program==="PISMP"?" selected":""}>PISMP</option><option${p.program==="DPLI"?" selected":""}>DPLI</option><option${p.program==="BPisMP"?" selected":""}>BPisMP</option></select></div>
          <div><label class="fl">Semester</label><select id="ep-sem" class="fi">${[1,2,3,4,5,6,7,8].map(s=>`<option${String(s)===p.semester?" selected":""}>${s}</option>`).join("")}</select></div>
          <div><label class="fl">Status</label><select id="ep-sts" class="fi"><option value="Normal"${p.statusK==="Normal"?" selected":""}>Normal</option><option value="Aktif — Perlu Susulan"${p.statusK.includes("Perlu")?" selected":""}>Perlu Susulan</option></select></div>
        </div>
        <div class="flex gap-3 pt-2">
          <button onclick="hapusPelajar('${kid}','${pid}')" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i>Padam</button>
          <div class="flex-1"></div>
          <button onclick="closeModal()" class="btn btn-ghost">Batal</button>
          <button onclick="kemaskiniPelajar('${kid}','${pid}')" class="btn btn-pri"><i class="fas fa-save"></i>Simpan</button>
        </div>
      </div>
    </div>
  </div>`;
}

function kemaskiniPelajar(kid,pid){
  const kd=APP.kampusData[kid];
  const p=kd.pelajar.find(x=>x.id===pid);
  p.nama=document.getElementById("ep-nama").value.trim();
  p.noMatrik=document.getElementById("ep-matrik").value.trim();
  p.program=document.getElementById("ep-prog").value;
  p.semester=document.getElementById("ep-sem").value;
  p.statusK=document.getElementById("ep-sts").value;
  saveApp(); closeModal(); navTo(SES.pg); toast("Rekod dikemaskini","ok");
}

function hapusPelajar(kid,pid){
  if(!confirm("Padam rekod ini?"))return;
  APP.kampusData[kid].pelajar=APP.kampusData[kid].pelajar.filter(x=>x.id!==pid);
  saveApp(); closeModal(); navTo(SES.pg); toast("Rekod dipadam","ok");
}

function pgAKStaf(c){
  c.innerHTML = `<div style="text-align:center;padding:60px 24px;color:var(--muted);">
      <i class="fas fa-id-badge" style="font-size:48px;display:block;margin-bottom:16px;opacity:.15;"></i>
      <div style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:6px;">Data Belum Tersedia</div>
      <div style="font-size:13px;">Data enrolmen pensyarah &amp; staf sedang dalam proses pengemaskinian.</div>
      <div style="font-size:12px;margin-top:6px;color:#94a3b8;">Sila hubungi Admin Utama untuk maklumat lanjut.</div>
    </div>`;
}

function pgAKLaporan(c){
  const kd=APP.kampusData[SES.kampus];
  const k=kObj(SES.kampus);
  const tP=kd.pelajar.length, tT=kd.pensyarah.length, tO=kd.pegawai.length;
  const susulan=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;
  c.innerHTML=`
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 mb-5">
    ${[
      {l:"Jumlah Pelajar",v:tP,sub:"Berdaftar dalam sistem"},
      {l:"Pensyarah Aktif",v:tT,sub:"Rekod dikemaskini"},
      {l:"Pegawai",v:tO,sub:"Berdaftar dalam sistem"},
      {l:"Sesi Kaunseling",v:kd.statsesi,sub:"Sepanjang sesi ini"},
      {l:"Temujanji Aktif",v:kd.statemujanji,sub:"Dijadualkan"},
      {l:"Kes Perlu Susulan",v:susulan,sub:"Memerlukan tindakan"}
    ].map(s=>`<div class="card"><div class="card-body"><div class="text-xs text-gray-400 mb-1">${s.l}</div><div class="font-display font-800 text-2xl text-navy-800">${fmt(s.v)}</div><div class="text-xs text-gray-400 mt-1">${s.sub}</div></div></div>`).join("")}
  </div>
  <div class="grid lg:grid-cols-2 gap-4">
    <div class="card"><div class="card-head"><span class="card-title">Taburan Skor Ujian</span></div><div class="card-body"><canvas id="ch-skor" height="230"></canvas></div></div>
    <div class="card"><div class="card-head"><span class="card-title">Jana Laporan</span></div>
      <div class="card-body space-y-3">
        ${["Laporan Bulanan Kaunseling","Laporan Rekod Pelajar","Laporan Rekod Pensyarah","Laporan Kes Susulan","Laporan Statistik Kampus"].map(l=>`
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 text-sm font-medium text-navy-800"><i class="fas fa-file-lines text-pri-500"></i>${l}</div>
          <button class="btn btn-out btn-xs" onclick="toast('Laporan dijana','ok')"><i class="fas fa-download"></i>Jana</button>
        </div>`).join("")}
      </div>
    </div>
  </div>`;
  setTimeout(()=>{
    const scores=kd.pelajar.map(p=>p.skor);
    const bins=[0,0,0,0,0];
    scores.forEach(s=>{if(s<40)bins[0]++;else if(s<55)bins[1]++;else if(s<70)bins[2]++;else if(s<85)bins[3]++;else bins[4]++;});
    _charts.skor=new Chart(document.getElementById("ch-skor"),{type:"bar",data:{labels:["<40","40–54","55–69","70–84","85+"],datasets:[{data:bins,backgroundColor:["#EF4444","#F97316","#FBBF24","#34D399","#0E7C61"],borderRadius:5}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{stepSize:1}}}}});
  },80);
}

// ══════════════════════════════════════════
// ADMIN UTAMA — PAGES
// ══════════════════════════════════════════
function pgAUDashboard(c){
  let tP=0,tT=0,tO=0,tS=0,susulan=0;
  KAMPUS.forEach(k=>{const kd=APP.kampusData[k.id];tP+=kd.pelajar.length;tT+=kd.pensyarah.length;tO+=kd.pegawai.length;tS+=kd.statsesi;susulan+=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;});
  c.innerHTML=`
  <div class="afu bg-gradient-to-br from-navy-900 to-navy-700 rounded-xl p-5 mb-5 text-white relative overflow-hidden">
    <div class="absolute right-0 top-0 w-48 h-48 bg-white/5 rounded-full -translate-y-1/3 translate-x-1/4"></div>
    <div class="relative z-10">
      <div class="text-white/45 text-xs mb-1">Admin Utama</div>
      <div class="font-display font-800 text-xl">Dashboard Kebangsaan — MyKaunseling IPGM</div>
      <div class="text-white/50 text-sm mt-1">Paparan keseluruhan 27 Kampus IPG seluruh Malaysia</div>
    </div>
  </div>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    ${[
      {l:"Jumlah Pelajar",v:tP,i:"fa-user-graduate",c:"sc-pri",bg:"bg-pri-50",fg:"text-pri-600"},
      {l:"Pensyarah & Pegawai",v:tT+tO,i:"fa-id-badge",c:"sc-navy",bg:"bg-navy-50",fg:"text-navy-600"},
      {l:"Sesi Kaunseling",v:tS,i:"fa-comments",c:"sc-amb",bg:"bg-amb-50",fg:"text-amb-600"},
      {l:"Kes Perlu Susulan",v:susulan,i:"fa-triangle-exclamation",c:"sc-red",bg:"bg-red-50",fg:"text-red-500"}
    ].map((s,i)=>`
    <div class="stat-card ${s.c} afu d${i+1}">
      <div class="stat-icon ${s.bg}"><i class="fas ${s.i} ${s.fg}"></i></div>
      <div class="stat-val">${fmt(s.v)}</div>
      <div class="stat-lbl">${s.l}</div>
    </div>`).join("")}
  </div>
  <div class="grid lg:grid-cols-2 gap-4 mb-4">
    <div class="card"><div class="card-head"><span class="card-title">Bilangan Pelajar mengikut Zon</span></div><div class="card-body"><canvas id="ch-zon" height="240"></canvas></div></div>
    <div class="card"><div class="card-head"><span class="card-title">Sesi Kaunseling mengikut Zon</span></div><div class="card-body"><canvas id="ch-sesi" height="240"></canvas></div></div>
  </div>
  <div class="card">
    <div class="card-head"><span class="card-title">Ringkasan Semua Kampus</span><button class="btn btn-out btn-sm" onclick="navTo('au-kampus')">Lihat Semua</button></div>
    <div class="overflow-x-auto"><table class="tbl">
      <thead><tr><th>Kampus</th><th>Zon</th><th>Negeri</th><th>Pelajar</th><th>Pensyarah</th><th>Sesi</th><th>Kes Susulan</th></tr></thead>
      <tbody>${KAMPUS.slice(0,8).map(k=>{const kd=APP.kampusData[k.id];const sl=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;return`<tr>
        <td class="font-medium whitespace-nowrap">${k.nama.replace("IPG Kampus ","")}</td>
        <td><span class="bdg bdg-navy">${k.zona}</span></td>
        <td class="text-xs">${k.negeri}</td>
        <td>${kd.pelajar.length}</td><td>${kd.pensyarah.length}</td><td>${kd.statsesi}</td>
        <td>${sl>0?`<span class="bdg bdg-amber">${sl}</span>`:`<span class="bdg bdg-green">0</span>`}</td>
      </tr>`;}).join("")}</tbody>
    </table></div>
  </div>`;
  setTimeout(()=>{
    const zonaData=KLIST.map(z=>{const ks=KAMPUS.filter(k=>k.zona===z);return{z,p:ks.reduce((a,k)=>a+APP.kampusData[k.id].pelajar.length,0),s:ks.reduce((a,k)=>a+APP.kampusData[k.id].statsesi,0)};});
    _charts.zon=new Chart(document.getElementById("ch-zon"),{type:"bar",data:{labels:zonaData.map(d=>d.z.replace("Zon ","")),datasets:[{data:zonaData.map(d=>d.p),backgroundColor:["#0E7C61","#3B82F6","#E88D3A","#8B5CF6","#EF4444","#14B8A6"],borderRadius:5}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true}}}});
    _charts.sesi=new Chart(document.getElementById("ch-sesi"),{type:"doughnut",data:{labels:zonaData.map(d=>d.z.replace("Zon ","")),datasets:[{data:zonaData.map(d=>d.s),backgroundColor:["#0E7C61","#3B82F6","#E88D3A","#8B5CF6","#EF4444","#14B8A6"],borderWidth:0,hoverOffset:8}]},options:{responsive:true,cutout:"60%",plugins:{legend:{position:"bottom",labels:{boxWidth:10,font:{size:11}}}}}});
  },80);
}

function pgAUKampus(c){
  c.innerHTML=`
  <div class="mb-4 flex gap-2 flex-wrap">
    <select class="fi" style="width:auto" id="f-zon" onchange="filterKampus()">
      <option value="">Semua Zon</option>
      ${KLIST.map(z=>`<option>${z}</option>`).join("")}
    </select>
  </div>
  <div class="grid lg:grid-cols-2 gap-3" id="kampus-grid">${renderKampusGrid(KAMPUS)}</div>`;
}

function filterKampus(){
  const z=document.getElementById("f-zon").value;
  const data=z?KAMPUS.filter(k=>k.zona===z):KAMPUS;
  document.getElementById("kampus-grid").innerHTML=renderKampusGrid(data);
}

function renderKampusGrid(data){
  return data.map(k=>{
    const kd=APP.kampusData[k.id];
    const sl=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;
    return`<div class="card hover:shadow-md transition cursor-pointer" onclick="lihatKampusDetail('${k.id}')">
      <div class="card-body">
        <div class="flex items-start justify-between mb-3">
          <div>
            <div class="font-display font-700 text-navy-800 text-sm">${k.nama}</div>
            <div class="text-xs text-gray-400 mt-0.5">${k.zona} &nbsp;·&nbsp; ${k.negeri}</div>
          </div>
          ${sl>0?`<span class="bdg bdg-amber">${sl} susulan</span>`:`<span class="bdg bdg-green">Normal</span>`}
        </div>
        <div class="grid grid-cols-3 gap-2 text-center">
          <div class="bg-pri-50 rounded-lg p-2"><div class="font-display font-700 text-pri-700">${kd.pelajar.length}</div><div class="text-xs text-gray-400">Pelajar</div></div>
          <div class="bg-navy-50 rounded-lg p-2"><div class="font-display font-700 text-navy-700">${kd.pensyarah.length+kd.pegawai.length}</div><div class="text-xs text-gray-400">Staf</div></div>
          <div class="bg-amb-50 rounded-lg p-2"><div class="font-display font-700 text-amb-700">${kd.statsesi}</div><div class="text-xs text-gray-400">Sesi</div></div>
        </div>
      </div>
    </div>`;
  }).join("");
}

function lihatKampusDetail(kid){
  const k=kObj(kid); const kd=APP.kampusData[kid];
  document.getElementById("modal-wrap").innerHTML=`
  <div class="modal-bg" onclick="if(event.target===this)closeModal()">
    <div class="modal-box" style="max-width:680px">
      <div class="flex items-center justify-between mb-4">
        <div><h3 class="font-display font-700 text-lg text-navy-800">${k.nama}</h3><div class="text-xs text-gray-400">${k.zona} · ${k.negeri}</div></div>
        <button onclick="closeModal()" class="text-gray-400"><i class="fas fa-times"></i></button>
      </div>
      <div class="grid grid-cols-3 gap-3 mb-4">
        <div class="bg-pri-50 rounded-lg p-3 text-center"><div class="font-display font-700 text-xl text-pri-700">${kd.pelajar.length}</div><div class="text-xs text-gray-500">Pelajar</div></div>
        <div class="bg-navy-50 rounded-lg p-3 text-center"><div class="font-display font-700 text-xl text-navy-700">${kd.pensyarah.length}</div><div class="text-xs text-gray-500">Pensyarah</div></div>
        <div class="bg-amb-50 rounded-lg p-3 text-center"><div class="font-display font-700 text-xl text-amb-700">${kd.pegawai.length}</div><div class="text-xs text-gray-500">Pegawai</div></div>
      </div>
      <div class="mb-3"><div class="font-semibold text-sm text-navy-800 mb-2">Pelajar Terkini</div>${renderTblPelajar(kd.pelajar.slice(0,4))}</div>
    </div>
  </div>`;
}

function pgAUPelajar(c){
  let allPelajar=[];
  KAMPUS.forEach(k=>allPelajar.push(...APP.kampusData[k.id].pelajar.map(p=>({...p,kampusNama:k.nama,kampusId:k.id}))));
  c.innerHTML=`
  <div class="card">
    <div class="card-head"><span class="card-title">Data Pelajar — Semua Kampus</span><span class="bdg bdg-navy">${allPelajar.length} rekod</span></div>
    <div class="card-body pb-2">
      <div class="flex flex-wrap gap-2 mb-3">
        <input type="text" class="fi" style="max-width:200px" placeholder="Cari nama / matrik..." id="cau-cari" oninput="filterAUPelajar()">
        <select class="fi" style="width:auto" id="cau-kampus" onchange="filterAUPelajar()"><option value="">Semua Kampus</option>${kampusOptgroup()}</select>
        <select class="fi" style="width:auto" id="cau-sts" onchange="filterAUPelajar()"><option value="">Semua Status</option><option value="susulan">Perlu Susulan</option><option value="normal">Normal</option></select>
      </div>
    </div>
    <div class="overflow-x-auto" id="tbl-au-pelajar">${renderTblAUPelajar(allPelajar.slice(0,20))}</div>
    <div class="card-body pt-2 text-xs text-gray-400">Menunjukkan ${Math.min(20,allPelajar.length)} daripada ${allPelajar.length} rekod</div>
  </div>`;
  window._auPelajar=allPelajar;
}

function filterAUPelajar(){
  let d=window._auPelajar||[];
  const q=document.getElementById("cau-cari")?.value.toLowerCase()||"";
  const kid=document.getElementById("cau-kampus")?.value||"";
  const sts=document.getElementById("cau-sts")?.value||"";
  if(q)d=d.filter(p=>p.nama.toLowerCase().includes(q)||p.noMatrik.toLowerCase().includes(q));
  if(kid)d=d.filter(p=>p.kampusId===kid);
  if(sts==="susulan")d=d.filter(p=>p.statusK.includes("Perlu"));
  if(sts==="normal")d=d.filter(p=>!p.statusK.includes("Perlu"));
  document.getElementById("tbl-au-pelajar").innerHTML=renderTblAUPelajar(d.slice(0,30));
}

function renderTblAUPelajar(data){
  if(!data.length)return`<p class="text-sm text-gray-400 p-4 text-center">Tiada rekod ditemui.</p>`;
  return`<table class="tbl"><thead><tr><th>Nama</th><th>Matrik</th><th>Kampus</th><th>Program</th><th>Skor</th><th>Status</th><th></th></tr></thead>
  <tbody>${data.map((p,i)=>`<tr>
    <td><div class="flex items-center gap-2"><div class="ava" style="background:${avaBg(i)};color:${avaFg(i)}">${initials(p.nama)}</div><span class="font-medium">${p.nama}</span></div></td>
    <td class="font-mono text-xs">${p.noMatrik}</td>
    <td class="text-xs">${(p.kampusNama||"").replace("IPG Kampus ","")}</td>
    <td>${p.program}</td>
    <td><span class="bdg ${p.skor>=70?"bdg-green":p.skor>=50?"bdg-amber":"bdg-red"}">${p.skor}%</span></td>
    <td><span class="bdg ${p.statusK.includes("Perlu")?"bdg-amber":"bdg-green"}">${p.statusK.includes("Perlu")?"Susulan":"Normal"}</span></td>
    ${isAdmin()?`<td><button class="btn btn-ghost btn-xs" onclick="modalEditPelajar('${p.kampusId}','${p.id}')"><i class="fas fa-pen"></i></button></td>`:"<td></td>"}
  </tr>`).join("")}</tbody></table>`;
}

function pgAUStaf(c){
  c.innerHTML = `<div style="text-align:center;padding:60px 24px;color:var(--muted);">
      <i class="fas fa-id-badge" style="font-size:48px;display:block;margin-bottom:16px;opacity:.15;"></i>
      <div style="font-size:15px;font-weight:700;color:var(--navy);margin-bottom:6px;">Data Belum Tersedia</div>
      <div style="font-size:13px;">Data enrolmen pensyarah &amp; staf sedang dalam proses pengemaskinian.</div>
      <div style="font-size:12px;margin-top:6px;color:#94a3b8;">Sila hubungi Admin Utama untuk maklumat lanjut.</div>
    </div>`;
}

function pgAULaporan(c){
  let tP=0,tT=0,tO=0,tS=0,sl=0;
  KAMPUS.forEach(k=>{const kd=APP.kampusData[k.id];tP+=kd.pelajar.length;tT+=kd.pensyarah.length;tO+=kd.pegawai.length;tS+=kd.statsesi;sl+=kd.pelajar.filter(p=>p.statusK.includes("Perlu")).length;});
  c.innerHTML=`
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 mb-5">
    ${[{l:"Jumlah Pelajar",v:tP},{l:"Jumlah Pensyarah",v:tT},{l:"Jumlah Pegawai",v:tO},{l:"Sesi Kaunseling",v:tS},{l:"Kampus Aktif",v:27},{l:"Kes Perlu Susulan",v:sl}].map(s=>`<div class="card"><div class="card-body"><div class="text-xs text-gray-400 mb-1">${s.l}</div><div class="font-display font-800 text-2xl text-navy-800">${fmt(s.v)}</div></div></div>`).join("")}
  </div>
  <div class="grid lg:grid-cols-2 gap-4">
    <div class="card"><div class="card-head"><span class="card-title">Perbandingan Pelajar & Sesi Mengikut Zon</span></div><div class="card-body"><canvas id="ch-au-zon" height="260"></canvas></div></div>
    <div class="card"><div class="card-head"><span class="card-title">Jana Laporan Kebangsaan</span></div>
      <div class="card-body space-y-3">
        ${["Laporan Kebangsaan Kaunseling","Laporan Semua Kampus","Laporan Data Pelajar Kebangsaan","Laporan Data Pensyarah","Laporan Kes Kritikal","Laporan Tahunan IPGM"].map(l=>`
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg border border-gray-100">
          <div class="flex items-center gap-2 text-sm font-medium text-navy-800"><i class="fas fa-file-chart-column text-pri-500"></i>${l}</div>
          <button class="btn btn-out btn-xs" onclick="toast('Laporan dijana','ok')"><i class="fas fa-download"></i>Jana</button>
        </div>`).join("")}
      </div>
    </div>
  </div>`;
  setTimeout(()=>{
    const zd=KLIST.map(z=>{const ks=KAMPUS.filter(k=>k.zona===z);return{z:z.replace("Zon ",""),p:ks.reduce((a,k)=>a+APP.kampusData[k.id].pelajar.length,0),s:ks.reduce((a,k)=>a+APP.kampusData[k.id].statsesi,0)};});
    _charts.auzon=new Chart(document.getElementById("ch-au-zon"),{type:"bar",data:{labels:zd.map(d=>d.z),datasets:[{label:"Pelajar",data:zd.map(d=>d.p),backgroundColor:"rgba(14,124,97,0.75)",borderRadius:4},{label:"Sesi",data:zd.map(d=>d.s),backgroundColor:"rgba(232,141,58,0.75)",borderRadius:4}]},options:{responsive:true,scales:{y:{beginAtZero:true}}}});
  },80);
}

// ══════════════════════════════════════════
// ADMIN UTAMA — PENGURUSAN SISTEM
// ══════════════════════════════════════════
function pgAUHebahan(c){
  const items = getHebItems();

  c.innerHTML = `
  <div class="afu" style="background:linear-gradient(135deg,#132238,#1F2C50);border-radius:12px;padding:18px 22px;margin-bottom:18px;color:#fff;">
    <div style="font-size:.7rem;color:rgba(255,255,255,0.5);margin-bottom:4px;"><i class="fas fa-bullhorn mr-2"></i>PENGURUSAN SISTEM</div>
    <div style="font-family:'Outfit',sans-serif;font-weight:800;font-size:1.2rem;">Hebahan Portal</div>
    <div style="font-size:.78rem;color:rgba(255,255,255,0.5);margin-top:3px;">Urus teks & gambar carousel di portal awam</div>
  </div>

  <!-- Maklumat Saiz -->
  <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:12px 16px;margin-bottom:16px;font-size:12px;color:#92400e;display:flex;gap:10px;align-items:center;">
    <i class="fas fa-ruler-combined" style="font-size:16px;flex-shrink:0;"></i>
    <div>
      <b>Spesifikasi Gambar Carousel:</b> JPEG / PNG &nbsp;·&nbsp;
      <b>Saiz: 420 × 160 piksel</b> (nisbah 2:1) &nbsp;·&nbsp;
      Saiz fail: maksimum <b>2MB</b> &nbsp;·&nbsp;
      Maksimum <b>8 gambar</b> dalam carousel
    </div>
  </div>

  <!-- Carousel Preview -->
  <div class="card" style="margin-bottom:16px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-eye text-pri-500 mr-2"></i>Pratonton Carousel</span></div>
    <div class="card-body">
      <div style="width:420px;height:160px;border-radius:8px;overflow:hidden;position:relative;background:#0a0a2e;margin:0 auto;">
        <div id="prev-slides" style="display:flex;height:100%;transition:transform .4s ease;"></div>
        <div id="prev-empty" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:12px;">Tiada gambar</div>
        <div id="prev-dots" style="position:absolute;bottom:6px;left:0;right:0;display:flex;justify-content:center;gap:5px;"></div>
      </div>
      <div style="text-align:center;margin-top:8px;font-size:11px;color:var(--muted);">
        <button onclick="prevNav(-1)" class="btn btn-ghost btn-sm" style="font-size:11px;">‹</button>
        &nbsp;<span id="prev-idx">—</span>&nbsp;
        <button onclick="prevNav(1)" class="btn btn-ghost btn-sm" style="font-size:11px;">›</button>
      </div>
    </div>
  </div>

  <!-- Tambah Gambar Baharu -->
  <div class="card" style="margin-bottom:16px;">
    <div class="card-head"><span class="card-title"><i class="fas fa-plus text-pri-500 mr-2"></i>Tambah Gambar Baharu</span></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
        <div>
          <label class="fl">Gambar (JPEG/PNG, 320×160px) <span style="color:red">*</span></label>
          <input type="file" accept="image/jpeg,image/png,image/jpg" id="heb-gambar" class="fi" onchange="prevGambar(this)">
          <canvas id="heb-canvas" style="display:none;"></canvas>
          <img id="heb-prev-img" style="display:none;width:160px;height:80px;object-fit:cover;border-radius:6px;margin-top:6px;border:1px solid var(--border);">
        </div>
        <div>
          <label class="fl">Tajuk / Kapsyen</label>
          <input type="text" id="heb-tajuk" class="fi" placeholder="Contoh: Program Minda Sihat 2025">
          <label class="fl" style="margin-top:8px;">Pautan (klik gambar)</label>
          <input type="text" id="heb-url" class="fi" placeholder="https://...">
        </div>
      </div>
      <button onclick="tambahHebGambar()" class="btn btn-pri"><i class="fas fa-upload mr-1"></i> Tambah ke Carousel</button>
    </div>
  </div>

  <!-- Senarai Gambar -->
  <div class="card">
    <div class="card-head">
      <span class="card-title"><i class="fas fa-images text-amb-500 mr-2"></i>Gambar dalam Carousel</span>
      <span style="font-size:.72rem;color:var(--muted);">${items.length} / 8</span>
    </div>
    <div id="heb-list" class="card-body">${renderHebList(items)}</div>
  </div>`;

  refreshPrev();
}

let _prevIdx = 0;
function refreshPrev(){
  const items = getHebItems();
  const slides = document.getElementById("prev-slides");
  const empty  = document.getElementById("prev-empty");
  const dots   = document.getElementById("prev-dots");
  const idxEl  = document.getElementById("prev-idx");
  if(!slides) return;
  if(!items.length){
    slides.innerHTML=""; if(empty)empty.style.display="flex";
    if(dots)dots.innerHTML=""; if(idxEl)idxEl.textContent="—"; return;
  }
  if(empty) empty.style.display="none";
  slides.style.width=(items.length*420)+"px";
  slides.innerHTML=items.map((h,i)=>`
    <div style="width:420px;height:160px;flex-shrink:0;position:relative;">
      <img src="${h.gambar}" style="width:100%;height:100%;object-fit:cover;">
      ${h.tajuk?`<div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.65));padding:6px 8px;color:#fff;font-size:11px;font-weight:600;">${h.tajuk}</div>`:""}
    </div>`).join("");
  if(dots) dots.innerHTML=items.map((_,i)=>`<div style="width:6px;height:6px;border-radius:50%;background:${i===_prevIdx?"#fff":"rgba(255,255,255,.4)"};"></div>`).join("");
  if(idxEl) idxEl.textContent=(_prevIdx+1)+" / "+items.length;
  slides.style.transform=`translateX(-${_prevIdx*420}px)`;
}
function prevNav(d){ const n=getHebItems().length; if(!n)return; _prevIdx=(_prevIdx+d+n)%n; refreshPrev(); }

function prevGambar(input){
  const file = input.files[0]; if(!file) return;
  if(file.size > 2097152){ toast("Fail terlalu besar. Maksimum 2MB.","err"); input.value=""; return; }
  const reader = new FileReader();
  reader.onload = e => {
    // Resize to 320x160
    const img = new Image();
    img.onload = () => {
      const canvas = document.getElementById("heb-canvas");
      canvas.width=420; canvas.height=160;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(img,0,0,320,160);
      const resized = canvas.toDataURL("image/jpeg",0.85);
      const prev = document.getElementById("heb-prev-img");
      if(prev){ prev.src=resized; prev.style.display="block"; }
      input._resized = resized;
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function tambahHebGambar(){
  const input = document.getElementById("heb-gambar");
  const tajuk = document.getElementById("heb-tajuk").value.trim();
  const url   = document.getElementById("heb-url").value.trim();
  const gambar = input._resized || "";
  if(!gambar){ toast("Sila pilih gambar dahulu","err"); return; }
  const items = getHebItems();
  if(items.length >= 8){ toast("Maksimum 8 gambar dalam carousel","err"); return; }
  items.push({gambar, tajuk, url, tarikh: new Date().toLocaleDateString("ms-MY")});
  localStorage.setItem("hebahan_gambar", JSON.stringify(items));
  // Reset form
  input.value=""; input._resized=null;
  document.getElementById("heb-tajuk").value="";
  document.getElementById("heb-url").value="";
  const prev = document.getElementById("heb-prev-img");
  if(prev) prev.style.display="none";
  document.getElementById("heb-list").innerHTML = renderHebList(items);
  refreshPrev();
  hcInit(); // Update portal carousel
  toast("Gambar berjaya ditambah ke carousel","ok");
}

function renderHebList(items){
  if(!items.length) return `<div style="text-align:center;padding:24px;color:var(--muted);font-size:13px;"><i class="fas fa-images" style="font-size:24px;display:block;margin-bottom:8px;opacity:.3;"></i>Tiada gambar dalam carousel</div>`;
  return `<div style="display:grid;gap:8px;">${items.map((h,i)=>`
    <div style="display:flex;align-items:center;gap:10px;padding:8px;border:1px solid var(--border);border-radius:8px;background:#fafafa;">
      <img src="${h.gambar}" style="width:80px;height:40px;object-fit:cover;border-radius:5px;flex-shrink:0;">
      <div style="flex:1;min-width:0;">
        <div style="font-weight:600;font-size:.82rem;">${h.tajuk||"(Tiada tajuk)"}</div>
        <div style="font-size:.7rem;color:var(--muted);">${h.tarikh||""} ${h.url?'· <a href="'+h.url+'" target="_blank" style="color:#0E7C61;">Pautan</a>':""}</div>
      </div>
      <div style="display:flex;gap:4px;flex-shrink:0;">
        ${i>0?`<button onclick="hcShift(${i},-1)" class="btn btn-ghost btn-xs" title="Ke atas"><i class="fas fa-arrow-up"></i></button>`:""}
        ${i<items.length-1?`<button onclick="hcShift(${i},1)" class="btn btn-ghost btn-xs" title="Ke bawah"><i class="fas fa-arrow-down"></i></button>`:""}
        <button onclick="hcRemove(${i})" class="btn btn-danger btn-xs btn-sm"><i class="fas fa-trash"></i></button>
      </div>
    </div>`).join("")}</div>`;
}

function hcRemove(i){
  if(!confirm("Padam gambar ini dari carousel?")) return;
  const items = getHebItems(); items.splice(i,1);
  localStorage.setItem("hebahan_gambar", JSON.stringify(items));
  document.getElementById("heb-list").innerHTML = renderHebList(items);
  _prevIdx = Math.min(_prevIdx, Math.max(0, items.length-1));
  refreshPrev(); hcInit();
  toast("Gambar dipadam","ok");
}

function hcShift(i, dir){
  const items = getHebItems();
  const j = i + dir;
  if(j<0||j>=items.length) return;
  [items[i],items[j]] = [items[j],items[i]];
  localStorage.setItem("hebahan_gambar", JSON.stringify(items));
  document.getElementById("heb-list").innerHTML = renderHebList(items);
  refreshPrev(); hcInit();
}


function pgAUMaklumatKampus(c){
  c.innerHTML=`
  <div class="mb-3 flex gap-2">
    <select class="fi" style="width:auto" onchange="filterMKZon(this.value)"><option value="">Semua Zon</option>${KLIST.map(z=>`<option>${z}</option>`).join("")}</select>
  </div>
  <div class="card">
    <div class="card-head"><span class="card-title">Senarai 27 Kampus IPG Malaysia</span></div>
    <div class="overflow-x-auto" id="tbl-mkampus">${renderTblKampus(KAMPUS)}</div>
  </div>`;
}

function filterMKZon(z){
  const d=z?KAMPUS.filter(k=>k.zona===z):KAMPUS;
  document.getElementById("tbl-mkampus").innerHTML=renderTblKampus(d);
}

function renderTblKampus(data){
  return`<table class="tbl"><thead><tr><th>#</th><th>Nama Kampus</th><th>Zon</th><th>Negeri</th><th>Pelajar</th><th>Pensyarah</th><th>Pegawai</th><th>Sesi</th></tr></thead>
  <tbody>${data.map((k,i)=>{const kd=APP.kampusData[k.id];return`<tr>
    <td class="text-gray-400 text-xs">${String(i+1).padStart(2,"0")}</td>
    <td class="font-medium">${k.nama}</td>
    <td><span class="bdg bdg-navy text-xs">${k.zona}</span></td>
    <td class="text-xs">${k.negeri}</td>
    <td>${kd.pelajar.length}</td><td>${kd.pensyarah.length}</td><td>${kd.pegawai.length}</td><td>${kd.statsesi}</td>
  </tr>`;}).join("")}</tbody></table>`;
}

