function simpanTukarPw(idx){
  const pw1=document.getElementById("tp-pw1").value.trim();
  const pw2=document.getElementById("tp-pw2").value.trim();
  if(!pw1){toast("Kata laluan tidak boleh kosong","err");return;}
  if(pw1!==pw2){toast("Kata laluan tidak sepadan","err");return;}
  APP.pengguna[idx].kataLaluan=pw1;
  saveApp(); closeModal(); navTo("au-pengguna"); toast("Kata laluan berjaya dikemaskini","ok");
}

function simpanPengguna(idx, oldId=""){
  const id=document.getElementById("pu-id").value.trim();
  const nama=document.getElementById("pu-nama").value.trim();
  const role=document.getElementById("pu-role").value;
  const kampus=role==="admin_utama"?null:document.getElementById("pu-kampus").value;
  const pw=document.getElementById("pu-pw").value.trim();

  // Validasi
  if(!id){toast("ID pengguna tidak boleh kosong","err");return;}
  if(!nama){toast("Nama pengguna tidak boleh kosong","err");return;}
  if(!pw){toast("Kata laluan tidak boleh kosong","err");return;}
  if(role==="admin_kampus"&&!kampus){toast("Sila pilih kampus","err");return;}

  if(idx>=0){
    // KEMASKINI — semak jika ID ditukar
    if(id !== oldId){
      // Semak ID baru tidak konflik dengan pengguna lain
      const conflict = APP.pengguna.find((x,i)=>x.id===id && i!==idx);
      if(conflict){toast(`ID "${id}" sudah digunakan oleh ${conflict.nama}. Sila guna ID lain`,"err");return;}
    }
    APP.pengguna[idx]={id,nama,peranan:role,kampus,kataLaluan:pw};
    toast(`Maklumat ${nama} berjaya dikemaskini`,"ok");
  } else {
    // TAMBAH BAHARU
    if(APP.pengguna.find(x=>x.id===id)){toast(`ID "${id}" sudah wujud. Sila guna ID lain`,"err");return;}
    APP.pengguna.push({id,nama,peranan:role,kampus,kataLaluan:pw});
    toast(`Pengguna baharu ${nama} berjaya ditambah`,"ok");
  }
  saveApp(true); closeModal(); navTo("au-pengguna");
}

function hapusPengguna(i){
  const u=APP.pengguna[i];
  if(!confirm(`Padam akaun "${u.nama}" (${u.id})?

Tindakan ini tidak boleh dibatalkan.`))return;
  APP.pengguna.splice(i,1); saveApp(); navTo("au-pengguna"); toast("Akaun dipadam","ok");
}

function kemaskiniKataLaluanPukal(){
  const kid=document.getElementById("bulk-kampus").value;
  const pw=document.getElementById("bulk-pw").value.trim();
  if(!kid){toast("Sila pilih kampus","err");return;}
  if(!pw){toast("Sila masukkan kata laluan baharu","err");return;}
  const aff=APP.pengguna.filter(u=>u.kampus===kid);
  if(!aff.length){toast("Tiada pengguna untuk kampus ini","err");return;}
  if(!confirm(`Kemaskini kata laluan untuk ${aff.length} pengguna kampus ${kNama(kid)}?

Kata Laluan Baharu: ${pw}`))return;
  aff.forEach(u=>u.kataLaluan=pw);
  saveApp(); navTo("au-pengguna"); toast(`${aff.length} kata laluan berjaya dikemaskini`,"ok");
}

function pgAUHubungi(c){
